# Behold.so Instagram feed ID — get this from behold.so dashboard after connecting @somosrecoficial
# When unset, the InstagramFeed component falls back to static seed data.
PUBLIC_BEHOLD_FEED_ID=

# Decap CMS GitHub OAuth (only needed if using GitHub backend)
# After authorizing the Decap app on the GitHub repo, no extra env vars needed
# (Decap exchanges the OAuth in-browser via a Vercel function — see /api/cms-auth.ts).
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Vercel KV (auto-populated by Vercel when KV is provisioned in dashboard)
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
