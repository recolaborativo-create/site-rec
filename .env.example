# ──────────────────────────────────────────────────────────────────────────────
#  REC Colaborativo — Variáveis de Ambiente
# ──────────────────────────────────────────────────────────────────────────────
#  Em LOCAL: copie pra `.env` e preencha (`.env` NUNCA vai pro Git).
#  Em PROD: configurar no painel da Vercel → Settings → Environment Variables.
# ──────────────────────────────────────────────────────────────────────────────

# ===== SUPABASE (avaliações de empresas + drafts de blog) =====
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE=

# ===== MODERAÇÃO (acesso ao painel /moderacao e /aprovacao-blog) =====
# Crie um token aleatório forte (mín 20 chars). Será usado pra autenticar.
MOD_SECRET=

# ===== BREVO (newsletter do blog + email de aprovação do blog auto) =====
BREVO_API_KEY=
BREVO_LIST_ID=2
CONTATO_TO_EMAIL=henrique@somosrecoficial.com.br
CONTATO_FROM_EMAIL=site@somosrecoficial.com.br

# Email pra notificação do blog automático mensal (separado)
BLOG_NOTIFY_EMAIL=henrique.callefi@gmail.com

# ===== NOTION (banco de eventos) =====
NOTION_TOKEN=

# ===== GOOGLE PLACES (reviews das empresas parceiras) =====
GOOGLE_PLACES_API_KEY=

# ===== INSTAGRAM (Behold.so) =====
PUBLIC_BEHOLD_FEED_ID=

# ===== DECAP CMS (painel /admin) — GitHub OAuth =====
# Crie em https://github.com/settings/developers → "New OAuth App"
# Callback URL: https://recolaborativo.com.br/api/auth/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ===== VERCEL KV (opcional, reservado pra cache futuro) =====
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
#  BLOG AUTOMÁTICO MENSAL
# ──────────────────────────────────────────────────────────────────────────────

# Anthropic API — escreve os 9 posts mensais
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Opcional: trocar pra "claude-sonnet-4-5" pra qualidade maior (custa mais)
ANTHROPIC_MODEL=claude-haiku-4-5

# Brave Search API — opcional. Sem isso, usa tópicos evergreen.
# Get key: https://brave.com/search/api/
BRAVE_SEARCH_KEY=

# Unsplash — imagens automáticas pros posts
UNSPLASH_ACCESS_KEY=

# GitHub Personal Access Token — pra publicar drafts aprovados como .md no repo
# Criar em https://github.com/settings/tokens (clássico ou fine-grained)
# Escopo necessário: `repo` (clássico) OU "Contents: read+write" (fine-grained)
GITHUB_PAT=
GITHUB_OWNER=HenriqueCallefi
GITHUB_REPO=REC-HUB-COMPLETO
GITHUB_BRANCH=main

# Cron secret — token que valida invocações manuais do endpoint /api/cron/*.
# A Vercel manda automaticamente nos seus crons agendados, então só precisa
# disso pra testar manualmente via curl.
CRON_SECRET=
