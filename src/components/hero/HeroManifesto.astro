---
import { whatsappLink, messages } from '../../utils/whatsapp'
import StatCounter from '../ui/StatCounter.astro'
---
<section class="hero-manifesto" data-hero>
  <video
    class="hero-video"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    aria-hidden="true"
  >
    <source src="/video/home-bg.mp4" type="video/mp4" />
    <source src="/video/home-bg.webm" type="video/webm" />
    <source src="/video/home-bg.mov" type="video/mp4" />
  </video>
  <div class="hero-content">
    <h1 class="hero-statement" aria-label="Movimento gera movimento">
      <span class="word-mask word-1"><span class="word fade">Movimento</span></span>
      <span class="word-mask word-2"><span class="word emphasis">gera</span></span>
      <span class="word-mask word-3"><span class="word fade">movimento.</span></span>
    </h1>
    <p class="hero-sub">Um ecossistema de empresas que crescem porque se movem juntas.</p>
    <a class="hero-cta" href={whatsappLink(messages.heroManifesto)} target="_blank" rel="noopener">começa agora →</a>
  </div>

  <div class="hero-stats" data-reveal>
    <div class="hero-stats-inner">
      <StatCounter target={10} prefix="+" suffix=" mil" label="conexões geradas" />
      <StatCounter target={90} prefix="+de " label="empresas conectadas" />
      <StatCounter target={8} label="anos de movimento" />
      <StatCounter target={30} prefix="+R$ " suffix="M" label="em receita gerada" />
    </div>
  </div>
</section>

<style>
.hero-manifesto { position: relative; min-height: 100vh; min-height: 100dvh; display: flex; flex-direction: column; justify-content: space-between; padding: var(--space-16) var(--space-6) var(--space-16); background: var(--grad-hero-teal); overflow: hidden; isolation: isolate; }
.hero-manifesto::after {
  content: "";
  position: absolute;
  inset: 0;
  z-index: -1;
  background: linear-gradient(
    180deg,
    rgba(1,38,89,0.72) 0%,
    rgba(1,38,89,0.68) 12%,
    rgba(1,38,89,0.64) 24%,
    rgba(1,38,89,0.58) 38%,
    rgba(1,38,89,0.50) 50%,
    rgba(1,38,89,0.42) 62%,
    rgba(1,38,89,0.28) 74%,
    rgba(1,38,89,0.16) 82%,
    rgba(255,255,255,0.35) 89%,
    rgba(255,255,255,0.75) 95%,
    #ffffff 100%
  );
  pointer-events: none;
}
.hero-video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: -2; opacity: 0.42; filter: saturate(0.85) contrast(0.95) brightness(0.85); animation: hero-video-fade 1.6s ease-out both; }
@keyframes hero-video-fade { from { opacity: 0; } to { opacity: 0.42; } }
.hero-content { max-width: var(--container-max); margin: 0 auto; width: 100%; display: flex; flex-direction: column; gap: var(--space-6); flex: 1; justify-content: center; padding: var(--space-12) 0; }
.hero-statement {
  font-size: clamp(2.4rem, 8vw, 5.5rem);
  font-weight: 800;
  line-height: 1;
  letter-spacing: var(--letter-tight);
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
  margin: var(--space-3) 0;
  color: #fff;
}
/* Mask container — clips the word until it slides up */
.hero-statement .word-mask {
  display: block;
  overflow: hidden;
  padding-bottom: 0.12em; /* space for descenders + softens clip line */
  line-height: 1;
}
.hero-statement .word {
  display: inline-block;
  will-change: transform;
  /* Layered shadow — close drop + soft halo + subtle glow for depth */
  text-shadow:
    0 2px 4px rgba(0,0,0,0.45),
    0 6px 18px rgba(0,0,0,0.40),
    0 14px 40px rgba(1,38,89,0.55);
}
.hero-statement .fade { color: var(--rec-teal); font-weight: 700; }
.hero-statement .emphasis { color: #fff; font-weight: 800; font-style: italic; }
.hero-sub { max-width: 520px; font-size: var(--type-body); color: #fff; font-weight: 500; line-height: 1.6; text-shadow: 0 1px 12px rgba(0,0,0,0.32); }
.hero-cta { display: inline-flex; align-self: flex-start; background: #fff; color: var(--rec-blue); padding: 14px 28px; border-radius: 8px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; font-size: var(--type-small); transition: transform var(--motion-fast) var(--easing), box-shadow var(--motion-fast) var(--easing); box-shadow: 0 4px 16px rgba(0,0,0,0.18); }
.hero-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.28); }

/* STATS INSIDE HERO — same video bg, white type */
.hero-stats { position: relative; z-index: 1; padding: var(--space-10) 0 var(--space-12); }
.hero-stats-inner { max-width: var(--container-max); margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-6); text-align: center; }
.hero-stats :global(.stat-counter) { text-align: center; }
.hero-stats :global(.stat-value) { color: #fff; text-shadow: 0 2px 12px rgba(1,38,89,0.85), 0 1px 3px rgba(1,38,89,0.95); }
.hero-stats :global(.stat-label) { color: rgba(255,255,255,0.92); font-weight: 700; text-shadow: 0 1px 6px rgba(1,38,89,0.7); }
@media (max-width: 900px) { .hero-stats-inner { grid-template-columns: repeat(2, 1fr); } }
/* Só telas MUITO pequenas (Galaxy Fold etc) caem pra 1 coluna */
@media (max-width: 340px) { .hero-stats-inner { grid-template-columns: 1fr; gap: var(--space-4); } }

/* MOBILE — padding lateral menor + CTA full-width pra touch */
@media (max-width: 640px) {
  /* Hero do mobile: SÓ título + subtítulo + CTA (sem stats) */
  .hero-manifesto {
    min-height: auto;
    padding: var(--space-10) var(--space-4) var(--space-8);
  }
  .hero-content { padding: var(--space-4) 0; gap: var(--space-4); flex: none; }
  .hero-statement {
    gap: var(--space-1);
    font-size: clamp(2.2rem, 11vw, 3rem);
  }
  .hero-sub { font-size: 0.95rem; }
  .hero-cta {
    align-self: stretch;
    text-align: center;
    justify-content: center;
    padding: 14px 24px;
    min-height: 50px;
    font-size: 0.85rem;
  }

  /* Stats viram parte natural do hero (degradê do vídeo passa por baixo). Sem fundo próprio. */
  .hero-stats {
    position: relative;
    z-index: 2;
    padding: var(--space-2) 0 var(--space-3);
    background: transparent;
    border-top: none;
    /* Esconde no mobile — vai aparecer em "três portas" */
    display: none;
  }
}

@media (prefers-reduced-motion: reduce) {
  .hero-video { display: none; }
}
</style>

<script>
  import { initHero } from './hero-animation'
  initHero()
</script>
