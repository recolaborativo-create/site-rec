---
interface Props {
  pulse?: boolean
  size?: 'sm' | 'md' | 'lg'
  inverted?: boolean
}
const { pulse = false, size = 'md', inverted = false } = Astro.props
---
<span class:list={['dot-logo', `size-${size}`, { pulse, inverted }]} aria-hidden="true">
  <span class="dot dot-1"></span>
  <span class="dot dot-2"></span>
  <span class="dot dot-3"></span>
</span>

<style>
.dot-logo { display: inline-flex; gap: var(--space-2); align-items: center; }
.dot { border-radius: 50%; display: inline-block; }
.dot-1, .dot-3 { background: var(--rec-purple); }
.dot-2 { background: var(--rec-teal); }
.size-sm .dot { width: 8px; height: 8px; }
.size-md .dot { width: 12px; height: 12px; }
.size-lg .dot { width: 16px; height: 16px; }
.inverted .dot-1, .inverted .dot-3 { background: #fff; }
.pulse .dot { animation: pulse-dot 2s ease-in-out infinite; }
.pulse .dot-2 { animation-delay: 0.3s; }
.pulse .dot-3 { animation-delay: 0.6s; }
@keyframes pulse-dot { 0%, 100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.3); opacity: 0.6; } }
</style>
