---
// Decorative REC-themed graphics that fade/float in as the user scrolls.
// They use mix-blend-mode: multiply so they blend visually with whatever
// section background sits beneath them (instead of being hidden by opaque bg).
// Section content wrappers have a higher z-index so text stays above them.
---
<div class="scroll-graphics" aria-hidden="true">
  <!-- 1. Three-bar mark (REC icon) — appears just below hero -->
  <div class="sg-item sg-bars" data-sg-pos="0.18">
    <span class="sg-bar"></span>
    <span class="sg-bar"></span>
    <span class="sg-bar"></span>
  </div>

  <!-- 2. Dotted ring — paths section, right side -->
  <svg class="sg-item sg-dots" data-sg-pos="0.28" viewBox="0 0 220 220" width="220" height="220">
    <g fill="currentColor">
      {Array.from({ length: 32 }).map((_, i) => {
        const a = (i / 32) * Math.PI * 2
        const cx = 110 + Math.cos(a) * 90
        const cy = 110 + Math.sin(a) * 90
        return <circle cx={cx} cy={cy} r={2.6} />
      })}
    </g>
  </svg>

  <!-- 3. Hand-drawn squiggle line — fundadora area, left -->
  <svg class="sg-item sg-squiggle" data-sg-pos="0.42" viewBox="0 0 320 80" width="320" height="80">
    <path d="M4 48 C 40 8, 80 88, 120 40 S 200 12, 240 56 S 300 24, 316 44" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
  </svg>

  <!-- 4. Soft circle accent — impact section, right -->
  <div class="sg-item sg-circle" data-sg-pos="0.55"></div>

  <!-- 5. Diamond grid — blog area, left -->
  <svg class="sg-item sg-diamonds" data-sg-pos="0.7" viewBox="0 0 100 160" width="100" height="160">
    <g fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round">
      <polygon points="28,8 48,28 28,48 8,28" />
      <polygon points="68,8 88,28 68,48 48,28" />
      <polygon points="28,68 48,88 28,108 8,88" />
      <polygon points="68,68 88,88 68,108 48,88" />
      <polygon points="28,128 48,148 28,168 8,148" />
      <polygon points="68,128 88,148 68,168 48,148" />
    </g>
  </svg>

  <!-- 6. Second three-bar mark, near footer -->
  <div class="sg-item sg-bars sg-bars-sm" data-sg-pos="0.85">
    <span class="sg-bar"></span>
    <span class="sg-bar"></span>
    <span class="sg-bar"></span>
  </div>
</div>

<style>
/* The wrapper covers the entire main area and uses mix-blend-mode so each
   graphic visually blends with the section background sitting beneath it.
   z-index sits above section backgrounds; section content wrappers in
   index.astro have a higher z-index so text remains crisp on top. */
.scroll-graphics {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 1;
  mix-blend-mode: multiply;
}

.sg-item {
  position: absolute;
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 900ms ease-out, transform 1100ms cubic-bezier(0.22, 0.7, 0.16, 1);
  will-change: opacity, transform;
}
.sg-item.in-view {
  opacity: 1;
  transform: translateY(0);
}

/* ---- 1. Three bars (REC icon mark) — proporção e cores oficiais ---- */
.sg-bars {
  display: flex;
  flex-direction: column;
  gap: 6px;
  left: 4vw;
  top: 110vh;
}
.sg-bar { display: block; height: 14px; border-radius: 999px; }
.sg-bars .sg-bar:nth-child(1) { width: 140px; background: var(--rec-blue); }
.sg-bars .sg-bar:nth-child(2) { width: 115px; background: var(--rec-teal); }
.sg-bars .sg-bar:nth-child(3) { width: 70px;  background: var(--rec-blue); }
.sg-bars-sm { left: auto; right: 5vw; top: 500vh; }
.sg-bars-sm .sg-bar { height: 10px; }
.sg-bars-sm .sg-bar:nth-child(1) { width: 95px; background: var(--rec-blue); }
.sg-bars-sm .sg-bar:nth-child(2) { width: 78px; background: var(--rec-teal); }
.sg-bars-sm .sg-bar:nth-child(3) { width: 48px; background: var(--rec-blue); }

/* ---- 2. Dot ring ---- */
.sg-dots {
  right: -50px;
  top: 165vh;
  color: rgba(1,38,89,0.45);
}

/* ---- 3. Squiggle ---- */
.sg-squiggle {
  left: -20px;
  top: 252vh;
  color: rgba(0,161,152,0.65);
}

/* ---- 4. Soft circle accent ---- */
.sg-circle {
  right: -60px;
  top: 305vh;
  width: 320px;
  height: 320px;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(184,224,221,0.95), rgba(184,224,221,0) 70%);
}

/* ---- 5. Diamond grid ---- */
.sg-diamonds {
  left: 4vw;
  top: 428vh;
  color: rgba(0,161,152,0.45);
}

@media (max-width: 760px) {
  .sg-bars { left: -4vw; }
  .sg-bars .sg-bar:nth-child(1) { width: 160px; }
  .sg-bars .sg-bar:nth-child(2) { width: 110px; }
  .sg-bars .sg-bar:nth-child(3) { width: 60px; }
  .sg-circle { width: 220px; height: 220px; right: -8vw; }
  .sg-dots { right: -90px; }
  .sg-squiggle { left: -40px; }
}
/* Mobile: esconde gráficos decorativos pra não atrapalhar conteúdo */
@media (max-width: 640px) {
  .scroll-graphics { display: none; }
}
</style>

<script>
  const items = document.querySelectorAll<HTMLElement>('.scroll-graphics .sg-item')
  if (items.length) {
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches
    if (reduce) {
      items.forEach(el => el.classList.add('in-view'))
    } else {
      const obs = new IntersectionObserver(
        entries => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              ;(e.target as HTMLElement).classList.add('in-view')
              obs.unobserve(e.target)
            }
          })
        },
        { threshold: 0.05, rootMargin: '0px 0px -10% 0px' },
      )
      items.forEach(el => obs.observe(el))

      // Subtle parallax — drifts the items down a few px as the user scrolls
      const onScroll = () => {
        const y = window.scrollY
        items.forEach(el => {
          if (!el.classList.contains('in-view')) return
          const factor = parseFloat(el.dataset.sgPos || '0.5')
          el.style.transform = `translateY(${y * factor * 0.04}px)`
        })
      }
      window.addEventListener('scroll', onScroll, { passive: true })
    }
  }
</script>
