---
import { whatsappLink, messages, type WhatsAppMessageKey } from '../../utils/whatsapp'

interface Props {
  name: string
  price?: string
  priceSuffix?: string
  summary?: string
  bullets: string[]
  addOns?: string[]
  featured?: boolean
  ctaKey: WhatsAppMessageKey
  ctaText?: string
  hidePrice?: boolean
}
const {
  name,
  price,
  priceSuffix = '/mês',
  summary,
  bullets,
  addOns = [],
  featured = false,
  ctaKey,
  ctaText = 'contratar',
  hidePrice = false,
} = Astro.props
const cta = whatsappLink(messages[ctaKey])
---
<article class:list={['plan-card', { featured, 'no-price': hidePrice }]}>
  {featured && <span class="featured-badge">popular</span>}
  <h3>{name}</h3>
  {summary && <p class="summary">{summary}</p>}
  {!hidePrice && price && (
    <div class="price"><span class="price-value">{price}</span><small>{priceSuffix}</small></div>
  )}
  <ul class="bullets">
    {bullets.map(b => <li>{b}</li>)}
  </ul>
  {addOns.length > 0 && (
    <div class="addons">
      <span class="addon-label">Add-ons opcionais</span>
      {addOns.map(a => <div class="addon">{a}</div>)}
    </div>
  )}
  <a href={cta} target="_blank" rel="noopener" class="card-cta">{ctaText}</a>
</article>

<style>
.plan-card { position: relative; padding: var(--space-8); background: #fff; border: 1px solid rgba(37,52,57,0.1); border-radius: 16px; display: flex; flex-direction: column; gap: var(--space-3); transition: transform var(--motion-fast) var(--easing), box-shadow var(--motion-fast) var(--easing); }
.plan-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(62,64,149,0.08); }
.plan-card.featured { border-color: var(--rec-purple); box-shadow: 0 8px 24px rgba(62,64,149,0.12); }
.featured-badge { position: absolute; top: -12px; right: 24px; background: var(--rec-teal); color: #fff; padding: 4px 12px; border-radius: 12px; font-size: var(--type-micro); letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700; }
.plan-card h3 { font-size: 1.4rem; color: var(--rec-dark); font-weight: 800; }
.summary { font-size: var(--type-small); color: #667; line-height: 1.5; }
.price { display: flex; align-items: baseline; gap: 4px; margin: var(--space-3) 0; }
.price-value { font-size: 2rem; font-weight: 800; color: var(--rec-purple); letter-spacing: var(--letter-tight); line-height: 1; }
.price small { font-size: var(--type-small); color: #667; font-weight: 400; }
.plan-card.no-price h3 { font-size: 1.5rem; }
.plan-card.no-price .summary { font-weight: 600; color: var(--rec-purple); margin-bottom: var(--space-2); }
.bullets { display: flex; flex-direction: column; gap: var(--space-2); margin-top: var(--space-2); }
.bullets li { font-size: var(--type-small); color: #444; line-height: 1.5; padding-left: 18px; position: relative; }
.bullets li::before { content: ''; position: absolute; left: 0; top: 9px; width: 8px; height: 8px; border-radius: 50%; background: var(--rec-teal); }
.addons { padding-top: var(--space-3); border-top: 1px dashed rgba(37,52,57,0.1); margin-top: var(--space-2); }
.addon-label { display: block; font-size: var(--type-micro); letter-spacing: 0.12em; text-transform: uppercase; color: #888; margin-bottom: 4px; font-weight: 600; }
.addon { font-size: var(--type-small); color: #556; }
.card-cta { display: block; text-align: center; margin-top: auto; padding: 12px 20px; background: var(--rec-purple); color: #fff; border-radius: 8px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; font-size: var(--type-micro); transition: background var(--motion-fast) var(--easing); }
.plan-card.featured .card-cta { background: var(--rec-teal); }
.card-cta:hover { background: var(--rec-teal); }
.plan-card.featured .card-cta:hover { background: var(--rec-purple); }
.plan-card.no-price .card-cta { background: transparent; color: var(--rec-purple); border: 1px solid var(--rec-purple); }
.plan-card.no-price.featured .card-cta { background: var(--rec-teal); color: #fff; border-color: var(--rec-teal); }
.plan-card.no-price .card-cta:hover { background: var(--rec-purple); color: #fff; }
</style>
