.card-cta:hover {
  box-shadow: 0 18px 44px rgba(0,161,152,0.44);
  background-position: 100% 0;
}
.cta-label { transition: opacity 180ms var(--easing); }
.cta-label.is-changing { opacity: 0; }
.cta-arrow { transition: transform var(--motion-fast) var(--easing); }
.card-cta:hover .cta-arrow { transform: translateX(4px); }

.card-foot {
  position: relative;
  z-index: 2;
  font-size: 0.78rem;
  font-style: italic;
  font-family: var(--font-display);
  color: rgba(1,38,89,0.55);
  line-height: 1.4;
  margin: 0;
}

/* ============================================
   BENEFITS BENTO
   ============================================ */
.showcase-benefits-col { padding-top: var(--space-4); }

.benefits-head { margin-bottom: var(--space-8); }
.benefits-eyebrow {
  display: inline-block;
  font-family: var(--font-ui);
  font-size: 0.66rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--rec-teal);
  padding: 5px 14px;
  border: 1px solid rgba(0,161,152,0.3);
  border-radius: 999px;
  margin-bottom: var(--space-4);
}
.benefits-head h3 {
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 3.2vw, 2.6rem);
  font-weight: 300;
  line-height: 1.15;
  letter-spacing: -0.02em;
  color: var(--rec-blue);
  margin: 0 0 var(--space-3);
}
.benefits-head h3 em { color: var(--rec-teal); font-style: italic; font-weight: 400; }
.benefits-lead {
  font-size: 0.96rem;
  line-height: 1.6;
  color: rgba(1,38,89,0.65);
  margin: 0;
  max-width: 540px;
}

.benefits-bento {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-4);
}
/* Mobile: mantém 2 colunas com cards compactos pra evitar lista vertical extensa */
@media (max-width: 640px) {
  .benefits-bento { grid-template-columns: 1fr 1fr; gap: var(--space-2); }
}

.benefit-cell {
  position: relative;
  padding: var(--space-6) var(--space-5);
  background: #fff;
  border: 1px solid rgba(1,38,89,0.08);
  border-radius: 18px;
  overflow: hidden;
  opacity: 0;
  transform: translateY(20px);
  transition:
    opacity 500ms var(--easing) calc(var(--i) * 60ms),
    transform 500ms var(--easing) calc(var(--i) * 60ms),
    border-color 320ms var(--easing),
    box-shadow 320ms var(--easing);
}
.benefit-cell.in-view { opacity: 1; transform: translateY(0); }
.benefit-cell:hover {
  border-color: rgba(0,161,152,0.32);
  box-shadow: 0 16px 36px rgba(1,38,89,0.06);
}

.benefit-cell-1 { grid-column: span 2; }
@media (max-width: 640px) {
  /* No mobile, todos cells viram 1 coluna do grid 2-col compacto */
  .benefit-cell-1 { grid-column: auto; }
  .benefit-cell { padding: var(--space-3) var(--space-3); border-radius: 12px; }
  .benefit-num { font-size: 1.1rem; top: var(--space-2); right: var(--space-3); }
  .benefit-icon { width: 32px; height: 32px; }
  .benefit-icon svg { width: 18px; height: 18px; }
  .benefit-cell h3 { font-size: 0.95rem; }
  .benefit-cell p { font-size: 0.78rem; line-height: 1.4; }
}

.benefit-num {
  position: absolute;
  top: var(--space-4);
  right: var(--space-5);
  font-family: var(--font-display);
  font-size: 1.6rem;
  font-weight: 200;
  font-style: italic;
  color: var(--rec-teal);
  opacity: 0.35;
  line-height: 1;
}
.benefit-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44px; height: 44px;
  background: rgba(0,161,152,0.1);
  border-radius: 12px;
  color: var(--rec-teal);
  margin-bottom: var(--space-4);
  transition: transform 320ms var(--easing), background 320ms var(--easing);
}
.benefit-icon svg { width: 22px; height: 22px; transition: transform 320ms var(--easing); }
.benefit-cell:hover .benefit-icon { background: rgba(0,161,152,0.18); transform: scale(1.08); }
.benefit-cell:hover .benefit-icon svg { transform: rotate(-6deg); }

.benefit-cell h4 {
  font-family: var(--font-display);
  font-size: 1.08rem;
  font-weight: 500;
  color: var(--rec-blue);
  letter-spacing: -0.01em;
  line-height: 1.25;
  margin: 0 0 var(--space-2);
}
.benefit-cell-1 h4 { font-size: 1.25rem; }
.benefit-cell p {
  font-size: 0.86rem;
  line-height: 1.55;
  color: rgba(1,38,89,0.7);
  margin: 0;
}

/* Gradient sweep on hover */
.benefit-sweep {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(120deg, transparent 30%, rgba(0,161,152,0.08) 50%, transparent 70%);
  transform: translateX(-100%);
  transition: transform 700ms var(--easing);
}
.benefit-cell:hover .benefit-sweep { transform: translateX(100%); }

/* ============================================
   STEPS TIMELINE
   ============================================ */
.com-steps {
  position: relative;
  padding: var(--space-12) var(--space-8);
  background: linear-gradient(135deg, #fff 0%, rgba(0,161,152,0.04) 100%);
  border: 1px solid rgba(0,161,152,0.14);
  border-radius: 24px;
}
.section-head {
  text-align: center;
  margin-bottom: var(--space-10);
}
.section-head h3 {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 2.8vw, 2.2rem);
  font-weight: 300;
  letter-spacing: -0.02em;
  line-height: 1.2;
  color: var(--rec-blue);
  margin: var(--space-3) 0 0;
}
.section-head h3 em { color: var(--rec-teal); font-style: italic; font-weight: 400; }

.steps-track {
  position: relative;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-8);
  max-width: 1020px;
  margin: 0 auto;
}
.steps-line {
  position: absolute;
  top: 28px;
  left: 12%;
  right: 12%;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--rec-teal) 20%, var(--rec-teal) 80%, transparent);
  opacity: 0.32;
}
@media (max-width: 780px) {
  .steps-track { grid-template-columns: 1fr; gap: var(--space-6); }
  .steps-line { display: none; }
}

.step {
  position: relative;
  text-align: center;
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 500ms var(--easing), transform 500ms var(--easing);
}
.step.in-view { opacity: 1; transform: translateY(0); }
.step-dot {
  position: relative;
  display: inline-flex;
  width: 56px; height: 56px;
  background: #fff;
  border: 2px solid var(--rec-teal);
  border-radius: 50%;
  margin: 0 auto var(--space-4);
  z-index: 1;
}
.step-dot::before {
  content: '';
  position: absolute;
  inset: 4px;
  border-radius: 50%;
  background: rgba(0,161,152,0.12);
  transition: background 320ms var(--easing);
}
.step:hover .step-dot::before { background: var(--rec-teal); }
.step-num {
  position: absolute;
  top: 12px;
  left: 50%;
  transform: translateX(-50%);
  font-family: var(--font-display);
  font-size: 1.2rem;
  font-weight: 400;
  font-style: italic;
  color: var(--rec-teal);
  line-height: 1;
  z-index: 2;
  transition: color 320ms var(--easing);
}
.step:hover .step-num { color: #fff; }

.step h4 {
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 500;
  color: var(--rec-blue);
  margin: 0 0 var(--space-2);
}
.step p {
  font-size: 0.88rem;
  line-height: 1.55;
  color: rgba(1,38,89,0.65);
  margin: 0;
  max-width: 280px;
  margin-left: auto;
  margin-right: auto;
}

/* ============================================
   MOBILE STICKY CTA BAR
   ============================================ */
.mobile-cta-bar {
  position: fixed;
  left: 0; right: 0;
  bottom: 0;
  z-index: 60;
  padding: var(--space-3) var(--space-4) calc(var(--space-3) + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.98);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1px solid rgba(1,38,89,0.1);
  box-shadow: 0 -8px 32px rgba(1,38,89,0.08);
  transform: translateY(120%);
  transition: transform 320ms var(--easing);
  display: none;
}
.mobile-cta-bar.is-visible { transform: translateY(0); }
@media (max-width: 1024px) { .mobile-cta-bar { display: block; } }

.mobile-cta-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-3);
  max-width: 560px;
  margin: 0 auto;
}
.mobile-cta-price {
  display: flex;
  align-items: baseline;
  gap: 2px;
  color: var(--rec-blue);
}
.mobile-cta-currency { font-family: var(--font-display); font-size: 0.9rem; font-weight: 400; }
.mobile-cta-value { font-family: var(--font-display); font-size: 1.5rem; font-weight: 400; letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }
.mobile-cta-suffix { font-family: var(--font-ui); font-size: 0.78rem; color: rgba(1,38,89,0.55); }
.mobile-cta-btn {
  display: inline-flex;
  align-items: center;
  padding: 12px 22px;
  background: linear-gradient(135deg, var(--rec-teal) 0%, var(--rec-blue) 100%);
  color: #fff;
  border-radius: 999px;
  font-family: var(--font-ui);
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-decoration: none;
  text-transform: lowercase;
  box-shadow: 0 8px 20px rgba(0,161,152,0.28);
}

/* ============================================
   NETWORK GRAPHIC (coluna esquerda)
   ============================================ */
.net-graphic {
  margin-top: var(--space-6);
  border-radius: 22px;
  border: 1px solid rgba(0,161,152,0.14);
  background:
    radial-gradient(circle at 50% 50%, rgba(0,161,152,0.06) 0%, transparent 55%),
    linear-gradient(160deg, #fafcfc 0%, #f5fafd 50%, #eef5fb 100%);
  position: relative;
  height: 360px;
  overflow: hidden;
  cursor: crosshair;
  transition: border-color 500ms var(--easing), box-shadow 500ms var(--easing), background 500ms var(--easing);
  box-shadow: 0 4px 24px rgba(1,38,89,0.04);
}
.net-graphic:hover,
.net-graphic.is-active {
  border-color: rgba(0,161,152,0.38);
  box-shadow: 0 12px 42px rgba(0,161,152,0.14);
}
@media (max-width: 1024px) { .net-graphic { display: none; } }

.net-canvas {
  display: block;
  width: 100%;
  height: 100%;
  position: absolute;
  inset: 0;
}

/* ===== Núcleo central — SUA EMPRESA ===== */
.net-core {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 76px;
  height: 76px;
  z-index: 2;
  pointer-events: none;
}
.net-core-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 1px solid rgba(0,161,152,0.35);
  animation: core-ring-pulse 2.6s ease-out infinite;
  opacity: 0;
}
.net-core-ring-2 { animation-delay: 0.85s; }
.net-core-ring-3 { animation-delay: 1.7s; }
@keyframes core-ring-pulse {
  0%   { transform: scale(0.85); opacity: 0; }
  20%  { opacity: 0.6; }
  100% { transform: scale(2.3); opacity: 0; }
}
.net-graphic.is-active .net-core-ring { animation-duration: 1.8s; border-color: rgba(0,161,152,0.55); }

.net-core-card {
  position: absolute;
  inset: 8px;
  background: linear-gradient(135deg, #ffffff 0%, #f4fbfa 100%);
  border: 1.5px solid rgba(0,161,152,0.55);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  box-shadow:
    0 0 0 4px rgba(0,161,152,0.08),
    0 14px 32px rgba(0,161,152,0.22),
    inset 0 1px 2px rgba(255,255,255,0.9);
  transition: transform 500ms cubic-bezier(0.34, 1.2, 0.4, 1), box-shadow 500ms var(--easing);
}
.net-graphic.is-active .net-core-card {
  transform: scale(1.06);
  box-shadow:
    0 0 0 6px rgba(0,161,152,0.14),
    0 20px 48px rgba(0,161,152,0.36),
    inset 0 1px 2px rgba(255,255,255,0.9);
}
.net-core-label {
  font-family: var(--font-ui);
  font-size: 0.52rem;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--rec-blue);
  text-align: center;
  line-height: 1.1;
  padding: 0 4px;
}
.net-core-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--rec-teal);
  box-shadow: 0 0 0 3px rgba(0,161,152,0.2), 0 0 12px rgba(0,161,152,0.6);
  animation: core-dot-pulse 1.8s ease-in-out infinite;
}
@keyframes core-dot-pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50%      { transform: scale(1.3); opacity: 0.7; }
}

/* ===== Labels de segmento (orbitais) ===== */
.net-tags {
  position: absolute;
  inset: 0;
  list-style: none;
  margin: 0;
  padding: 0;
  pointer-events: none;
  z-index: 1;
}
.net-tag {
  position: absolute;
  top: 0; left: 0;
  font-family: var(--font-ui);
  font-size: 0.58rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: lowercase;
  color: rgba(1,38,89,0.6);
  background: rgba(255,255,255,0.85);
  border: 1px solid rgba(0,161,152,0.22);
  border-radius: 999px;
  padding: 3px 9px;
  white-space: nowrap;
  opacity: 0.4;
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  transition: opacity 400ms var(--easing), border-color 400ms var(--easing), color 400ms var(--easing);
  will-change: transform, opacity;
}
.net-graphic.is-active .net-tag {
  border-color: rgba(0,161,152,0.45);
  color: var(--rec-blue);
}

/* ===== Hint inferior ===== */
.net-hint {
  position: absolute;
  bottom: var(--space-4);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-ui);
  font-size: 0.58rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(0,161,152,0.6);
  white-space: nowrap;
  pointer-events: none;
  margin: 0;
  z-index: 3;
  transition: opacity 400ms var(--easing);
}
.net-hint-pulse {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--rec-teal);
  box-shadow: 0 0 0 0 rgba(0,161,152,0.6);
  animation: hint-pulse 1.6s ease-out infinite;
}
@keyframes hint-pulse {
  0%   { box-shadow: 0 0 0 0 rgba(0,161,152,0.55); }
  100% { box-shadow: 0 0 0 10px rgba(0,161,152,0); }
}
.net-graphic.is-active .net-hint { opacity: 0; }
@media (prefers-reduced-motion: reduce) {
  .net-core-ring, .net-core-dot, .net-hint-pulse { animation: none; }
}

/* ============================================
   RESPONSIVE
   ============================================ */
@media (max-width: 600px) {
  .com-showcase { padding: 0 var(--space-4) var(--space-16); }
  .plan-card { padding: var(--space-8) var(--space-6) var(--space-6); border-radius: 22px; }
  .com-steps { padding: var(--space-8) var(--space-5); border-radius: 18px; }
}

/* ============================================
   CLUBE CERTO — benefício exclusivo associadas
   ============================================ */
.clube-certo {
  margin: var(--space-12) 0;
  padding: var(--space-12) var(--space-6);
  background: linear-gradient(160deg, #f7fbfd 0%, #eef6fc 100%);
  border-radius: 22px;
  border: 1px solid rgba(0,161,152,0.12);
}
.clube-certo-inner {
  max-width: 560px;
  margin: 0 auto;
}
.clube-certo-header {
  text-align: center;
  margin-bottom: var(--space-8);
}
.clube-certo-header h3 {
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 3.6vw, 2.4rem);
  font-weight: 300;
  color: var(--rec-blue);
  margin: var(--space-2) 0 var(--space-3);
  line-height: 1.1;
}
.clube-certo-header h3 em {
  color: var(--rec-teal);
  font-style: italic;
  font-weight: 400;
}
.clube-certo-header p {
  color: rgba(1,38,89,0.65);
  max-width: 520px;
  margin: 0 auto;
  line-height: 1.65;
  font-size: var(--type-small);
}

/* Grid de marcas principais */
.clube-brands {
  list-style: none;
  margin: 0 0 var(--space-3);
  padding: 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-3);
}
.clube-brand {
  background: #fff;
  border: 1px solid rgba(0,161,152,0.12);
  border-radius: 14px;
  padding: var(--space-4) var(--space-3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  min-height: 110px;
  transition: transform 240ms var(--easing), border-color 240ms ease, box-shadow 240ms ease;
}
.clube-brand:hover {
  transform: translateY(-2px);
  border-color: rgba(0,161,152,0.35);
  box-shadow: 0 8px 24px rgba(1,38,89,0.08);
}
.clube-brand img {
  max-height: 44px;
  max-width: 90%;
  width: auto;
  height: auto;
  object-fit: contain;
  filter: saturate(0.95);
}
.clube-brand-cat {
  font-family: var(--font-ui);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(1,38,89,0.5);
  text-align: center;
  line-height: 1.2;
}

.clube-brands-note {
  text-align: center;
  font-size: 0.78rem;
  color: rgba(1,38,89,0.55);
  font-style: italic;
  margin: 0 0 var(--space-7);
}

/* Card de CPF */
.clube-cpf-card {
  background: #fff;
  border-radius: 18px;
  border: 1px solid rgba(0,161,152,0.18);
  box-shadow: 0 8px 32px rgba(1,38,89,0.08);
  padding: var(--space-8) var(--space-6) var(--space-6);
  text-align: center;
}
.clube-cpf-icon {
  width: 56px;
  height: 56px;
  margin: 0 auto var(--space-4);
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,161,152,0.08);
  border-radius: 50%;
  color: var(--rec-teal);
}
.clube-cpf-icon svg { width: 28px; height: 28px; }

.clube-cpf-title {
  font-family: var(--font-display);
  font-size: clamp(1.25rem, 2.4vw, 1.5rem);
  font-weight: 400;
  color: var(--rec-blue);
  margin-bottom: var(--space-3);
}
.clube-cpf-explain {
  font-size: var(--type-small);
  line-height: 1.55;
  color: rgba(1,38,89,0.7);
  margin-bottom: var(--space-5);
  max-width: 400px;
  margin-left: auto;
  margin-right: auto;
}

.clube-cpf-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  margin-bottom: var(--space-3);
}
.clube-cpf-form input {
  width: 100%;
  padding: 14px 18px;
  border-radius: 12px;
  border: 1.5px solid rgba(1,38,89,0.15);
  background: #fafcfe;
  font-family: var(--font-ui);
  font-size: 16px;
  font-weight: 600;
  color: var(--rec-blue);
  text-align: center;
  letter-spacing: 0.06em;
  transition: border-color 200ms ease, background 200ms ease;
}
.clube-cpf-form input:focus {
  outline: none;
  border-color: var(--rec-teal);
  background: #fff;
}
.clube-cpf-form input.has-error {
  border-color: #e07b7b;
  background: rgba(224,123,123,0.04);
}

.clube-cpf-submit {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 14px 24px;
  background: var(--rec-teal);
  color: #fff;
  border: none;
  border-radius: 999px;
  font-family: var(--font-ui);
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 200ms ease, transform 200ms var(--easing), box-shadow 200ms ease;
}
.clube-cpf-submit:hover {
  background: #008b83;
  transform: translateY(-1px);
  box-shadow: 0 8px 24px rgba(0,161,152,0.25);
}
.clube-cpf-submit svg { width: 16px; height: 16px; }

.clube-cpf-error {
  font-size: 0.78rem;
  color: #c0382b;
  font-weight: 600;
  min-height: 1.2em;
  margin-bottom: var(--space-3);
}
.clube-cpf-help {
  font-size: 0.78rem;
  color: rgba(1,38,89,0.55);
  line-height: 1.55;
}
.clube-cpf-help a {
  color: var(--rec-teal);
  font-weight: 700;
  text-decoration: underline;
