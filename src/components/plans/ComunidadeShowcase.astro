---
import { comunidadePlan } from '../../data/plans-comunidade'
import { whatsappLink, messages } from '../../utils/whatsapp'

function brl(n: number) {
  return n.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}

function icon(name: string): string {
  const i: Record<string, string> = {
    eye:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s4-8 10-8 10 8 10 8-4 8-10 8-10-8-10-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
    gift:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>`,
    mic:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>`,
    ticket:  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v3a2 2 0 0 0 0 4v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-3a2 2 0 0 0 0-4z"/><line x1="13" y1="5" x2="13" y2="19" stroke-dasharray="2 3"/></svg>`,
    compass: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>`,
    tag:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41 13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>`,
    spark:   `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/><circle cx="12" cy="12" r="3"/></svg>`,
    store:   `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l1-5h16l1 5"/><path d="M5 9v11a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V9"/><path d="M3 9a3 3 0 0 0 6 0 3 3 0 0 0 6 0 3 3 0 0 0 6 0"/></svg>`,
    card:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2.5"/><line x1="2" y1="10" x2="22" y2="10"/><line x1="6" y1="15" x2="10" y2="15"/></svg>`,
    pix:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12 L12 5 L19 12 L12 19 Z"/><line x1="7.5" y1="9.5" x2="9.5" y2="11.5"/><line x1="14.5" y1="9.5" x2="16.5" y2="11.5" transform="scale(-1,1) translate(-22,0)"/><line x1="9.5" y1="14.5" x2="7.5" y2="16.5" transform="scale(1,-1) translate(0,-22)"/><line x1="14.5" y1="14.5" x2="16.5" y2="16.5"/></svg>`,
  }
  return i[name] || ''
}

const links: Record<string, string> = {}
comunidadePlan.adesoes.forEach(a => { links[a.id] = whatsappLink(messages[a.ctaKey]) })

const initial = comunidadePlan.adesoes[0]
---

<section class="com-showcase" id="comunidade">
  <!-- ===== GRID: card sticky + benefits ===== -->
  <div class="showcase-grid">

    <!-- ===== LEFT: Plan card (sticky on desktop) ===== -->
    <aside class="showcase-card-col">
      <article class="plan-card" data-tilt>
        <span class="card-glow" aria-hidden="true"></span>
        <span class="card-ring" aria-hidden="true"></span>

        <header class="card-head">
          <span class="card-eyebrow">plano único</span>
          <h2 class="card-name">{comunidadePlan.name}</h2>
          <p class="card-tagline">{comunidadePlan.tagline}</p>
        </header>

        <!-- Adesão toggle -->
        <div class="adesao-toggle" role="tablist">
          {comunidadePlan.adesoes.map((a, i) => (
            <button
              class:list={['ad-tab', i === 0 && 'active']}
              data-ad={a.id}
              data-monthly={a.monthly}
              aria-selected={i === 0}
              role="tab"
            >
              <span class="ad-tab-label">{a.label}</span>
              <span class="ad-tab-sub">{a.durationLabel}</span>
              {a.badge && <span class="ad-tab-badge">{a.badge}</span>}
            </button>
          ))}
          <span class="ad-toggle-indicator" aria-hidden="true"></span>
        </div>

        <!-- Price + payment (single panel that morphs between adesões) -->
        <div class="card-price-block">
          <div class="price-row">
            <span class="price-currency">R$</span>
            <span class="price-amount" data-price-counter>{brl(initial.monthly)}</span>
            <span class="price-suffix">/mês</span>
          </div>
          <p class="price-total" data-price-total>{initial.totalLabel}</p>
        </div>

        <!-- Payment methods (very visual) -->
        <div class="payment-block has-pix" data-payment-block>
          <span class="payment-eyebrow">forma de pagamento</span>

          <div class="payment-options">
            <!-- Cartão (always visible) -->
            <div class="payment-option" data-pay="card">
              <span class="payment-icon" set:html={icon('card')}></span>
              <span class="payment-label">Cartão</span>
              <span class="payment-check" aria-hidden="true">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 8 7 12 13 4"/></svg>
              </span>
            </div>

            <!-- Pix -->
            <div class="payment-option payment-option-pix is-visible" data-pay="pix">
              <span class="payment-icon" set:html={icon('pix')}></span>
              <span class="payment-label">Pix</span>
              <span class="payment-check" aria-hidden="true">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 8 7 12 13 4"/></svg>
              </span>
            </div>
          </div>

          <p class="payment-detail" data-payment-detail>{initial.paymentDetail}</p>
        </div>

        <a class="card-cta" data-magnetic data-cta-link href={links[initial.id]} target="_blank" rel="noopener">
          <span class="cta-label" data-cta-label>{initial.ctaLabel}</span>
          <span class="cta-arrow" aria-hidden="true">→</span>
        </a>

        <p class="card-foot">Curadoria parte do diferencial. <br/>A gente conversa antes.</p>
      </article>

      <!-- Rede interativa — sua empresa no centro do ecossistema REC -->
      <div class="net-graphic">
        <canvas class="net-canvas" aria-hidden="true"></canvas>

        <!-- Núcleo central: SUA EMPRESA -->
        <div class="net-core" aria-hidden="true">
          <span class="net-core-ring net-core-ring-1"></span>
          <span class="net-core-ring net-core-ring-2"></span>
          <span class="net-core-ring net-core-ring-3"></span>
          <div class="net-core-card">
            <span class="net-core-label">sua empresa</span>
            <span class="net-core-dot"></span>
          </div>
        </div>

        <!-- Labels de segmentos da rede (posicionamento via JS) -->
        <ul class="net-tags" aria-hidden="true">
          <li class="net-tag" data-seg="0">saúde</li>
          <li class="net-tag" data-seg="1">imóveis</li>
          <li class="net-tag" data-seg="2">moda</li>
          <li class="net-tag" data-seg="3">fitness</li>
          <li class="net-tag" data-seg="4">alimentação</li>
          <li class="net-tag" data-seg="5">educação</li>
        </ul>

        <p class="net-hint">
          <span class="net-hint-pulse"></span>
          aproxime o cursor pra conectar
        </p>
      </div>
    </aside>

    <!-- ===== RIGHT: Bento de benefícios ===== -->
    <div class="showcase-benefits-col">
      <header class="benefits-head">
        <span class="benefits-eyebrow">está incluso no plano</span>
        <h3>A rede <em>trabalhando</em> por você.</h3>
        <p class="benefits-lead">Oito benefícios pensados pra empresas que querem crescer pela rede. Vale tanto pra semestral quanto pra anual.</p>
      </header>

      <div class="benefits-bento">
        {comunidadePlan.benefits.map((b, idx) => (
          <article class:list={['benefit-cell', `benefit-cell-${idx + 1}`]} style={`--i: ${idx}`}>
            <span class="benefit-num">0{idx + 1}</span>
            <span class="benefit-icon" set:html={icon(b.icon)}></span>
            <h4>{b.title}</h4>
            <p>{b.description}</p>
            <span class="benefit-sweep" aria-hidden="true"></span>
          </article>
        ))}
      </div>
    </div>
  </div>

  <!-- ===== CLUBE CERTO — benefício exclusivo das associadas ===== -->
  <section class="clube-certo" id="clube-certo">
    <div class="clube-certo-inner">
      <header class="clube-certo-header">
        <span class="benefits-eyebrow">BENEFÍCIO EXCLUSIVO</span>
        <h3>Clube <em>Certo</em></h3>
        <p>Associadas REC têm acesso a uma rede de descontos em parceiros como esses abaixo. Mais de centenas de marcas em diferentes segmentos.</p>
      </header>

      <!-- Grid de marcas principais (preview visual) -->
      <ul class="clube-brands" aria-label="Algumas marcas parceiras do Clube Certo">
        <li class="clube-brand">
          <img src="https://clubecerto.com.br/images/parceiros/clubeDrogasil.jpg" alt="Drogasil" loading="lazy" />
          <span class="clube-brand-cat">farmácia</span>
        </li>
        <li class="clube-brand">
          <img src="https://clubecerto.com.br/images/parceiros/Dominos.jpg" alt="Domino's" loading="lazy" />
          <span class="clube-brand-cat">restaurante</span>
        </li>
        <li class="clube-brand">
          <img src="https://clubecerto.com.br/images/parceiros/LogoPetzCBC250x250.png" alt="Petz" loading="lazy" />
          <span class="clube-brand-cat">pet shop</span>
        </li>
        <li class="clube-brand">
          <img src="https://clubecerto.s3.amazonaws.com/Upload/establishments/162862505032/1740080441439_NETSHOES_600X600.png" alt="Netshoes" loading="lazy" />
          <span class="clube-brand-cat">esportes</span>
        </li>
        <li class="clube-brand">
          <img src="https://clubecerto.s3.amazonaws.com/Upload/establishments/687758087478/1777036427317_Hotels.com%20Chiclet.png" alt="Hotels.com" loading="lazy" />
          <span class="clube-brand-cat">turismo</span>
        </li>
        <li class="clube-brand">
          <img src="https://clubecerto.com.br/images/parceiros/clubeunidas.jpg" alt="Unidas" loading="lazy" />
          <span class="clube-brand-cat">aluguel de carros</span>
        </li>
      </ul>

      <p class="clube-brands-note">e centenas de outras marcas — entre na sua conta para ver tudo</p>

      <!-- Card de CPF (input + abre nova aba) -->
      <div class="clube-cpf-card">
        <div class="clube-cpf-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="5" width="18" height="14" rx="2"/>
            <circle cx="9" cy="12" r="2.2"/>
            <path d="M13.5 10.5h4M13.5 13.5h4M6 17h12"/>
          </svg>
        </div>

        <h4 class="clube-cpf-title">Ver todos os descontos</h4>
        <p class="clube-cpf-explain">
          Digite seu CPF. Abrimos o Clube Certo em uma nova aba com seus benefícios já carregados.
        </p>

        <form class="clube-cpf-form" id="clube-cpf-form" novalidate>
          <label class="sr-only" for="clube-cpf-input">CPF</label>
          <input
            id="clube-cpf-input"
            type="text"
            inputmode="numeric"
            autocomplete="off"
            placeholder="000.000.000-00"
            maxlength="14"
            aria-describedby="clube-cpf-error"
            required
          />
          <button type="submit" class="clube-cpf-submit">
            ver meus descontos
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14 3h7v7M21 3l-9 9M21 14v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5"/>
            </svg>
          </button>
        </form>
        <p class="clube-cpf-error" id="clube-cpf-error" role="alert"></p>

        <p class="clube-cpf-help">
          O acesso só funciona com CPF previamente cadastrado pela equipe REC. Se for associada e não conseguir entrar,
          <a href="https://wa.me/5551984632545?text=Olá! Quero ativar meu acesso ao Clube Certo." target="_blank" rel="noopener">fale com a gente</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== Como funciona — timeline ===== -->
  <section class="com-steps">
    <header class="section-head">
      <span class="benefits-eyebrow">como funciona</span>
      <h3>Três passos pra <em>entrar no movimento.</em></h3>
    </header>
    <div class="steps-track">
      <span class="steps-line" aria-hidden="true"></span>
      {comunidadePlan.steps.map(s => (
        <article class="step">
          <span class="step-dot" aria-hidden="true"></span>
          <span class="step-num">{s.num}</span>
          <h4>{s.title}</h4>
          <p>{s.description}</p>
        </article>
      ))}
    </div>
  </section>
</section>

<!-- ===== Sticky CTA bar (mobile) ===== -->
<div class="mobile-cta-bar" data-mobile-cta>
  <div class="mobile-cta-inner">
    <div class="mobile-cta-price">
      <span class="mobile-cta-currency">R$</span>
      <span class="mobile-cta-value" data-mobile-price>{brl(initial.monthly)}</span>
      <span class="mobile-cta-suffix">/mês</span>
    </div>
    <a class="mobile-cta-btn" data-mobile-link href={links[initial.id]} target="_blank" rel="noopener">
      <span data-mobile-label>quero entrar →</span>
    </a>
  </div>
</div>

<script>
  const root = document.querySelector<HTMLElement>('.com-showcase')
  if (root) {
    type AdesaoKey = 'semestral' | 'anual'
    type AdesaoData = { monthly: number; totalLabel: string; paymentDetail: string; ctaLabel: string; pix: boolean }
    const data: Record<AdesaoKey, AdesaoData> = {
      semestral: {
        monthly: 149.90,
        totalLabel: 'R$ 899,40 em 6 meses',
        paymentDetail: 'Cartão de crédito em até 6x (taxas do cartão por conta do cliente) ou Pix à vista',
        ctaLabel: 'quero o plano semestral',
        pix: true,
      },
      anual: {
        monthly: 109.90,
        totalLabel: 'R$ 1.318,80 em 12 meses',
        paymentDetail: 'Pix mensal recorrente ou cartão em até 12x (taxas do cartão por conta do cliente)',
        ctaLabel: 'quero o plano anual',
        pix: true,
      },
    }

    const links: Record<string, string> = {}
    document.querySelectorAll<HTMLButtonElement>('.ad-tab').forEach(b => {
      const id = b.dataset.ad!
      const href = (b.closest('.adesao-toggle')?.parentElement?.querySelector('[data-cta-link]') as HTMLAnchorElement)?.href
      if (href && !links[id]) links[id] = href
    })

    const adTabs = Array.from(root.querySelectorAll<HTMLButtonElement>('.ad-tab'))
    const indicator = root.querySelector<HTMLElement>('.ad-toggle-indicator')
    const priceCounter = root.querySelector<HTMLElement>('[data-price-counter]')
    const priceTotal = root.querySelector<HTMLElement>('[data-price-total]')
    const paymentBlock = root.querySelector<HTMLElement>('[data-payment-block]')
    const paymentDetail = root.querySelector<HTMLElement>('[data-payment-detail]')
    const pixOption = root.querySelector<HTMLElement>('.payment-option-pix')
    const ctaLink = root.querySelector<HTMLAnchorElement>('[data-cta-link]')
    const ctaLabel = root.querySelector<HTMLElement>('[data-cta-label]')
    const mobileLink = document.querySelector<HTMLAnchorElement>('[data-mobile-link]')
    const mobileLabel = document.querySelector<HTMLElement>('[data-mobile-label]')
    const mobilePrice = document.querySelector<HTMLElement>('[data-mobile-price]')

    function brl(n: number) {
      return n.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
    }

    function placeIndicator(target: string) {
      if (!indicator) return
      const idx = adTabs.findIndex(t => t.dataset.ad === target)
      indicator.style.transform = `translateX(${idx * 100}%)`
    }
    placeIndicator('semestral')

    // ===== Price counter animation =====
    let priceAnimRaf = 0
    function animatePrice(from: number, to: number, ms = 600) {
      if (!priceCounter) return
      const start = performance.now()
      cancelAnimationFrame(priceAnimRaf)
      const step = (now: number) => {
        const p = Math.min(1, (now - start) / ms)
        const ease = 1 - Math.pow(1 - p, 3)
        const v = from + (to - from) * ease
        priceCounter.textContent = brl(v)
        if (mobilePrice) mobilePrice.textContent = brl(v)
        if (p < 1) priceAnimRaf = requestAnimationFrame(step)
      }
      priceAnimRaf = requestAnimationFrame(step)
    }

    let currentAdesao: AdesaoKey = 'semestral'

    function switchAdesao(target: AdesaoKey) {
      if (target === currentAdesao) return

      // Update tabs
      adTabs.forEach(t => {
        const active = t.dataset.ad === target
        t.classList.toggle('active', active)
        t.setAttribute('aria-selected', String(active))
      })
      placeIndicator(target)

      // Animate price
      animatePrice(data[currentAdesao].monthly, data[target].monthly)

      // Update labels with stagger fade
      if (priceTotal) {
        priceTotal.classList.add('is-changing')
        setTimeout(() => {
          priceTotal.textContent = data[target].totalLabel
          priceTotal.classList.remove('is-changing')
        }, 180)
      }
      if (paymentDetail) {
        paymentDetail.classList.add('is-changing')
        setTimeout(() => {
          paymentDetail.textContent = data[target].paymentDetail
          paymentDetail.classList.remove('is-changing')
        }, 180)
      }
      if (ctaLabel) {
        ctaLabel.classList.add('is-changing')
        setTimeout(() => {
          ctaLabel.textContent = data[target].ctaLabel
          ctaLabel.classList.remove('is-changing')
        }, 180)
      }
      if (mobileLabel) {
        mobileLabel.textContent = target === 'anual' ? 'quero o plano anual →' : 'quero o plano semestral →'
      }

      // Pix appearance
      if (pixOption) pixOption.classList.toggle('is-visible', data[target].pix)
      if (paymentBlock) paymentBlock.classList.toggle('has-pix', data[target].pix)

      // Update CTA hrefs
      const href = links[target]
      if (ctaLink && href) ctaLink.href = href
      if (mobileLink && href) mobileLink.href = href

      currentAdesao = target
    }

    adTabs.forEach(t => t.addEventListener('click', () => switchAdesao(t.dataset.ad as AdesaoKey)))

    // ===== Intersection reveal for benefits + steps =====
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('in-view')
            io.unobserve(e.target)
          }
        })
      }, { threshold: 0.12 })
      root.querySelectorAll('.benefit-cell, .step').forEach(el => io.observe(el))

      // Trigger price counter when card enters view (from 0)
      const cardEl = root.querySelector('.plan-card')
      if (cardEl) {
        const cardIo = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              animatePrice(0, data[currentAdesao].monthly, 900)
              cardIo.unobserve(e.target)
            }
          })
        }, { threshold: 0.3 })
        cardIo.observe(cardEl)
      }
    }

    // ===== 3D tilt on plan card =====
    const tiltEl = root.querySelector<HTMLElement>('[data-tilt]')
    if (tiltEl && window.matchMedia('(hover: hover)').matches) {
      tiltEl.addEventListener('mousemove', (e) => {
        const r = tiltEl.getBoundingClientRect()
        const x = ((e.clientX - r.left) / r.width - 0.5) * 2
        const y = ((e.clientY - r.top) / r.height - 0.5) * 2
        tiltEl.style.transform = `perspective(1000px) rotateY(${x * 3}deg) rotateX(${-y * 2.5}deg) translateZ(0)`
      })
      tiltEl.addEventListener('mouseleave', () => {
        tiltEl.style.transform = ''
      })
    }

    // ===== Magnetic CTA =====
    document.querySelectorAll<HTMLElement>('[data-magnetic]').forEach(m => {
      m.addEventListener('mousemove', (e) => {
        const r = m.getBoundingClientRect()
        const x = e.clientX - r.left - r.width / 2
        const y = e.clientY - r.top - r.height / 2
        m.style.transform = `translate(${x * 0.18}px, ${y * 0.28}px)`
      })
      m.addEventListener('mouseleave', () => { m.style.transform = '' })
    })

    // ===== Ecossistema interativo — SUA EMPRESA no centro =====
    const netGraphic = root.querySelector<HTMLElement>('.net-graphic')
    const netCanvas  = root.querySelector<HTMLCanvasElement>('.net-canvas')
    const netTagsEl  = root.querySelector<HTMLElement>('.net-tags')
    if (netGraphic && netCanvas && window.matchMedia('(min-width: 1025px)').matches && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const ctx = netCanvas.getContext('2d')!
      const DPR = Math.min(window.devicePixelRatio || 1, 2)
      let CW = 0, CH = 0, CX = 0, CY = 0

      function resizeNet() {
        CW = netGraphic.offsetWidth
        CH = netGraphic.offsetHeight
        CX = CW / 2
        CY = CH / 2
        netCanvas.width  = CW * DPR
        netCanvas.height = CH * DPR
        netCanvas.style.width  = CW + 'px'
        netCanvas.style.height = CH + 'px'
      }
      resizeNet()
      window.addEventListener('resize', resizeNet)

      // Configuração: 3 órbitas concêntricas — empresas REC ao redor da sua
      interface OrbitNode {
        ring: number          // 0 = mais perto, 2 = mais longe
        angle: number         // posição angular (rad)
        speed: number         // velocidade orbital (rad/s)
        baseR: number         // raio do nó
        teal: boolean         // cor dominante
        phase: number         // fase para pulsação
        // posição calculada
        x: number; y: number
        // segmento (label) se for nó "tag"
        seg?: number
      }

      const ORBITS = [
        { radius: 0.30, count: 5, speed:  0.10 },
        { radius: 0.52, count: 8, speed: -0.06 },
        { radius: 0.78, count: 11, speed: 0.04 },
      ]

      const nodes: OrbitNode[] = []

      // Nós ambient (rede de fundo) — preenchem cada órbita
      ORBITS.forEach((o, ringIdx) => {
        for (let i = 0; i < o.count; i++) {
          const baseAngle = (i / o.count) * Math.PI * 2 + ringIdx * 0.3
          nodes.push({
            ring: ringIdx,
            angle: baseAngle,
            speed: o.speed * (0.85 + Math.random() * 0.3),
            baseR: ringIdx === 0 ? 4 + Math.random() * 1.5 : (ringIdx === 1 ? 3 + Math.random() * 1.4 : 2 + Math.random() * 1.2),
            teal: Math.random() > 0.35,
            phase: Math.random() * Math.PI * 2,
            x: 0, y: 0,
          })
        }
      })

      // Nós DE SEGMENTO (com tag) — distribuídos em 6 ângulos uniformes (60° entre cada)
      // e alternando raios pra não ficar todos na mesma órbita.
      // Offset pra evitar sobreposição perfeita com nós ambient.
      const TAG_PLACEMENTS: Array<{ ring: number; angle: number }> = [
        { ring: 1, angle: Math.PI * (1/6) },   //  30°  — saúde
        { ring: 2, angle: Math.PI * (3/6) },   //  90°  — imóveis
        { ring: 0, angle: Math.PI * (5/6) },   // 150°  — moda
        { ring: 2, angle: Math.PI * (7/6) },   // 210°  — fitness
        { ring: 1, angle: Math.PI * (9/6) },   // 270°  — alimentação
        { ring: 0, angle: Math.PI * (11/6) },  // 330°  — educação
      ]
      TAG_PLACEMENTS.forEach((placement, segIdx) => {
        nodes.push({
          ring: placement.ring,
          angle: placement.angle,
          speed: ORBITS[placement.ring].speed * 0.7,
          baseR: 4.5,
          teal: true,
          phase: Math.random() * Math.PI * 2,
          x: 0, y: 0,
          seg: segIdx,
        })
      })

      // Mouse tracking
      let mx = -9999, my = -9999, hovering = false
      netGraphic.addEventListener('mousemove', (e: MouseEvent) => {
        const rr = netGraphic.getBoundingClientRect()
        mx = e.clientX - rr.left
        my = e.clientY - rr.top
        hovering = true
        netGraphic.classList.add('is-active')
      })
      netGraphic.addEventListener('mouseleave', () => {
        mx = -9999; my = -9999; hovering = false
        netGraphic.classList.remove('is-active')
      })

      // Hover intensity (suavizado)
      let hoverInt = 0
      let netRaf = 0
      const tagEls = netTagsEl ? Array.from(netTagsEl.querySelectorAll<HTMLElement>('.net-tag')) : []

      function drawNet(ts: number) {
        const t = ts * 0.001
        ctx.setTransform(DPR, 0, 0, DPR, 0, 0)
        ctx.clearRect(0, 0, CW, CH)

        // Suavização da intensidade do hover
        const targetInt = hovering ? 1 : 0
        hoverInt += (targetInt - hoverInt) * 0.08

        const maxRadius = Math.min(CW, CH) * 0.45
        const coreR = 38 // raio "intocável" ao redor do core (px)

        // ── calcula posições orbitais ─────────────
        nodes.forEach(n => {
          const orbitR = ORBITS[n.ring].radius * maxRadius
          const a = n.angle + n.speed * t
          n.x = CX + Math.cos(a) * orbitR
          n.y = CY + Math.sin(a) * orbitR
        })

        // ── linhas entre nós (rede ambiente) ─────
        ctx.lineCap = 'round'
        const LINK_DIST = 95
        for (let i = 0; i < nodes.length; i++) {
          for (let j = i + 1; j < nodes.length; j++) {
            const d = Math.hypot(nodes[i].x - nodes[j].x, nodes[i].y - nodes[j].y)
            if (d >= LINK_DIST) continue
            const a = (1 - d / LINK_DIST) * 0.18
            ctx.beginPath()
            ctx.moveTo(nodes[i].x, nodes[i].y)
            ctx.lineTo(nodes[j].x, nodes[j].y)
            ctx.strokeStyle = `rgba(0,161,152,${a})`
            ctx.lineWidth = 0.8
            ctx.stroke()
          }
        }

        // ── conexões do CORE para nós (no hover) ──
        if (hoverInt > 0.02) {
          nodes.forEach((n, idx) => {
            const dxc = n.x - CX, dyc = n.y - CY
            const dc = Math.hypot(dxc, dyc)
            if (dc < coreR) return

            // Proximidade do cursor ao nó dita a força da conexão
            const dxm = mx - n.x, dym = my - n.y
            const dm = Math.hypot(dxm, dym)
            const prox = Math.max(0, 1 - dm / 170)
            const strength = prox * hoverInt
            if (strength < 0.03) return

            // Ponto de início do "raio" (sai da borda do core, não do centro)
            const ux = dxc / dc, uy = dyc / dc
            const sx = CX + ux * coreR
            const sy = CY + uy * coreR

            // Glow externo
            ctx.beginPath()
            ctx.moveTo(sx, sy); ctx.lineTo(n.x, n.y)
            ctx.strokeStyle = `rgba(0,161,152,${strength * 0.18})`
            ctx.lineWidth = 6
            ctx.stroke()

            // Linha principal
            ctx.beginPath()
            ctx.moveTo(sx, sy); ctx.lineTo(n.x, n.y)
            ctx.strokeStyle = `rgba(0,161,152,${0.35 + strength * 0.55})`
            ctx.lineWidth = 1.2 + strength * 0.6
            ctx.stroke()

            // Pulso correndo pela linha (sinapse)
            const pulseT = ((t * 1.4 + idx * 0.12) % 1)
            const px = sx + (n.x - sx) * pulseT
            const py = sy + (n.y - sy) * pulseT
            ctx.beginPath()
            ctx.arc(px, py, 2 + strength * 1.2, 0, Math.PI * 2)
            ctx.fillStyle = `rgba(255,255,255,${0.7 + strength * 0.3})`
            ctx.shadowColor = 'rgba(0,161,152,0.9)'
            ctx.shadowBlur = 10
            ctx.fill()
            ctx.shadowBlur = 0
          })
        }

        // ── nós orbitais ──────────────────────────
        nodes.forEach(n => {
          const pulse = Math.sin(t * 1.2 + n.phase) * 0.5 + 0.5
          const r = n.baseR + pulse * 0.6
          const c = n.teal ? '0,161,152' : '1,38,89'

          // Halo no hover quando perto do cursor
          const dm = Math.hypot(mx - n.x, my - n.y)
          const near = Math.max(0, 1 - dm / 130) * hoverInt

          if (near > 0.05) {
            ctx.beginPath()
            ctx.arc(n.x, n.y, r + 6 + near * 4, 0, Math.PI * 2)
            ctx.fillStyle = `rgba(0,161,152,${near * 0.18})`
            ctx.fill()
          }

          ctx.shadowColor = `rgba(${c},0.4)`
          ctx.shadowBlur = 6 + near * 6
          ctx.beginPath()
          ctx.arc(n.x, n.y, r + near * 0.8, 0, Math.PI * 2)
          ctx.fillStyle = `rgba(${c},${0.55 + near * 0.35})`
          ctx.fill()
          ctx.shadowBlur = 0

          // Brilho interno
          const g = ctx.createRadialGradient(n.x - r * 0.3, n.y - r * 0.3, 0, n.x, n.y, r)
          g.addColorStop(0, `rgba(255,255,255,${0.35 + near * 0.3})`)
          g.addColorStop(1, 'rgba(255,255,255,0)')
          ctx.beginPath(); ctx.arc(n.x, n.y, r, 0, Math.PI * 2)
          ctx.fillStyle = g; ctx.fill()
        })

        // ── posiciona labels dos segmentos ────────
        tagEls.forEach((el, i) => {
          const node = nodes.find(n => n.seg === i)
          if (!node) return
          // offset radial pra fora
          const dxc = node.x - CX, dyc = node.y - CY
          const dc = Math.hypot(dxc, dyc) || 1
          const ox = dxc / dc * 22
          const oy = dyc / dc * 22
          el.style.transform = `translate3d(${node.x + ox - el.offsetWidth / 2}px, ${node.y + oy - el.offsetHeight / 2}px, 0)`
          el.style.opacity = String(0.4 + hoverInt * 0.55)
        })

        netRaf = requestAnimationFrame(drawNet)
      }
      requestAnimationFrame(drawNet)
      window.addEventListener('beforeunload', () => cancelAnimationFrame(netRaf))
    }

    // ===== Mobile sticky CTA bar — show when plan card scrolls out =====
    const mobileBar = document.querySelector<HTMLElement>('[data-mobile-cta]')
    const cardEl = root.querySelector<HTMLElement>('.plan-card')
    if (mobileBar && cardEl && 'IntersectionObserver' in window) {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          mobileBar.classList.toggle('is-visible', !e.isIntersecting && e.boundingClientRect.top < 0)
        })
      }, { threshold: 0 })
      obs.observe(cardEl)
    }
  }

  // CLUBE CERTO — máscara CPF + abrir Clube Certo em nova aba com CPF pré-preenchido
  const clubeForm  = document.getElementById('clube-cpf-form') as HTMLFormElement | null
  const clubeInput = document.getElementById('clube-cpf-input') as HTMLInputElement | null
  const clubeError = document.getElementById('clube-cpf-error')

  function maskCpf(value: string): string {
    const d = value.replace(/\D/g, '').slice(0, 11)
    if (d.length > 9)      return `${d.slice(0,3)}.${d.slice(3,6)}.${d.slice(6,9)}-${d.slice(9)}`
    if (d.length > 6)      return `${d.slice(0,3)}.${d.slice(3,6)}.${d.slice(6)}`
    if (d.length > 3)      return `${d.slice(0,3)}.${d.slice(3)}`
    return d
  }

  function isValidCpf(cpf: string): boolean {
    const d = cpf.replace(/\D/g, '')
    if (d.length !== 11) return false
    if (/^(\d)\1+$/.test(d)) return false
    let sum = 0
    for (let i = 0; i < 9; i++) sum += parseInt(d[i]) * (10 - i)
    let r = (sum * 10) % 11
    if (r === 10) r = 0
    if (r !== parseInt(d[9])) return false
    sum = 0
    for (let i = 0; i < 10; i++) sum += parseInt(d[i]) * (11 - i)
    r = (sum * 10) % 11
    if (r === 10) r = 0
    return r === parseInt(d[10])
  }

  if (clubeInput) {
    clubeInput.addEventListener('input', () => {
      clubeInput.value = maskCpf(clubeInput.value)
      clubeInput.classList.remove('has-error')
      if (clubeError) clubeError.textContent = ''
    })
  }

  if (clubeForm && clubeInput && clubeError) {
    clubeForm.addEventListener('submit', (e) => {
      e.preventDefault()
      const raw = clubeInput.value.replace(/\D/g, '')
      if (!isValidCpf(clubeInput.value)) {
        clubeInput.classList.add('has-error')
        clubeError.textContent = raw.length < 11
          ? 'Digite os 11 números do seu CPF.'
          : 'CPF inválido. Confira os números e tente novamente.'
        return
      }
      // Abre o Clube Certo em nova aba já com o CPF preenchido
      const url = `https://app.clubecerto.com.br/?cpf=${encodeURIComponent(raw)}&ent=rec445`
      window.open(url, '_blank', 'noopener,noreferrer')
    })
  }
</script>

