---
import PlanCard from './PlanCard.astro'
import OrcamentoCTA from './OrcamentoCTA.astro'
import { comunidadePlan } from '../../data/plans-comunidade'
import { hubPlans } from '../../data/plans-hub'
import { whatsappLink, messages } from '../../utils/whatsapp'

function brl(n: number) {
  return n.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}

const semestralLink = whatsappLink(messages.comunidadeProSemestral)
const anualLink = whatsappLink(messages.comunidadeProAnual)
---
<div class="plan-tabs" data-plan-tabs id="hub-digital">
  <div class="tab-bar-wrap">
    <div class="tab-bar" role="tablist">
      <button class="tab active" data-tab="comunidade" role="tab" aria-selected="true">Comunidade</button>
      <button class="tab" data-tab="hub" role="tab" aria-selected="false">HUB Digital</button>
    </div>
  </div>

  <div class="tab-panel active" data-panel="comunidade" role="tabpanel">
    <p class="panel-intro">Adesão à Comunidade REC: networking, parcerias, visibilidade e benefícios exclusivos da rede. Plano único, com adesão semestral ou anual.</p>

    <div class="single-plan-wrap">
      <article class="single-plan-card">
        <div class="plan-ribbon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5L18.2 22 12 17.5 5.8 22l2.4-8.1L2 9.4h7.6z"/></svg>
          <span>mais escolhido</span>
        </div>

        <header class="plan-card-header">
          <span class="plan-eyebrow">plano único</span>
          <h2 class="plan-name">{comunidadePlan.name}</h2>
          <p class="plan-tagline">Pra empresas que querem fazer parte do ecossistema completo.</p>
        </header>

        <div class="adesao-toggle" role="tablist" aria-label="Tipo de adesão">
          <button class="ad-tab active" data-ad="semestral" role="tab" aria-selected="true">
            <span class="ad-tab-label">semestral</span>
            <span class="ad-tab-sub">6 meses</span>
          </button>
          <button class="ad-tab" data-ad="anual" role="tab" aria-selected="false">
            <span class="ad-tab-label">anual</span>
            <span class="ad-tab-sub">12 meses</span>
          </button>
        </div>

        <div class="ad-panel active" data-ad-panel="semestral">
          <div class="price-row">
            <span class="price-currency">R$</span>
            <span class="price-amount">{brl(comunidadePlan.monthly)}</span>
            <span class="price-suffix">/mês</span>
          </div>
          <p class="price-note">Equivalente <strong>R$ {brl(comunidadePlan.semestralEquivalent)}</strong> em 6 meses</p>
          <a class="plan-cta" href={semestralLink} target="_blank" rel="noopener">
            <span>quero o plano semestral</span>
            <span class="cta-arrow" aria-hidden="true">→</span>
          </a>
        </div>

        <div class="ad-panel" data-ad-panel="anual">
          <div class="price-row">
            <span class="price-currency">R$</span>
            <span class="price-amount">{brl(comunidadePlan.monthly)}</span>
            <span class="price-suffix">/mês</span>
          </div>
          <p class="price-note">Acerto mensal via Pix em 12 meses</p>
          <a class="plan-cta" href={anualLink} target="_blank" rel="noopener">
            <span>quero o plano anual</span>
            <span class="cta-arrow" aria-hidden="true">→</span>
          </a>
        </div>

        <div class="plan-section">
          <h4 class="plan-section-title">o que está incluso</h4>
          <ul class="plan-bullets">
            {comunidadePlan.bullets.map(b => (
              <li>{b}</li>
            ))}
          </ul>
        </div>

        <div class="plan-section">
          <h4 class="plan-section-title">formas de pagamento</h4>
          <ul class="payment-methods-list">
            {comunidadePlan.paymentMethods.map(m => (
              <li>{m}</li>
            ))}
          </ul>
        </div>

        <div class="plan-after-info">
          <span class="info-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
          <p>Após a adesão você vai receber no email um formulário pra concluir sua inscrição na rede.</p>
        </div>
      </article>
    </div>
  </div>

  <div class="tab-panel" data-panel="hub" role="tabpanel">
    <p class="panel-intro">A ideia do HUB é estruturar e aumentar seu faturamento. Cada negócio tem um momento, e o orçamento sai sob medida.</p>
    <div class="plan-grid plan-grid-4">
      {hubPlans.map(p => (
        <PlanCard
          name={p.name}
          summary={p.summary}
          bullets={p.bullets}
          addOns={p.addOns}
          featured={p.featured}
          ctaKey={p.ctaKey}
          ctaText="quero esse plano"
          hidePrice
        />
      ))}
    </div>
    <OrcamentoCTA />
  </div>
</div>

<script>
  // Top-level tabs (Comunidade / HUB)
  const tabs = document.querySelectorAll<HTMLButtonElement>('[data-plan-tabs] .tab')
  const panels = document.querySelectorAll<HTMLElement>('[data-plan-tabs] .tab-panel')

  function switchTab(targetTab: string) {
    tabs.forEach(x => {
      const active = x.dataset.tab === targetTab
      x.classList.toggle('active', active)
      x.setAttribute('aria-selected', String(active))
    })
    panels.forEach(p => p.classList.toggle('active', p.dataset.panel === targetTab))
  }

  tabs.forEach(t => t.addEventListener('click', () => switchTab(t.dataset.tab!)))

  // Ativa aba HUB automaticamente se vier pelo hash #hub-digital
  if (window.location.hash === '#hub-digital') {
    switchTab('hub')
    setTimeout(() => {
      document.getElementById('hub-digital')?.scrollIntoView({ behavior: 'smooth', block: 'start' })
    }, 100)
  }

  // Adesão sub-tabs (semestral / anual) inside Comunidade
  const adTabs = document.querySelectorAll<HTMLButtonElement>('[data-plan-tabs] .ad-tab')
  const adPanels = document.querySelectorAll<HTMLElement>('[data-plan-tabs] [data-ad-panel]')
  adTabs.forEach(t => t.addEventListener('click', () => {
    adTabs.forEach(x => {
      const active = x === t
      x.classList.toggle('active', active)
      x.setAttribute('aria-selected', String(active))
    })
    adPanels.forEach(p => p.classList.toggle('active', p.dataset.adPanel === t.dataset.ad))
  }))
</script>

<style>
.plan-tabs { max-width: var(--container-max); margin: 0 auto; padding: var(--space-6); }
.tab-bar-wrap { display: flex; justify-content: center; margin-bottom: var(--space-12); }
.tab-bar { display: inline-flex; gap: var(--space-2); padding: 4px; background: rgba(37,52,57,0.05); border-radius: 12px; }
.tab { padding: 10px 20px; border-radius: 8px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; font-size: var(--type-micro); color: #667; transition: all var(--motion-fast) var(--easing); }
.tab.active { background: var(--rec-purple); color: #fff; }
.tab-panel { display: none; }
.tab-panel.active { display: block; }
.panel-intro { color: #667; margin: 0 auto var(--space-8); max-width: 640px; line-height: 1.6; text-align: center; }

/* Single plan card (Comunidade) */
.single-plan-wrap { display: flex; justify-content: center; }
.single-plan-card {
  width: 100%;
  max-width: 520px;
  background: linear-gradient(180deg, #fff 0%, rgba(0,161,152,0.04) 100%);
  border: 1px solid rgba(0,161,152,0.18);
  border-radius: 18px;
  padding: var(--space-8) var(--space-7);
  box-shadow: 0 12px 40px rgba(0,109,104,0.08);
  position: relative;
}
.plan-card-header { text-align: center; margin-bottom: var(--space-6); }
.plan-eyebrow {
  display: inline-block;
  font-size: var(--type-micro);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--rec-teal);
  font-weight: 700;
  margin-bottom: var(--space-2);
}
.plan-card-header h2 { font-size: 2.25rem; line-height: 1; color: var(--rec-dark); font-weight: 800; margin-bottom: var(--space-2); }
.plan-tagline { font-size: var(--type-small); color: #556; line-height: 1.5; max-width: 380px; margin: 0 auto; }

.adesao-toggle {
  display: inline-flex;
  gap: 4px;
  padding: 4px;
  margin: 0 auto var(--space-6);
  background: rgba(37,52,57,0.06);
  border-radius: 10px;
  width: 100%;
  justify-content: center;
}
.ad-tab {
  flex: 1;
  max-width: 180px;
  padding: 8px 16px;
  border-radius: 7px;
  font-size: var(--type-micro);
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #556;
  background: transparent;
  transition: all var(--motion-fast) var(--easing);
}
.ad-tab.active { background: var(--rec-teal); color: #fff; }

.ad-panel { display: none; text-align: center; }
.ad-panel.active { display: block; animation: fadeIn 240ms var(--easing); }
@keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }

.price-row { display: flex; align-items: flex-end; justify-content: center; gap: 4px; margin-bottom: var(--space-2); }
.price-currency { font-size: 1.25rem; color: var(--rec-dark); font-weight: 600; padding-bottom: 8px; }
.price-amount { font-size: 3.5rem; line-height: 1; color: var(--rec-dark); font-weight: 800; letter-spacing: -0.02em; }
.price-suffix { font-size: var(--type-small); color: #556; padding-bottom: 12px; }
.price-note { font-size: var(--type-small); color: #667; margin-bottom: var(--space-5); }
.price-note strong { color: var(--rec-dark); font-weight: 700; }

.plan-cta {
  display: inline-block;
  padding: 14px 32px;
  background: var(--rec-purple);
  color: #fff;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  font-size: var(--type-small);
  border-radius: 10px;
  transition: all var(--motion-fast) var(--easing);
  margin-bottom: var(--space-6);
}
.plan-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(108,90,178,0.32); }

.plan-bullets {
  list-style: none;
  padding: var(--space-6) 0;
  margin: 0 0 var(--space-5);
  border-top: 1px solid rgba(37,52,57,0.1);
  border-bottom: 1px solid rgba(37,52,57,0.1);
  display: grid;
  gap: var(--space-3);
}
.plan-bullets li {
  font-size: var(--type-small);
  color: var(--rec-dark);
  line-height: 1.5;
  padding-left: 26px;
  position: relative;
}
.plan-bullets li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 7px;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: var(--rec-teal);
  background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><path d="M4 8.5l2.5 2.5L12 5.5" fill="none" stroke="white" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>');
  background-repeat: no-repeat;
  background-position: center;
  background-size: 14px;
}

.payment-methods { margin-top: 0; }
.payment-methods h4 {
  font-size: var(--type-micro);
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: #667;
  font-weight: 700;
  margin-bottom: var(--space-3);
}
.payment-methods ul { list-style: none; padding: 0; margin: 0; display: grid; gap: var(--space-2); }
.payment-methods li { font-size: var(--type-micro); color: #556; line-height: 1.5; }

/* HUB grid (unchanged) */
.plan-grid { display: grid; gap: var(--space-6); margin: 0 auto; justify-content: center; }
.plan-grid-4 { grid-template-columns: repeat(4, minmax(220px, 1fr)); max-width: 1040px; }
@media (max-width: 900px) {
  .plan-grid-4 { grid-template-columns: repeat(2, minmax(220px, 1fr)); max-width: 560px; }
}
@media (max-width: 520px) {
  .plan-grid-4 { grid-template-columns: 1fr; max-width: 360px; }
  .single-plan-card { padding: var(--space-6) var(--space-5); }
  .price-amount { font-size: 2.75rem; }
  .plan-card-header h2 { font-size: 1.75rem; }
}
</style>
