---
import { navItems, externalLinks } from '../../data/nav'
interface Props { current?: string }
const { current } = Astro.props
---
<nav data-adaptive-nav class="adaptive-nav" aria-label="navegação principal">
  <div class="nav-inner">
    <a href="/" aria-label="REC início" class="nav-logo-wrap">
      <img src="/logo-icon.png" alt="" aria-hidden="true" class="nav-icon" />
      <img src="/logo-full.png" alt="REC" class="nav-logo" />
    </a>

    <ul class="nav-items">
      {navItems.map(item => (
        <li><a href={item.href} class:list={[{ active: current === item.label }]}>{item.label}</a></li>
      ))}
    </ul>
    <a href={externalLinks.whatsapp.url} class="nav-cta" target="_blank" rel="noopener">contato</a>
    <button class="nav-burger" aria-label="abrir menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<style>
.adaptive-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255,255,255,0.94);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(37,52,57,0.08);
  transition: transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
}
.adaptive-nav.is-hidden { transform: translateY(-100%); }

.nav-inner { max-width: var(--container-max); margin: 0 auto; padding: var(--space-3) var(--space-6); display: flex; align-items: center; gap: var(--space-6); }

.nav-logo-wrap { display: inline-flex; align-items: center; gap: 8px; text-decoration: none; }
.nav-icon { height: 36px; width: auto; display: block; }
.nav-logo { height: 28px; width: auto; display: block; margin-top: 4px; mix-blend-mode: multiply; }

.nav-items { display: flex; gap: var(--space-5); margin-left: auto; align-items: center; }
.nav-items a {
  font-size: var(--type-small);
  font-weight: 500;
  color: rgba(1,38,89,0.65);
  letter-spacing: 0.01em;
  position: relative;
  padding-bottom: 3px;
  transition: color 250ms ease;
}
.nav-items a::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0;
  width: 100%; height: 1.5px;
  background: var(--rec-teal);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 250ms ease;
}
.nav-items a:hover { color: var(--rec-blue); }
.nav-items a:hover::after { transform: scaleX(1); }
.nav-items a.active { color: var(--rec-blue); font-weight: 600; }
.nav-items a.active::after { transform: scaleX(1); }

.nav-cta {
  background: transparent;
  color: var(--rec-teal);
  border: 1.5px solid var(--rec-teal);
  padding: 7px 18px;
  border-radius: 999px;
  font-size: var(--type-micro);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  font-weight: 700;
  transition: background 250ms ease, color 250ms ease;
}
.nav-cta:hover { background: var(--rec-teal); color: #fff; }

.nav-burger { display: none; flex-direction: column; gap: 4px; padding: 4px; background: none; border: none; cursor: pointer; }
.nav-burger span { width: 22px; height: 2px; background: var(--rec-blue); border-radius: 2px; }

@media (max-width: 768px) {
  .nav-items, .nav-cta { display: none; }
  .nav-burger { display: flex; margin-left: auto; }
}
</style>

<script>
  import { initNavScroll, initNavDrawer } from './nav-scroll'
  initNavScroll()
  initNavDrawer()
</script>
