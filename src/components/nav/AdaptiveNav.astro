---
import { navItems } from '../../data/nav'
interface Props { current?: string }
const { current } = Astro.props
---
<nav data-adaptive-nav class="adaptive-nav" aria-label="navegação principal">
  <div class="nav-inner">
    <a href="/" aria-label="REC início" class="nav-logo-wrap">
      <img src="/logo-icon.png" alt="" aria-hidden="true" class="nav-icon" />
      <img src="/NORMAL - FT.png" alt="REC" class="nav-logo" />
    </a>

    <ul class="nav-items">
      {navItems.map(item => (
        <li><a href={item.href} class:list={[{ active: current === item.label }]}>{item.label}</a></li>
      ))}
    </ul>
    <button class="nav-burger touch-target" aria-label="abrir menu" aria-expanded="false">
      <span class="burger-bar" aria-hidden="true"></span>
      <span class="burger-bar" aria-hidden="true"></span>
      <span class="burger-bar" aria-hidden="true"></span>
    </button>
  </div>
</nav>

<style>
.adaptive-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255,255,255,0.94);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(37,52,57,0.08);
  transition: transform 600ms cubic-bezier(0.22, 1, 0.36, 1), opacity 280ms var(--easing);
}
.adaptive-nav.is-hidden { transform: translateY(-100%); }

/* Quando modal de empresa está aberto, navbar somem pra liberar o botão de fechar */
:global(body.modal-open) .adaptive-nav {
  opacity: 0;
  pointer-events: none;
  transform: translateY(-100%);
}

.nav-inner {
  max-width: var(--container-max);
  margin: 0 auto;
  padding: var(--space-3) var(--space-5);
  display: flex;
  align-items: center;
  gap: var(--space-6);
}
@media (min-width: 640px) {
  .nav-inner { padding: var(--space-3) var(--space-6); }
}

.nav-logo-wrap { display: inline-flex; align-items: center; gap: 8px; text-decoration: none; }
.nav-icon { height: 36px; width: auto; display: block; }
.nav-logo { height: 28px; width: auto; display: block; margin-top: 4px; }

.nav-items { display: flex; gap: var(--space-5); margin-left: auto; align-items: center; }
.nav-items a {
  font-size: var(--type-small);
  font-weight: 500;
  color: rgba(1,38,89,0.65);
  letter-spacing: 0.01em;
  position: relative;
  padding-bottom: 3px;
  transition: color 250ms ease;
}
.nav-items a::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0;
  width: 100%; height: 1.5px;
  background: var(--rec-teal);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 250ms ease;
}
.nav-items a:hover { color: var(--rec-blue); }
.nav-items a:hover::after { transform: scaleX(1); }
.nav-items a.active { color: var(--rec-blue); font-weight: 600; }
.nav-items a.active::after { transform: scaleX(1); }

/* ============================================
   BURGER BUTTON — morfa pra X ao abrir
   ============================================ */
.nav-burger {
  display: none;
  position: relative;
  width: 44px;
  height: 44px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  margin-left: auto;
}
.burger-bar {
  position: absolute;
  left: 50%;
  width: 22px;
  height: 2px;
  background: var(--rec-blue);
  border-radius: 2px;
  transform: translateX(-50%);
  transform-origin: center;
  transition:
    transform 320ms var(--easing),
    opacity 200ms var(--easing),
    top 320ms var(--easing);
}
.burger-bar:nth-child(1) { top: 14px; }
.burger-bar:nth-child(2) { top: 21px; }
.burger-bar:nth-child(3) { top: 28px; }

/* Estado aberto: vira um X */
.nav-burger[aria-expanded="true"] .burger-bar:nth-child(1) {
  top: 21px;
  transform: translateX(-50%) rotate(45deg);
}
.nav-burger[aria-expanded="true"] .burger-bar:nth-child(2) {
  opacity: 0;
}
.nav-burger[aria-expanded="true"] .burger-bar:nth-child(3) {
  top: 21px;
  transform: translateX(-50%) rotate(-45deg);
}

@media (max-width: 1023px) {
  .nav-items { display: none; }
  .nav-burger { display: block; }
}
</style>

<script>
  import { initNavScroll, initNavDrawer } from './nav-scroll'
  initNavScroll()
  initNavDrawer()
</script>
