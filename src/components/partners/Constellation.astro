---
import { loadAllPartners } from '../../data/partners-merged'
import { SECTOR_LABEL } from '../../data/sector-labels'
import { safeJson } from '../../utils/safe-json'
const partners = await loadAllPartners()
// Inject sectorLabel pra o modal exibir label legível em vez do key cru
const partnersWithLabel = partners.map(p => ({
  ...p,
  sectorLabel: SECTOR_LABEL[p.sector] ?? p.sector,
}))
---
<div class="constellation-wrap" data-constellation-wrap>
  <div class="constellation-viewport">
    <div
      class="constellation"
      data-constellation
      aria-label="rede de empresas REC"
    ></div>
  </div>
</div>

<!-- Partners (static + CMS-managed merged) injected as JSON for client script -->
<script type="application/json" data-partners-json set:html={safeJson(partnersWithLabel)}></script>

<script>
  import { initConstellation } from './constellation'
  const el = document.querySelector<HTMLElement>('[data-constellation]')
  const dataEl = document.querySelector<HTMLElement>('[data-partners-json]')
  if (el && dataEl) {
    try {
      const partners = JSON.parse(dataEl.textContent || '[]')
      initConstellation(el, partners)
    } catch (err) {
      console.error('failed to parse partners data', err)
    }
  }

  // Esconde/mostra conforme ViewToggle
  const wrap = document.querySelector<HTMLElement>('[data-constellation-wrap]')
  if (wrap) {
    document.addEventListener('partners-view-change' as any, (ev: any) => {
      const mode = ev.detail?.mode
      wrap.hidden = mode !== 'constellation'
    })
  }
</script>

<style>
.constellation-wrap { padding: var(--space-8) var(--space-3); max-width: var(--container-max); margin: 0 auto; }
.constellation-viewport {
  position: relative;
  width: 100%;
  height: 720px;
  overflow: hidden;
  border-radius: 12px;
  background: radial-gradient(ellipse at center, rgba(0,161,152,0.04) 0%, rgba(255,255,255,0) 70%);
}
.constellation { position: relative; width: 100%; height: 100%; touch-action: none; user-select: none; }
.constellation :global(.constellation-edges) { position: absolute; inset: 0; pointer-events: none; z-index: 0; }
.constellation :global(.constellation-node) {
  position: absolute;
  width: 96px;
  height: 54px;
  padding: 6px 8px;
  background: #fff;
  border: 1px solid rgba(37,52,57,0.1);
  border-radius: 8px;
  box-shadow: 0 3px 8px rgba(62,64,149,0.08);
  cursor: grab;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: box-shadow var(--motion-fast) var(--easing), border-color var(--motion-fast) var(--easing);
  touch-action: none;
  z-index: 1;
}
.constellation :global(.constellation-node:hover) {
  box-shadow: 0 8px 20px rgba(62,64,149,0.22);
  border-color: var(--rec-teal);
  z-index: 2;
}
.constellation :global(.constellation-node:active) { cursor: grabbing; }
.constellation :global(.constellation-node img) { max-width: 100%; max-height: 100%; object-fit: contain; pointer-events: none; }
.constellation :global(.constellation-node.is-center) {
  width: 160px;
  height: 90px;
  padding: 12px 16px;
  background: linear-gradient(135deg, #fff 0%, rgba(0,161,152,0.06) 100%);
  border: 2px solid var(--rec-teal);
  box-shadow: 0 8px 28px rgba(0,161,152,0.25), 0 0 0 6px rgba(0,161,152,0.08);
  cursor: default;
  z-index: 3;
}
.constellation :global(.constellation-node.is-center::before) {
  content: '';
  position: absolute;
  inset: -14px;
  border-radius: 14px;
  border: 1px solid rgba(0,161,152,0.18);
  pointer-events: none;
  animation: rec-pulse 3s ease-out infinite;
}
@keyframes rec-pulse {
  0% { transform: scale(1); opacity: 0.6; }
  100% { transform: scale(1.25); opacity: 0; }
}
.constellation.fallback-static :global(.static-grid) {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
  gap: var(--space-3);
  padding: var(--space-3);
  height: 100%;
  overflow-y: auto;
}
.constellation.fallback-static :global(.static-tile) {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64px;
  padding: 6px;
  background: #fff;
  border: 1px solid rgba(37,52,57,0.1);
  border-radius: 8px;
  transition: border-color var(--motion-fast) var(--easing);
}
.constellation.fallback-static :global(.static-tile:hover) { border-color: var(--rec-teal); }
.constellation.fallback-static :global(.static-tile img) { max-width: 100%; max-height: 100%; object-fit: contain; }
.hint { text-align: center; font-size: var(--type-micro); letter-spacing: 0.1em; text-transform: uppercase; color: #999; margin-top: var(--space-3); }
@media (max-width: 600px) {
  .constellation-viewport { height: 560px; }
  .constellation :global(.constellation-node) { width: 78px; height: 44px; padding: 4px 6px; }
  .constellation :global(.constellation-node.is-center) { width: 130px; height: 76px; padding: 10px 12px; }
}
@media (prefers-reduced-motion: reduce) {
  .constellation :global(.constellation-node.is-center::before) { animation: none; }
}
</style>
