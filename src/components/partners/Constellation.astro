---
---
<div class="constellation-wrap">
  <div class="constellation" data-constellation aria-label="rede de parceiros REC"></div>
  <p class="hint" aria-hidden="true">arrasta um logo - pinça pra dar zoom - toca pra ver detalhes</p>
</div>

<script>
  import { initConstellation } from './constellation'
  const el = document.querySelector<HTMLElement>('[data-constellation]')
  if (el) initConstellation(el)
</script>

<style>
.constellation-wrap { padding: var(--space-8) var(--space-3); max-width: var(--container-max); margin: 0 auto; }
.constellation { position: relative; width: 100%; height: 600px; touch-action: none; user-select: none; }
.constellation :global(.constellation-edges) { position: absolute; inset: 0; pointer-events: none; }
.constellation :global(.constellation-node) {
  position: absolute;
  width: 64px;
  height: 36px;
  padding: 4px 6px;
  background: #fff;
  border: 1px solid rgba(37,52,57,0.1);
  border-radius: 6px;
  box-shadow: 0 2px 6px rgba(62,64,149,0.06);
  cursor: grab;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform var(--motion-fast) var(--easing), box-shadow var(--motion-fast) var(--easing);
  touch-action: none;
}
.constellation :global(.constellation-node:hover) { box-shadow: 0 6px 16px rgba(62,64,149,0.2); }
.constellation :global(.constellation-node:active) { cursor: grabbing; }
.constellation :global(.constellation-node img) { max-width: 100%; max-height: 100%; object-fit: contain; pointer-events: none; }
.constellation.fallback-static { display: none; }
.hint { text-align: center; font-size: var(--type-micro); letter-spacing: 0.1em; text-transform: uppercase; color: #999; margin-top: var(--space-3); }
@media (max-width: 600px) { .constellation { height: 480px; } }
</style>
