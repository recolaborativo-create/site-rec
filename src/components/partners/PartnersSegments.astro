---
import { loadAllPartners } from '../../data/partners-merged'
import { SECTOR_LABEL } from '../../data/sector-labels'
import { safeJson } from '../../utils/safe-json'
import type { PartnerSector } from '../../data/partners'

const partners = await loadAllPartners()

// Agrupar por segmento
const grouped = new Map<PartnerSector, typeof partners>()
partners.forEach(p => {
  if (!grouped.has(p.sector)) grouped.set(p.sector, [])
  grouped.get(p.sector)!.push(p)
})

// Ordem: maiores grupos primeiro
const segments = [...grouped.entries()]
  .map(([key, list]) => ({
    key,
    label: SECTOR_LABEL[key] ?? key,
    count: list.length,
    partners: list.sort((a, b) => b.reach - a.reach || a.name.localeCompare(b.name, 'pt-BR')),
  }))
  .sort((a, b) => b.count - a.count || a.label.localeCompare(b.label, 'pt-BR'))
---
<div class="partners-segments" data-partners-segments hidden>
  <div class="segments-empty" data-segments-empty hidden>
    <span class="segments-empty-icon" aria-hidden="true">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </span>
    <p class="segments-empty-title">nenhuma empresa encontrada</p>
    <p class="segments-empty-sub">tenta outro nome ou limpa os filtros</p>
  </div>
  <div class="segments-container">
    {segments.map((seg) => (
      <section class="segment-block" data-segment-block={seg.key}>
        <header class="segment-header">
          <div class="segment-title-row">
            <h3 class="segment-title">{seg.label}</h3>
            <span class="segment-count">{seg.count} {seg.count === 1 ? 'empresa' : 'empresas'}</span>
          </div>
          <div class="segment-line" aria-hidden="true"></div>
        </header>

        <div class="segment-strip">
          {seg.partners.map(p => (
            <button
              class="seg-card"
              data-partner-id={p.id}
              data-name={p.name}
              type="button"
              aria-label={`Ver detalhes de ${p.name}`}
            >
              <div class="seg-card-logo">
                <img src={p.logo} alt={p.name} loading="lazy" decoding="async" />
              </div>
              <span class="seg-card-name">{p.name}</span>
            </button>
          ))}
        </div>
      </section>
    ))}
  </div>
</div>

<script type="application/json" data-segments-partners-json set:html={safeJson(partners.map(p => ({
  ...p,
  sectorLabel: SECTOR_LABEL[p.sector] ?? p.sector,
})))}></script>

<script>
  import type { PartnerLite } from '../../data/partners'
  const root = document.querySelector<HTMLElement>('[data-partners-segments]')
  const dataEl = document.querySelector<HTMLElement>('[data-segments-partners-json]')
  if (root && dataEl) {
    let partners: PartnerLite[] = []
    try { partners = JSON.parse(dataEl.textContent || '[]') } catch {}
    const byId = new Map(partners.map(p => [p.id, p]))

    root.addEventListener('click', (e) => {
      const card = (e.target as HTMLElement).closest<HTMLElement>('.seg-card')
      if (!card) return
      const id = card.dataset.partnerId
      if (!id) return
      const partner = byId.get(id)
      if (!partner) return
      document.dispatchEvent(new CustomEvent('partner-modal-open', { detail: partner }))
    })

    const emptyEl = root.querySelector<HTMLElement>('[data-segments-empty]')
    const containerEl = root.querySelector<HTMLElement>('.segments-container')
    let activeSectors: string[] = []
    let activeQuery = ''

    const norm = (s: string) => (s || '')
      .toLowerCase()
      .normalize('NFD')
      .replace(/[̀-ͯ]/g, '')
      .trim()

    function applyFilters() {
      const showAllSectors = activeSectors.length === 0
      const q = norm(activeQuery)
      const blocks = root.querySelectorAll<HTMLElement>('.segment-block')
      let totalVisible = 0
      blocks.forEach(b => {
        const sectorMatch = showAllSectors || activeSectors.includes(b.dataset.segmentBlock || '')
        if (!sectorMatch) { b.style.display = 'none'; return }
        // dentro do bloco, filtra cards por nome
        const cards = b.querySelectorAll<HTMLElement>('.seg-card')
        let blockVisible = 0
        cards.forEach(c => {
          const matchesName = !q || norm(c.dataset.name || '').includes(q)
          c.style.display = matchesName ? '' : 'none'
          if (matchesName) blockVisible++
        })
        // se busca está ativa e bloco ficou vazio, esconde o bloco inteiro
        b.style.display = blockVisible > 0 ? '' : 'none'
        totalVisible += blockVisible
      })
      if (emptyEl) emptyEl.hidden = totalVisible > 0
      if (containerEl) containerEl.style.display = totalVisible > 0 ? '' : 'none'
    }

    document.addEventListener('partners-filter' as any, (ev: any) => {
      activeSectors = ev.detail?.sectors ?? []
      applyFilters()
    })
    document.addEventListener('partners-search' as any, (ev: any) => {
      activeQuery = ev.detail?.query ?? ''
      applyFilters()
    })

    document.addEventListener('partners-view-change' as any, (ev: any) => {
      const mode = ev.detail?.mode
      root.hidden = mode !== 'segments'
    })
  }
</script>

<style>
.partners-segments {
  max-width: var(--container-max);
  margin: 0 auto;
  padding: var(--space-6) var(--space-6) var(--space-10);
}

.segments-container {
  display: flex;
  flex-direction: column;
  gap: var(--space-10);
}

.segments-empty {
  text-align: center;
  padding: var(--space-12) var(--space-6);
  max-width: 360px;
  margin: 0 auto;
}
.segments-empty-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: rgba(0, 161, 152, 0.08);
  color: var(--rec-teal);
  margin-bottom: var(--space-4);
}
.segments-empty-title {
  font-family: var(--font-display);
  font-size: 1.3rem;
  font-weight: 400;
  color: var(--rec-blue);
  margin: 0 0 6px;
}
.segments-empty-sub {
  font-family: var(--font-ui);
  font-size: 0.9rem;
  color: rgba(1, 38, 89, 0.55);
  margin: 0;
}

.segment-block {
  position: relative;
}

.segment-header {
  margin-bottom: var(--space-4);
}
.segment-title-row {
  display: flex;
  align-items: baseline;
  gap: var(--space-3);
  margin-bottom: var(--space-2);
}
.segment-title {
  font-family: var(--font-display);
  font-size: clamp(1.2rem, 2.2vw, 1.55rem);
  font-weight: 400;
  letter-spacing: -0.015em;
  color: var(--rec-blue);
  margin: 0;
  text-transform: lowercase;
}
.segment-count {
  font-family: var(--font-ui);
  font-size: 0.66rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--rec-teal);
  background: rgba(0, 161, 152, 0.08);
  padding: 4px 10px;
  border-radius: 999px;
}
.segment-line {
  height: 1px;
  background: linear-gradient(to right, rgba(0, 161, 152, 0.32) 0%, rgba(0, 161, 152, 0) 80%);
}

.segment-strip {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
  gap: var(--space-3);
}

.seg-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-4) var(--space-3);
  background: #fff;
  border: 1px solid rgba(1, 38, 89, 0.08);
  border-radius: 12px;
  cursor: pointer;
  text-align: center;
  overflow: hidden;
  transition:
    transform 320ms var(--easing),
    border-color 320ms var(--easing),
    box-shadow 320ms var(--easing);
}
.seg-card:hover {
  transform: translateY(-3px);
  border-color: rgba(0, 161, 152, 0.32);
  box-shadow: 0 10px 24px rgba(1, 38, 89, 0.08);
}
.seg-card:focus-visible {
  outline: none;
  border-color: var(--rec-teal);
  box-shadow: 0 0 0 3px rgba(0, 161, 152, 0.22);
}

.seg-card-logo {
  width: 100%;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6px;
}
.seg-card-logo img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
}

.seg-card-name {
  font-family: var(--font-ui);
  font-size: 0.74rem;
  font-weight: 600;
  line-height: 1.3;
  color: rgba(1, 38, 89, 0.78);
  /* Trunca em 2 linhas */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  overflow: hidden;
}

@media (max-width: 1023px) {
  .partners-segments { padding: var(--space-4) var(--space-4) var(--space-8); }
  .segments-container { gap: var(--space-6); }
  /* Block precisa de position relative pro indicador de swipe */
  .segment-block { position: relative; }
  /* Strip vira GRID DE 3 LINHAS rolando lateralmente (swipe horizontal) */
  .segment-strip {
    display: grid;
    grid-template-rows: repeat(3, 1fr);
    grid-auto-flow: column;
    grid-auto-columns: 130px;
    gap: var(--space-2);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: var(--space-1) 0 var(--space-2);
    margin: 0 calc(-1 * var(--space-2));
    padding-left: var(--space-2);
    padding-right: var(--space-2);
  }
  .segment-strip::-webkit-scrollbar { display: none; }
  .seg-card {
    scroll-snap-align: start;
    padding: var(--space-2);
    min-height: 88px;
  }
  .seg-card-logo { height: 40px; }
  .seg-card-name { font-size: 0.7rem; }

  /* SETINHA de swipe (indicador animado lado direito) — só mobile */
  .segment-block::after {
    content: '';
    position: absolute;
    top: 60%;
    right: -2px;
    width: 12px;
    height: 12px;
    border-right: 2.5px solid var(--rec-teal);
    border-top: 2.5px solid var(--rec-teal);
    transform: translateY(-50%) rotate(45deg);
    animation: seg-swipe-hint 1.6s ease-in-out infinite;
    pointer-events: none;
    z-index: 5;
    filter: drop-shadow(0 1px 4px rgba(0,161,152,0.35));
  }
  @keyframes seg-swipe-hint {
    0%, 100% { transform: translateY(-50%) translateX(0) rotate(45deg); opacity: 0.4; }
    50%      { transform: translateY(-50%) translateX(5px) rotate(45deg); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .segment-block::after { animation: none; opacity: 0.55; }
  }
}
</style>
