---
// Side card opened when a constellation node is clicked.
// Description and reviews wire up at runtime via constellation.ts events.
---
<aside class="partner-card" data-partner-card aria-hidden="true" role="dialog" aria-label="detalhes da empresa">
  <button class="card-close" aria-label="fechar">×</button>

  <img class="card-logo" alt="" />
  <h3 class="card-name"></h3>
  <div class="card-sector"></div>

  <a class="card-instagram" target="_blank" rel="noopener" style="display:none"></a>

  <section class="card-section">
    <h4 class="card-section-title">sobre a empresa</h4>
    <p class="card-description">descrição em breve</p>
  </section>

  <section class="card-section card-reviews-section">
    <h4 class="card-section-title">avaliações</h4>
    <div class="rating-summary">
      <div class="rating-stars" data-rating-stars aria-label="média de avaliações">
        <span class="star" data-i="1">★</span>
        <span class="star" data-i="2">★</span>
        <span class="star" data-i="3">★</span>
        <span class="star" data-i="4">★</span>
        <span class="star" data-i="5">★</span>
      </div>
      <span class="rating-meta" data-rating-meta>sem avaliações ainda</span>
    </div>

    <ul class="reviews-list" data-reviews-list aria-live="polite"></ul>

    <button class="reviews-toggle" data-reviews-toggle type="button">
      <span class="reviews-toggle-line"></span>
      <span class="reviews-toggle-text">deixar uma avaliação</span>
      <span class="reviews-toggle-arrow" aria-hidden="true">→</span>
    </button>

    <form class="review-form" data-review-form hidden>
      <label class="form-row">
        <span class="form-label">sua nota</span>
        <div class="rate-input" role="radiogroup" aria-label="nota de 1 a 5 estrelas">
          {[1,2,3,4,5].map(n => (
            <button type="button" class="rate-star" data-rate={n} role="radio" aria-checked="false" aria-label={`${n} estrelas`}>★</button>
          ))}
        </div>
      </label>
      <label class="form-row">
        <span class="form-label">seu nome (opcional)</span>
        <input type="text" name="name" maxlength="40" autocomplete="off" />
      </label>
      <label class="form-row">
        <span class="form-label">comentário (até 200 caracteres)</span>
        <textarea name="comment" maxlength="200" rows="3"></textarea>
      </label>
      <div class="form-actions">
        <button type="button" class="form-cancel" data-review-cancel>cancelar</button>
        <button type="submit" class="form-submit">enviar</button>
      </div>
      <p class="form-status" data-review-status aria-live="polite"></p>
    </form>
  </section>
</aside>

<script>
  // Reviews UI — fetches from /api/reviews?partnerId=... and posts new ones via /api/reviews
  // The Vercel KV backend is wired via api/reviews.ts at the project root.
  type Review = { rating: number; name?: string; comment?: string; createdAt: number }

  const card = document.querySelector<HTMLElement>('[data-partner-card]')
  if (card) {
    const starsEl = card.querySelector<HTMLElement>('[data-rating-stars]')!
    const metaEl = card.querySelector<HTMLElement>('[data-rating-meta]')!
    const listEl = card.querySelector<HTMLElement>('[data-reviews-list]')!
    const toggleBtn = card.querySelector<HTMLButtonElement>('[data-reviews-toggle]')!
    const form = card.querySelector<HTMLFormElement>('[data-review-form]')!
    const cancelBtn = card.querySelector<HTMLButtonElement>('[data-review-cancel]')!
    const statusEl = card.querySelector<HTMLElement>('[data-review-status]')!
    const rateStars = card.querySelectorAll<HTMLButtonElement>('[data-rate]')
    let chosenRating = 0

    function paintStars(value: number) {
      const stars = starsEl.querySelectorAll<HTMLElement>('.star')
      stars.forEach((s, idx) => {
        s.classList.toggle('filled', idx < Math.round(value))
      })
    }

    function renderReviews(reviews: Review[]) {
      if (reviews.length === 0) {
        metaEl.textContent = 'sem avaliações ainda'
        paintStars(0)
        listEl.innerHTML = ''
        return
      }
      const avg = reviews.reduce((s, r) => s + r.rating, 0) / reviews.length
      paintStars(avg)
      metaEl.textContent = `${avg.toFixed(1)} · ${reviews.length} ${reviews.length === 1 ? 'avaliação' : 'avaliações'}`
      const fmt = new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })
      listEl.innerHTML = reviews
        .slice()
        .sort((a, b) => b.createdAt - a.createdAt)
        .slice(0, 6)
        .map(r => {
          const stars = '★'.repeat(r.rating) + '☆'.repeat(5 - r.rating)
          const safeName = (r.name || 'anônimo').replace(/[<>&"]/g, '')
          const safeComment = (r.comment || '').replace(/[<>&"]/g, '')
          const date = fmt.format(new Date(r.createdAt))
          return `<li class="review-item">
            <div class="review-meta"><span class="review-stars">${stars}</span><span class="review-name">${safeName}</span><span class="review-date">${date}</span></div>
            ${safeComment ? `<p class="review-comment">${safeComment}</p>` : ''}
          </li>`
        })
        .join('')
    }

    async function loadReviews(partnerId: string) {
      try {
        const res = await fetch(`/api/reviews?partnerId=${encodeURIComponent(partnerId)}`)
        if (!res.ok) throw new Error('fetch failed')
        const data = await res.json() as { reviews: Review[] }
        renderReviews(data.reviews || [])
      } catch {
        renderReviews([])
      }
    }

    rateStars.forEach(btn => {
      btn.addEventListener('click', () => {
        chosenRating = Number(btn.dataset.rate)
        rateStars.forEach((s, i) => {
          const filled = i < chosenRating
          s.classList.toggle('filled', filled)
          s.setAttribute('aria-checked', String(i + 1 === chosenRating))
        })
      })
    })

    toggleBtn.addEventListener('click', () => {
      form.hidden = !form.hidden
      toggleBtn.hidden = !form.hidden
    })

    cancelBtn.addEventListener('click', () => {
      form.hidden = true
      toggleBtn.hidden = false
      chosenRating = 0
      rateStars.forEach(s => { s.classList.remove('filled'); s.setAttribute('aria-checked', 'false') })
      ;(form.elements.namedItem('name') as HTMLInputElement).value = ''
      ;(form.elements.namedItem('comment') as HTMLTextAreaElement).value = ''
      statusEl.textContent = ''
    })

    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      if (chosenRating < 1) {
        statusEl.textContent = 'escolhe uma nota antes de enviar.'
        statusEl.dataset.kind = 'error'
        return
      }
      const partnerId = card.dataset.partnerId
      if (!partnerId) return
      const name = (form.elements.namedItem('name') as HTMLInputElement).value.trim().slice(0, 40)
      const comment = (form.elements.namedItem('comment') as HTMLTextAreaElement).value.trim().slice(0, 200)
      statusEl.textContent = 'enviando…'
      statusEl.dataset.kind = ''
      try {
        const res = await fetch('/api/reviews', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ partnerId, rating: chosenRating, name, comment }),
        })
        if (!res.ok) {
          const err = await res.json().catch(() => ({}))
          throw new Error(err.error || 'submission failed')
        }
        statusEl.textContent = 'avaliação enviada. obrigada!'
        statusEl.dataset.kind = 'success'
        await loadReviews(partnerId)
        setTimeout(() => cancelBtn.click(), 1500)
      } catch (err) {
        statusEl.textContent = (err as Error).message || 'erro ao enviar.'
        statusEl.dataset.kind = 'error'
      }
    })

    document.addEventListener('partner-card-opened' as any, (ev: any) => {
      // Reset form on open
      form.hidden = true
      toggleBtn.hidden = false
      chosenRating = 0
      rateStars.forEach(s => { s.classList.remove('filled'); s.setAttribute('aria-checked', 'false') })
      ;(form.elements.namedItem('name') as HTMLInputElement).value = ''
      ;(form.elements.namedItem('comment') as HTMLTextAreaElement).value = ''
      statusEl.textContent = ''
      // Load reviews for this partner
      const id = ev.detail?.id
      if (id) loadReviews(id)
    })
  }
</script>

<style>
.partner-card {
  position: fixed;
  right: 0;
  top: 0;
  height: 100vh;
  width: min(420px, 92vw);
  background: #fff;
  box-shadow: -8px 0 24px rgba(0,0,0,0.1);
  padding: var(--space-12) var(--space-6) var(--space-8);
  transform: translateX(100%);
  transition: transform var(--motion-medium) var(--easing);
  z-index: 150;
  overflow-y: auto;
}
.partner-card.open { transform: translateX(0); }
.card-close { position: absolute; top: var(--space-4); right: var(--space-6); font-size: 1.8rem; padding: var(--space-2) var(--space-3); color: var(--rec-dark); }
.card-logo { width: 140px; height: 84px; object-fit: contain; margin-bottom: var(--space-5); border: 1px solid rgba(37,52,57,0.08); border-radius: 8px; padding: var(--space-3); background: #fff; }
.card-name { font-size: 1.4rem; color: var(--rec-dark); margin-bottom: var(--space-2); font-weight: 800; }
.card-sector { font-size: var(--type-micro); letter-spacing: 0.15em; text-transform: uppercase; color: #667; margin-bottom: var(--space-4); }
.card-sector:empty { display: none; }
.card-instagram {
  display: inline-block;
  color: var(--rec-purple);
  font-weight: 700;
  font-size: var(--type-small);
  margin-bottom: var(--space-6);
}
.card-instagram:hover { color: var(--rec-teal); }

.card-section {
  border-top: 1px solid rgba(37,52,57,0.08);
  padding-top: var(--space-5);
  margin-top: var(--space-5);
}
.card-section-title {
  font-size: var(--type-micro);
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: #667;
  font-weight: 700;
  margin-bottom: var(--space-3);
}
.card-description {
  font-size: var(--type-small);
  line-height: 1.55;
  color: var(--rec-dark);
  /* 5-line clamp — keeps layout consistent regardless of content length */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 5;
  line-clamp: 5;
  overflow: hidden;
  min-height: 6.5em;
}
.card-description.is-empty {
  color: #aab;
  font-style: italic;
}

/* Rating summary */
.rating-summary { display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-4); }
.rating-stars { display: inline-flex; gap: 2px; font-size: 1.15rem; line-height: 1; color: rgba(37,52,57,0.18); }
.rating-stars .star.filled { color: #f5b400; }
.rating-meta { font-size: var(--type-micro); color: #667; letter-spacing: 0.04em; }

/* Existing reviews list */
.reviews-list { list-style: none; padding: 0; margin: 0 0 var(--space-4); display: grid; gap: var(--space-3); }
.reviews-list:empty { display: none; }
.review-item { padding: var(--space-3); background: rgba(0,161,152,0.04); border-radius: 8px; }
.review-meta { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-2); margin-bottom: 4px; font-size: var(--type-micro); }
.review-stars { color: #f5b400; letter-spacing: 1px; }
.review-name { font-weight: 700; color: var(--rec-dark); }
.review-date { color: #889; }
.review-comment { font-size: var(--type-small); color: var(--rec-dark); line-height: 1.5; margin: 0; }

/* Reviews submit form — elegant inline trigger (not a heavy button) */
.reviews-toggle {
  display: flex;
  align-items: center;
  gap: 12px;
  width: 100%;
  font-size: var(--type-micro);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--rec-purple);
  font-weight: 700;
  padding: 10px 0;
  background: transparent;
  border: none;
  border-top: 1px solid rgba(37,52,57,0.08);
  cursor: pointer;
  transition: color var(--motion-fast) var(--easing);
}
.reviews-toggle:hover { color: var(--rec-teal); }
.reviews-toggle-line {
  flex: 1;
  height: 1px;
  background: linear-gradient(to right, rgba(108,90,178,0.3) 0%, rgba(108,90,178,0.05) 100%);
  transition: background var(--motion-fast) var(--easing);
}
.reviews-toggle:hover .reviews-toggle-line {
  background: linear-gradient(to right, rgba(0,161,152,0.4) 0%, rgba(0,161,152,0.05) 100%);
}
.reviews-toggle-text { white-space: nowrap; }
.reviews-toggle-arrow {
  font-weight: 400;
  font-size: 0.95rem;
  transition: transform var(--motion-fast) var(--easing);
}
.reviews-toggle:hover .reviews-toggle-arrow { transform: translateX(4px); }
.review-form { display: grid; gap: var(--space-3); margin-top: var(--space-3); }
.form-row { display: grid; gap: 4px; }
.form-label { font-size: var(--type-micro); letter-spacing: 0.08em; text-transform: uppercase; color: #667; font-weight: 700; }
.review-form input, .review-form textarea {
  font: inherit;
  padding: 8px 10px;
  border-radius: 6px;
  border: 1px solid rgba(37,52,57,0.18);
  background: #fff;
  color: var(--rec-dark);
  resize: vertical;
}
.review-form input:focus, .review-form textarea:focus { outline: none; border-color: var(--rec-teal); box-shadow: 0 0 0 3px rgba(0,161,152,0.12); }
.rate-input { display: inline-flex; gap: 4px; }
.rate-star {
  font-size: 1.5rem;
  line-height: 1;
  color: rgba(37,52,57,0.18);
  padding: 4px;
  transition: color var(--motion-fast) var(--easing);
}
.rate-star:hover, .rate-star.filled { color: #f5b400; }
.form-actions { display: flex; gap: var(--space-3); justify-content: flex-end; }
.form-cancel { font-size: var(--type-micro); padding: 8px 14px; color: #667; }
.form-submit {
  font-size: var(--type-micro);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-weight: 700;
  padding: 8px 16px;
  background: var(--rec-teal);
  color: #fff;
  border-radius: 6px;
  transition: all var(--motion-fast) var(--easing);
}
.form-submit:hover { background: #006d68; }
.form-status { font-size: var(--type-micro); margin: 0; min-height: 1.2em; }
.form-status[data-kind="success"] { color: var(--rec-teal); }
.form-status[data-kind="error"] { color: #c0392b; }
</style>
