---
import { SECTOR_LABEL } from '../../data/sector-labels'
import { safeJson } from '../../utils/safe-json'
import type { PartnerSector } from '../../data/partners'

interface PartnerLite { id: string; name: string; sector: string }
interface Props { sectors: PartnerSector[]; partners?: PartnerLite[] }
const { sectors, partners = [] } = Astro.props
const sorted = sectors
  .map((s) => ({ key: s, label: SECTOR_LABEL[s] ?? s }))
  .sort((a, b) => a.label.localeCompare(b.label, 'pt-BR'))
---
<script type="application/json" data-filter-partners-json set:html={safeJson(partners)}></script>
<div class="segment-filter" data-segment-filter>
  <div class="filter-inner">
    <header class="filter-header" data-filter-toggle role="button" tabindex="0" aria-expanded="false" aria-controls="filter-body">
      <div class="filter-title-wrap">
        <span class="filter-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
        </span>
        <span class="filter-label">filtrar empresas</span>
      </div>
      <span class="filter-count" data-filter-count hidden></span>
      <!-- Chevron — visível só no mobile -->
      <span class="filter-chevron" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
    </header>

    <div class="filter-body" id="filter-body" data-filter-body>

    <!-- BUSCA POR NOME -->
    <div class="search-wrap">
      <span class="search-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </span>
      <input
        type="search"
        class="search-input"
        data-search-input
        placeholder="buscar por nome da empresa..."
        autocomplete="off"
        spellcheck="false"
      />
      <button class="search-clear" data-search-clear type="button" hidden aria-label="limpar busca">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <span class="search-hits" data-search-hits hidden></span>
    </div>

    <div class="chip-row" role="group" aria-label="filtros de segmento">
      {sorted.map((s) => (
        <button class="filter-chip" data-sector={s.key} type="button" aria-pressed="false">
          <span class="chip-check" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
          <span class="chip-label">{s.label}</span>
        </button>
      ))}
    </div>

    <div class="filter-actions">
      <button class="btn-clear" data-clear-filter type="button" hidden>
        <span aria-hidden="true">×</span> limpar filtro
      </button>
      <button class="btn-apply" data-apply-filter type="button" disabled>
        aplicar filtro
        <span class="btn-apply-arrow" aria-hidden="true">→</span>
      </button>
    </div>

    </div><!-- /.filter-body -->
  </div>
</div>

<script>
  const root = document.querySelector<HTMLElement>('[data-segment-filter]')
  if (root) {
    const chips = root.querySelectorAll<HTMLButtonElement>('.filter-chip')
    const clearBtn = root.querySelector<HTMLButtonElement>('[data-clear-filter]')!
    const applyBtn = root.querySelector<HTMLButtonElement>('[data-apply-filter]')!
    const countEl = root.querySelector<HTMLElement>('[data-filter-count]')!
    // pending = "desired next state" (absolute, not delta)
    // Inicializado a partir de applied no primeiro clique após cada apply.
    const pending = new Set<string>()
    const applied = new Set<string>()
    let pendingInitialized = false

    function syncApplyState() {
      const sameAsApplied = pending.size === applied.size && [...pending].every(s => applied.has(s))
      const nothingEverSelected = pending.size === 0 && applied.size === 0
      applyBtn.disabled = sameAsApplied || nothingEverSelected
      applyBtn.classList.toggle('has-pending', !sameAsApplied && pending.size > 0)
    }

    function syncCount() {
      if (applied.size === 0) {
        countEl.hidden = true
      } else {
        countEl.hidden = false
        countEl.textContent = `${applied.size} ${applied.size === 1 ? 'segmento ativo' : 'segmentos ativos'}`
      }
      clearBtn.hidden = applied.size === 0
    }

    function emit(sectors: string[]) {
      document.dispatchEvent(new CustomEvent('partners-filter', { detail: { sectors } }))
    }

    // ===== BUSCA POR NOME =====
    const searchInput = root.querySelector<HTMLInputElement>('[data-search-input]')!
    const searchClear = root.querySelector<HTMLButtonElement>('[data-search-clear]')!
    const searchHits = root.querySelector<HTMLElement>('[data-search-hits]')!
    const partnersDataEl = document.querySelector<HTMLElement>('[data-filter-partners-json]')
    let allPartners: { id: string; name: string; sector: string }[] = []
    try { allPartners = JSON.parse(partnersDataEl?.textContent || '[]') } catch {}

    // normalizar string: lowercase + remove acentos
    const norm = (s: string) => (s || '')
      .toLowerCase()
      .normalize('NFD')
      .replace(/[̀-ͯ]/g, '')
      .trim()

    let currentQuery = ''
    let searchTimer: number | undefined

    function updateHitsBadge() {
      if (!currentQuery) {
        searchHits.hidden = true
        searchHits.classList.remove('no-hits')
        return
      }
      const q = norm(currentQuery)
      const sectors = [...applied]
      const useSectors = sectors.length > 0
      const count = allPartners.filter(p => {
        const matchesName = norm(p.name).includes(q)
        const matchesSector = !useSectors || sectors.includes(p.sector)
        return matchesName && matchesSector
      }).length
      searchHits.hidden = false
      if (count === 0) {
        searchHits.textContent = 'nenhuma empresa'
        searchHits.classList.add('no-hits')
      } else {
        searchHits.textContent = `${count} ${count === 1 ? 'resultado' : 'resultados'}`
        searchHits.classList.remove('no-hits')
      }
    }

    function emitSearch(query: string) {
      currentQuery = query
      document.dispatchEvent(new CustomEvent('partners-search', { detail: { query } }))
      updateHitsBadge()
    }

    function handleSearch() {
      const raw = searchInput.value.trim()
      searchClear.hidden = raw.length === 0
      window.clearTimeout(searchTimer)
      searchTimer = window.setTimeout(() => emitSearch(raw), 120)
    }

    searchInput.addEventListener('input', handleSearch)
    searchClear.addEventListener('click', () => {
      searchInput.value = ''
      searchClear.hidden = true
      emitSearch('')
      searchInput.focus()
    })

    // Atalho: '/' foca a busca (padrão UX moderna)
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement !== searchInput) {
        const tag = (document.activeElement as HTMLElement)?.tagName
        if (tag === 'INPUT' || tag === 'TEXTAREA') return
        e.preventDefault()
        searchInput.focus()
        searchInput.select()
      }
    })

    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        const key = chip.dataset.sector!

        // Na primeira interação pós-apply, pending herda o estado atual de applied.
        // Isso garante que clicar num chip aplicado o REMOVE corretamente,
        // em vez de re-adicioná-lo à fila de "a adicionar".
        if (!pendingInitialized) {
          pending.clear()
          applied.forEach(s => pending.add(s))
          pendingInitialized = true
        }

        if (pending.has(key)) {
          pending.delete(key)
          chip.setAttribute('aria-pressed', 'false')
          chip.classList.remove('selected', 'applied')
        } else {
          pending.add(key)
          chip.setAttribute('aria-pressed', 'true')
          chip.classList.add('selected')
          chip.classList.remove('applied')
        }
        syncApplyState()
      })
    })

    applyBtn.addEventListener('click', () => {
      applied.clear()
      pending.forEach(s => applied.add(s))
      pendingInitialized = false
      // Sincroniza visual: applied → teal, restante → neutro
      chips.forEach(c => {
        const key = c.dataset.sector!
        const isApplied = applied.has(key)
        c.classList.toggle('applied', isApplied)
        c.classList.remove('selected')
        c.setAttribute('aria-pressed', isApplied ? 'true' : 'false')
      })
      emit([...applied])
      syncCount()
      syncApplyState()
      updateHitsBadge()
    })

    clearBtn.addEventListener('click', () => {
      pending.clear()
      applied.clear()
      pendingInitialized = false
      chips.forEach(c => {
        c.setAttribute('aria-pressed', 'false')
        c.classList.remove('selected', 'applied')
      })
      emit([])
      syncCount()
      syncApplyState()
      updateHitsBadge()
    })

    syncApplyState()
  }

  // ─── Mobile: toggle dos filtros via botão "filtrar empresas" ───
  const toggleHeader = document.querySelector<HTMLElement>('[data-filter-toggle]')
  const filterBody = document.querySelector<HTMLElement>('[data-filter-body]')
  const segmentRoot = document.querySelector<HTMLElement>('[data-segment-filter]')
  if (toggleHeader && filterBody && segmentRoot) {
    function isMobile() { return window.matchMedia('(max-width: 1023px)').matches }
    function toggleFilters(force?: boolean) {
      const willExpand = force !== undefined ? force : segmentRoot!.classList.contains('is-collapsed')
      segmentRoot!.classList.toggle('is-collapsed', !willExpand)
      toggleHeader!.setAttribute('aria-expanded', String(willExpand))
    }
    // Estado inicial no mobile: colapsado
    if (isMobile()) toggleFilters(false)
    toggleHeader.addEventListener('click', (e) => {
      if (!isMobile()) return
      e.preventDefault()
      toggleFilters()
    })
    toggleHeader.addEventListener('keydown', (e) => {
      if (!isMobile()) return
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault()
        toggleFilters()
      }
    })
    // Ao redimensionar pra desktop, garante que filtros aparecem
    window.addEventListener('resize', () => {
      if (!isMobile()) {
        segmentRoot.classList.remove('is-collapsed')
        toggleHeader.setAttribute('aria-expanded', 'true')
      } else {
        toggleFilters(false)
      }
    })
  }
</script>

<style>
.segment-filter {
  max-width: var(--container-max);
  margin: 0 auto;
  padding: 0 var(--space-6) var(--space-4);
}
.filter-inner {
  background: linear-gradient(180deg, #fff 0%, rgba(0,161,152,0.03) 100%);
  border: 1px solid rgba(108,90,178,0.12);
  border-radius: 16px;
  padding: var(--space-5) var(--space-6);
  box-shadow: 0 4px 20px rgba(37,52,57,0.04);
}

.filter-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-3);
  margin-bottom: var(--space-4);
  padding-bottom: var(--space-3);
  border-bottom: 1px solid rgba(37,52,57,0.06);
}
.filter-title-wrap { display: inline-flex; align-items: center; gap: 8px; }
.filter-icon {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(0,161,152,0.1);
  color: var(--rec-teal);
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.filter-label {
  font-size: var(--type-small);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--rec-dark);
  font-weight: 700;
}
.filter-count {
  font-size: var(--type-micro);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--rec-teal);
  font-weight: 700;
  padding: 4px 10px;
  background: rgba(0,161,152,0.1);
  border-radius: 999px;
}

/* ===== BUSCA POR NOME ===== */
.search-wrap {
  position: relative;
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: var(--space-4);
  padding: 10px 14px;
  background: #fff;
  border: 1.5px solid rgba(1, 38, 89, 0.1);
  border-radius: 12px;
  transition: all var(--motion-fast) var(--easing);
}
.search-wrap:focus-within {
  border-color: var(--rec-teal);
  box-shadow: 0 0 0 4px rgba(0, 161, 152, 0.12);
}
.search-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: rgba(1, 38, 89, 0.4);
  flex-shrink: 0;
  transition: color var(--motion-fast) var(--easing);
}
.search-wrap:focus-within .search-icon { color: var(--rec-teal); }
.search-input {
  flex: 1;
  min-width: 0;
  border: none;
  outline: none;
  background: transparent;
  font-family: var(--font-ui);
  font-size: 0.95rem;
  color: var(--rec-blue);
  padding: 2px 0;
}
.search-input::placeholder {
  color: rgba(1, 38, 89, 0.38);
  font-weight: 400;
}
/* Remove o X nativo do input[type=search] */
.search-input::-webkit-search-cancel-button { display: none; }
.search-clear {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  border: none;
  background: rgba(1, 38, 89, 0.06);
  color: rgba(1, 38, 89, 0.55);
  cursor: pointer;
  flex-shrink: 0;
  transition: all var(--motion-fast) var(--easing);
}
.search-clear:hover {
  background: var(--rec-teal);
  color: #fff;
  transform: rotate(90deg);
}
.search-hits {
  font-family: var(--font-ui);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--rec-teal);
  padding: 4px 10px;
  background: rgba(0, 161, 152, 0.1);
  border-radius: 999px;
  flex-shrink: 0;
  white-space: nowrap;
}
.search-hits.no-hits {
  color: #c25a5a;
  background: rgba(194, 90, 90, 0.1);
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-bottom: var(--space-4);
}
.filter-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 14px;
  border-radius: 999px;
  font-size: var(--type-micro);
  letter-spacing: 0.04em;
  font-weight: 600;
  color: var(--rec-dark);
  background: rgba(37,52,57,0.04);
  border: 1.5px solid transparent;
  transition: all var(--motion-fast) var(--easing);
  cursor: pointer;
}
.chip-check {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: rgba(0,161,152,0.2);
  color: var(--rec-teal);
  opacity: 0;
  transform: scale(0.6);
  transition: all var(--motion-fast) var(--easing);
}
.chip-label { line-height: 1; }
.filter-chip:hover {
  background: rgba(0,161,152,0.08);
  border-color: rgba(0,161,152,0.2);
  transform: translateY(-1px);
}
.filter-chip.selected {
  background: rgba(108,90,178,0.1);
  border-color: var(--rec-purple);
  color: var(--rec-purple);
}
.filter-chip.selected .chip-check {
  background: var(--rec-purple);
  color: #fff;
  opacity: 1;
  transform: scale(1);
}
.filter-chip.applied {
  background: var(--rec-teal);
  color: #fff;
  border-color: var(--rec-teal);
  box-shadow: 0 4px 12px rgba(0,161,152,0.25);
}
.filter-chip.applied .chip-check {
  background: rgba(255,255,255,0.25);
  color: #fff;
  opacity: 1;
  transform: scale(1);
}

.filter-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-3);
  flex-wrap: wrap;
}
.btn-clear {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: var(--type-micro);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #889;
  font-weight: 700;
  padding: 8px 12px;
  border-radius: 8px;
  cursor: pointer;
  transition: all var(--motion-fast) var(--easing);
  background: transparent;
  border: none;
}
.btn-clear:hover { color: var(--rec-purple); background: rgba(108,90,178,0.06); }

.btn-apply {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-left: auto;
  padding: 11px 24px;
  border-radius: 10px;
  background: linear-gradient(135deg, var(--rec-teal) 0%, var(--rec-teal-deep, #006d68) 100%);
  color: #fff;
  font-size: var(--type-small);
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  border: none;
  transition: all var(--motion-fast) var(--easing);
  box-shadow: 0 4px 14px rgba(0,161,152,0.3);
}
.btn-apply:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 8px 22px rgba(0,161,152,0.4);
}
.btn-apply:disabled {
  opacity: 0.4;
  cursor: not-allowed;
  background: rgba(37,52,57,0.2);
  box-shadow: none;
}
.btn-apply.has-pending {
  animation: btn-pulse 1.6s ease-in-out infinite;
}
@keyframes btn-pulse {
  0%, 100% { box-shadow: 0 4px 14px rgba(0,161,152,0.3); }
  50% { box-shadow: 0 6px 22px rgba(0,161,152,0.5); }
}
.btn-apply-arrow { transition: transform var(--motion-fast) var(--easing); }
.btn-apply:hover:not(:disabled) .btn-apply-arrow { transform: translateX(3px); }

@media (max-width: 600px) {
  .filter-inner { padding: var(--space-4); }
  .btn-apply { width: 100%; justify-content: center; margin-left: 0; }
  .filter-actions { flex-direction: column-reverse; align-items: stretch; }
  .btn-clear { width: 100%; justify-content: center; }
}

/* ============================================
   MOBILE — Filtros escondidos com botão expansível
   ============================================ */
.filter-chevron {
  display: none;
  margin-left: auto;
  color: var(--rec-teal);
  transition: transform var(--motion-fast) var(--easing);
}
.filter-body {
  overflow: hidden;
  transition: max-height 380ms cubic-bezier(0.22,1,0.36,1), opacity 280ms ease;
}

@media (max-width: 1023px) {
  .filter-chevron { display: inline-flex; }
  .filter-header {
    cursor: pointer;
    user-select: none;
    padding: var(--space-2) 0;
    min-height: 48px;
    border-bottom: none;
    margin-bottom: 0;
    transition: padding var(--motion-fast) var(--easing);
  }
  /* Quando colapsado: filter-body some */
  .segment-filter.is-collapsed .filter-body {
    max-height: 0;
    opacity: 0;
    margin-top: 0;
    pointer-events: none;
  }
  .segment-filter.is-collapsed .filter-chevron {
    transform: rotate(0deg);
  }
  .segment-filter:not(.is-collapsed) .filter-chevron {
    transform: rotate(-180deg);
  }
  .segment-filter:not(.is-collapsed) .filter-body {
    max-height: 800px;
    opacity: 1;
    margin-top: var(--space-3);
  }
}
</style>
