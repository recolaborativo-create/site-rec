---
interface Props {
  label: string
  title: string
  body: string
  href: string
  ctaText: string
  invert?: boolean
}
const { label, title, body, href, ctaText, invert = false } = Astro.props
---
<section class:list={['teaser', { invert }]}>
  <div class="teaser-inner">
    <span class="uppercase-label teaser-label">{label}</span>
    <h2 set:html={title} />
    <p>{body}</p>
    <a href={href} class="teaser-cta">{ctaText} →</a>
  </div>
</section>

<style>
.teaser { padding: var(--space-16) var(--space-6); border-bottom: 1px solid rgba(37,52,57,0.05); }
.teaser:nth-child(even) { background: linear-gradient(180deg, #fff 0%, rgba(0,161,152,0.025) 100%); }
.teaser-inner { max-width: 760px; margin: 0 auto; }
.teaser-label { color: var(--rec-teal); display: block; }
.teaser h2 { font-size: clamp(1.8rem, 4vw, 2.6rem); margin: var(--space-3) 0 var(--space-4); color: var(--rec-dark); line-height: 1.1; font-weight: 800; letter-spacing: var(--letter-tight); }
.teaser h2 :global(em) { color: var(--rec-teal); font-style: normal; }
.teaser p { font-size: var(--type-body); color: #556; line-height: 1.7; margin-bottom: var(--space-6); max-width: 580px; }
.teaser-cta { display: inline-block; font-size: var(--type-small); font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--rec-purple); border-bottom: 2px solid var(--rec-teal); padding-bottom: 4px; transition: color var(--motion-fast) var(--easing); }
.teaser-cta:hover { color: var(--rec-teal); }
</style>
