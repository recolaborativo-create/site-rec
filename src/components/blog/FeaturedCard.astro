---
import { getCategoryInfo, readingTime, type Pillar } from '../../utils/blog-category'

interface Props {
  slug: string
  title: string
  excerpt: string
  pillar: Pillar
  publishedAt: Date
  cover?: string
  coverAlt?: string
  body?: string
}

const { slug, title, excerpt, pillar, publishedAt, cover, coverAlt, body = '' } = Astro.props
const cat = getCategoryInfo(pillar)
const dateStr = publishedAt.toLocaleDateString('pt-BR', {
  day: '2-digit', month: 'long', year: 'numeric',
})
const minutes = body ? readingTime(body) : 4
---

<a
  href={`/blog/${slug}`}
  class="featured-card"
  data-category={cat.slug}
  data-reveal
  style={`--cat-color: ${cat.color};`}
  aria-label={title}
>
  {cover ? (
    <div class="featured-media">
      <img src={cover} alt={coverAlt ?? ''} loading="eager" decoding="async" />
      <div class="featured-overlay" aria-hidden="true"></div>
    </div>
  ) : (
    <div class="featured-placeholder" aria-hidden="true">
      <div class="featured-placeholder-noise"></div>
      <span class="featured-placeholder-label">{cat.label}</span>
    </div>
  )}

  <div class="featured-content">
    <div class="featured-meta">
      <span class="featured-cat">
        <span class="featured-cat-dot" aria-hidden="true"></span>
        {cat.label}
      </span>
      <span class="featured-tag-leitura">leitura em destaque</span>
    </div>

    <h2 class="featured-title">{title}</h2>
    <p class="featured-excerpt">{excerpt}</p>

    <div class="featured-footer">
      <span class="featured-cta">
        ler artigo
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </span>
      <span class="featured-info">
        <time datetime={publishedAt.toISOString()}>{dateStr}</time>
        <span aria-hidden="true">·</span>
        <span>{minutes} min</span>
      </span>
    </div>
  </div>
</a>

<style>
.featured-card {
  --cat-color: var(--rec-teal);
  position: relative;
  display: block;
  overflow: hidden;
  border-radius: 24px;
  min-height: 480px;
  text-decoration: none;
  color: #fff;
  background: var(--rec-blue);
  /* Borda + sombra que separa o card do fundo hero em todos os lados */
  outline: 1.5px solid rgba(255,255,255,0.10);
  box-shadow:
    0 0 0 1px rgba(255,255,255,0.06),
    0 24px 60px rgba(1,14,42,0.55),
    0 4px 16px rgba(1,14,42,0.40);
  opacity: 0;
  transform: translateY(32px);
  transition:
    opacity 800ms cubic-bezier(0.22, 1, 0.36, 1),
    transform 800ms cubic-bezier(0.22, 1, 0.36, 1);
}
.featured-card.is-visible {
  opacity: 1;
  transform: translateY(0);
}

/* MEDIA full bleed */
.featured-media {
  position: absolute; inset: 0;
  overflow: hidden;
}
.featured-media img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 900ms cubic-bezier(0.22, 1, 0.36, 1);
}
.featured-card:hover .featured-media img {
  transform: scale(1.035);
}
.featured-overlay {
  position: absolute; inset: 0;
  background:
    linear-gradient(180deg, rgba(1,14,42,0) 0%, rgba(1,14,42,0.55) 55%, rgba(1,14,42,0.92) 100%),
    linear-gradient(135deg, rgba(1,38,89,0.35) 0%, transparent 60%);
}

/* CONTENT */
.featured-content {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  padding: var(--space-12) var(--space-8) var(--space-8);
  min-height: 480px;
  max-width: 760px;
  z-index: 2;
  justify-content: flex-end;
}

.featured-meta {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  flex-wrap: wrap;
}

.featured-cat {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 7px 14px;
  border-radius: 999px;
  background: rgba(255,255,255,0.94);
  font-family: var(--font-ui);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--cat-color);
}
.featured-cat-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--cat-color);
}

.featured-tag-leitura {
  font-family: var(--font-ui);
  font-size: 0.66rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  font-weight: 600;
  color: rgba(255,255,255,0.7);
}

.featured-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4.2vw, 3.4rem);
  line-height: 1.05;
  font-weight: 300;
  letter-spacing: -0.02em;
  color: #fff;
  margin: 0;
  max-width: 680px;
}

.featured-excerpt {
  font-size: 1.05rem;
  line-height: 1.65;
  color: rgba(255,255,255,0.85);
  margin: 0;
  max-width: 580px;
}

.featured-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  margin-top: var(--space-4);
  padding-top: var(--space-4);
  border-top: 1px solid rgba(255,255,255,0.14);
}

.featured-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-ui);
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #fff;
  transition: gap 250ms var(--easing), color 250ms var(--easing);
}
.featured-cta svg {
  width: 18px; height: 18px;
  stroke-width: 2;
  transition: transform 250ms var(--easing);
}
.featured-card:hover .featured-cta {
  gap: 14px;
  color: var(--cat-color);
}
.featured-card:hover .featured-cta svg {
  transform: translateX(4px);
}

.featured-info {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-ui);
  font-size: 0.72rem;
  letter-spacing: 0.06em;
  color: rgba(255,255,255,0.6);
}

/* Placeholder quando não há cover — fundo branco com acento lateral colorido */
.featured-placeholder {
  position: absolute;
  inset: 0;
  background: var(--rec-navy);
  overflow: hidden;
}
.featured-placeholder::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 8px;
  background: var(--cat-color);
  z-index: 2;
}
.featured-placeholder::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 80% at 80% 50%, rgba(255,255,255,0.04) 0%, transparent 70%),
    linear-gradient(135deg, rgba(255,255,255,0.02) 0%, transparent 60%);
}
.featured-placeholder-noise {
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 200px 200px;
  opacity: 0.035;
  mix-blend-mode: screen;
}
.featured-placeholder-label {
  position: absolute;
  bottom: var(--space-6);
  right: var(--space-8);
  font-family: var(--font-ui);
  font-size: clamp(4rem, 8vw, 8rem);
  font-weight: 800;
  letter-spacing: -0.04em;
  color: var(--cat-color);
  opacity: 0.07;
  line-height: 1;
  text-transform: uppercase;
  pointer-events: none;
  z-index: 1;
  white-space: nowrap;
}

@media (max-width: 720px) {
  .featured-card { min-height: 420px; }
  .featured-content { padding: var(--space-10) var(--space-6) var(--space-6); min-height: 420px; }
  .featured-title { font-size: clamp(1.6rem, 7vw, 2.4rem); }
  .featured-footer { flex-direction: column; align-items: flex-start; gap: var(--space-3); }
}

@media (prefers-reduced-motion: reduce) {
  .featured-card { opacity: 1; transform: none; transition: none; }
  .featured-card:hover .featured-media img { transform: none; }
}
</style>
