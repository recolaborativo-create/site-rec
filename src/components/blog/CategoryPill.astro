---
import { CATEGORIES, type Category } from '../../utils/blog-category'

type Value = 'all' | Category

interface Props {
  value: Value
  active?: boolean
  filterable?: boolean
  size?: 'sm' | 'md'
  variant?: 'dark' | 'light'   // dark = sobre fundo navy | light = sobre fundo branco
}

const { value, active = false, filterable = false, size = 'md', variant = 'dark' } = Astro.props

const labels: Record<Value, string> = {
  all: 'todos',
  eventos: CATEGORIES.eventos.label.toLowerCase(),
  educacional: CATEGORIES.educacional.label.toLowerCase(),
  historias: CATEGORIES.historias.label.toLowerCase(),
  empreendedorismo: CATEGORIES.empreendedorismo.label.toLowerCase(),
}

const colors: Record<Value, string> = {
  all: '#012659',
  eventos: CATEGORIES.eventos.color,
  educacional: CATEGORIES.educacional.color,
  historias: CATEGORIES.historias.color,
  empreendedorismo: CATEGORIES.empreendedorismo.color,
}

const Tag = filterable ? 'button' : 'span'
---

<Tag
  class:list={['cat-pill', `cat-pill--${value}`, `cat-pill--${size}`, { 'is-active': active, 'cat-pill--on-light': variant === 'light' }]}
  data-category={value}
  style={`--cat-color: ${colors[value]};`}
  type={filterable ? 'button' : undefined}
>
  <span class="cat-pill-dot" aria-hidden="true"></span>
  {labels[value]}
</Tag>

<style>
.cat-pill {
  --cat-color: var(--rec-teal);
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-ui);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  font-weight: 600;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.18);
  background: rgba(255,255,255,0.04);
  color: rgba(255,255,255,0.7);
  cursor: default;
  transition:
    background var(--motion-fast) var(--easing),
    color var(--motion-fast) var(--easing),
    border-color var(--motion-fast) var(--easing),
    transform var(--motion-fast) var(--easing);
}
.cat-pill--md { font-size: 0.72rem; padding: 8px 16px; }
.cat-pill--sm { font-size: 0.62rem; padding: 4px 10px; letter-spacing: 0.12em; }

button.cat-pill { cursor: pointer; }

.cat-pill-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--cat-color);
  box-shadow: 0 0 0 0 var(--cat-color);
  transition: box-shadow var(--motion-fast) var(--easing);
}
.cat-pill--sm .cat-pill-dot { width: 5px; height: 5px; }

.cat-pill:hover {
  color: #fff;
  border-color: var(--cat-color);
  background: rgba(255,255,255,0.06);
}
.cat-pill:hover .cat-pill-dot {
  box-shadow: 0 0 0 4px rgba(255,255,255,0.06);
}

.cat-pill.is-active {
  background: var(--cat-color);
  color: #fff;
  border-color: var(--cat-color);
}
.cat-pill.is-active .cat-pill-dot {
  background: #fff;
  box-shadow: 0 0 0 4px rgba(255,255,255,0.18);
}

/* Variante clara — quando aparece sobre fundo branco */
.cat-pill--on-light {
  border-color: rgba(1,38,89,0.12);
  background: rgba(1,38,89,0.03);
  color: rgba(1,38,89,0.65);
}
.cat-pill--on-light:hover {
  color: var(--cat-color);
  border-color: var(--cat-color);
  background: rgba(255,255,255,0.6);
}
</style>
