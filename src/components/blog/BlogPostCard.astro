---
import IllustrativeImg from '../ui/IllustrativeImg.astro'
import PillarChip from './PillarChip.astro'

interface Props {
  slug: string
  title: string
  excerpt: string
  pillar: 'negocios' | 'estrategia' | 'comunidade' | 'eventos' | 'mentalidade' | 'empreendedorismo'
  publishedAt: Date
  cover?: string
  coverAlt?: string
}
const { slug, title, excerpt, pillar, publishedAt, cover, coverAlt = '' } = Astro.props
const dateStr = publishedAt.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' }).replace('.', '')
---
<article class="post-card" data-pillar={pillar}>
  <a href={`/blog/${slug}`} class="card-link">
    {cover && <div class="card-cover"><IllustrativeImg src={cover} alt={coverAlt} ratio="16/9" mood="warm" /></div>}
    <div class="card-body">
      <div class="card-meta">
        <PillarChip pillar={pillar} />
        <time datetime={publishedAt.toISOString()}>{dateStr}</time>
      </div>
      <h3>{title}</h3>
      <p>{excerpt}</p>
      <span class="card-cta">LER →</span>
    </div>
  </a>
</article>

<style>
.post-card { padding: var(--space-6) 0; border-bottom: 1px solid rgba(37,52,57,0.08); }
.post-card[hidden] { display: none; }
.card-link { display: grid; grid-template-columns: 240px 1fr; gap: var(--space-6); align-items: start; }
.card-cover { width: 100%; }
.card-meta { display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-3); }
.card-meta time { font-size: var(--type-micro); color: #667; letter-spacing: 0.1em; text-transform: lowercase; }
.card-body h3 { font-size: 1.25rem; line-height: 1.25; color: var(--rec-dark); margin-bottom: var(--space-3); transition: color var(--motion-fast) var(--easing); }
.post-card:hover .card-body h3 { color: var(--rec-purple); }
.card-body p { font-size: var(--type-small); color: #556; line-height: 1.6; margin-bottom: var(--space-3); max-width: 560px; }
.card-cta { display: inline-block; font-size: var(--type-micro); font-weight: 700; letter-spacing: 0.12em; color: var(--rec-purple); }
@media (max-width: 640px) { .card-link { grid-template-columns: 1fr; } }
</style>
