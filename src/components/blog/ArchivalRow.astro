---
import { getCategoryInfo, readingTime, type Pillar } from '../../utils/blog-category'

interface Props {
  slug: string
  title: string
  excerpt: string
  pillar: Pillar
  publishedAt: Date
  cover?: string
  coverAlt?: string
  body?: string
  number: number
  index?: number
}

const {
  slug, title, excerpt, pillar, publishedAt,
  cover, coverAlt = '', body = '', number, index = 0,
} = Astro.props

const cat     = getCategoryInfo(pillar)
const minutes = body ? readingTime(body) : 4
const numStr  = String(number).padStart(2, '0')
const dateStr = publishedAt.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' }).replace('.', '')
---

<!--
  Wrapper: o hover acontece aqui, propagando pro
  row E pro expand ao mesmo tempo.
-->
<div
  class="archival-item-wrap"
  style={`--cat-color: ${cat.color}; --reveal-delay: ${index * 60}ms;`}
  data-reveal
>
  <!-- ── Linha principal ── -->
  <a
    href={`/blog/${slug}`}
    class="archival-row"
    data-category={cat.slug}
    aria-label={title}
  >
    <span class="archival-row-number">Nº {numStr}</span>
    <h3 class="archival-row-title">{title}</h3>
    <span class="archival-row-cat">{cat.label}</span>
    <span class="archival-row-arrow" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
           stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
      </svg>
    </span>
  </a>

  <!-- ── Painel que expande abaixo no hover ── -->
  <div class="archival-expand" aria-hidden="true">
    <div class="archival-expand-overflow">
      <div class="archival-expand-inner">

        <!-- Esquerda: data + tempo + excerpt -->
        <div class="archival-expand-text">
          <div class="archival-expand-meta">
            <time datetime={publishedAt.toISOString()}>{dateStr}</time>
            <span class="archival-expand-sep" aria-hidden="true">·</span>
            <span>{minutes} min de leitura</span>
          </div>
          <p class="archival-expand-excerpt">{excerpt}</p>
          <span class="archival-expand-cta">
            ler artigo
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </span>
        </div>

        <!-- Direita: imagem ou placeholder -->
        <div class="archival-expand-media">
          {cover ? (
            <img src={cover} alt={coverAlt} loading="lazy" decoding="async" />
          ) : (
            <div class="archival-expand-placeholder">
              <span class="archival-expand-watermark">{cat.label}</span>
            </div>
          )}
        </div>

      </div>
    </div>
  </div>
</div>

<style>
/* ============================================
   WRAPPER — o hover dispara tudo
   ============================================ */
.archival-item-wrap {
  --cat-color: var(--rec-teal);
  border-bottom: 1px solid rgba(1,38,89,0.10);
  opacity: 0;
  transform: translateY(16px);
  transition:
    background 280ms cubic-bezier(0.22, 1, 0.36, 1);
}
.archival-item-wrap[data-revealed='true'] {
  opacity: 1;
  transform: translateY(0);
  transition:
    opacity 600ms cubic-bezier(0.22, 1, 0.36, 1) var(--reveal-delay, 0ms),
    transform 600ms cubic-bezier(0.22, 1, 0.36, 1) var(--reveal-delay, 0ms),
    background 280ms cubic-bezier(0.22, 1, 0.36, 1);
}
.archival-item-wrap:hover {
  background: rgba(0,161,152,0.035);
}

/* ============================================
   LINHA PRINCIPAL
   Layout: [Nº] [Título] [Categoria] [→]
   ============================================ */
.archival-row {
  display: grid;
  grid-template-columns: 60px 1fr auto 32px;
  align-items: center;
  gap: 0 var(--space-7);
  padding: var(--space-6) var(--space-4);
  text-decoration: none;
  color: var(--rec-blue);
  transition: padding 280ms cubic-bezier(0.22, 1, 0.36, 1);
}
.archival-item-wrap:hover .archival-row {
  padding-left: var(--space-6);
  padding-right: var(--space-5);
}

/* Número */
.archival-row-number {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 400;
  letter-spacing: -0.01em;
  color: rgba(1,38,89,0.3);
  font-feature-settings: 'tnum';
  white-space: nowrap;
  transition: color 280ms var(--easing);
}
.archival-item-wrap:hover .archival-row-number {
  color: var(--cat-color);
}

/* Título — recebe 1fr, sem clamp precoce */
.archival-row-title {
  font-family: var(--font-display);
  font-size: clamp(1.2rem, 1.8vw, 1.65rem);
  font-weight: 400;
  line-height: 1.2;
  letter-spacing: -0.015em;
  color: var(--rec-blue);
  margin: 0;
  /* Permite até 2 linhas — mas título curto ocupa 1 só */
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  transition: color 280ms var(--easing);
}
.archival-item-wrap:hover .archival-row-title {
  color: rgba(1,38,89,0.9);
}

/* Categoria */
.archival-row-cat {
  font-family: var(--font-ui);
  font-size: 0.62rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  font-weight: 700;
  color: var(--cat-color);
  white-space: nowrap;
  text-align: right;
  opacity: 0.7;
  transition: opacity 280ms var(--easing);
}
.archival-item-wrap:hover .archival-row-cat {
  opacity: 1;
}

/* Seta */
.archival-row-arrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: rgba(1,38,89,0.25);
  transition: transform 280ms var(--easing), color 280ms var(--easing);
}
.archival-row-arrow svg { width: 20px; height: 20px; }
.archival-item-wrap:hover .archival-row-arrow {
  color: var(--cat-color);
  transform: translateX(5px);
}

/* ============================================
   PAINEL EXPAND — abre abaixo no hover
   Técnica: grid-template-rows 0fr → 1fr
   (sem height fixo, transição suave)
   ============================================ */
.archival-expand {
  display: grid;
  grid-template-rows: 0fr;
  opacity: 0;
  transition:
    grid-template-rows 400ms cubic-bezier(0.22, 1, 0.36, 1),
    opacity 350ms cubic-bezier(0.22, 1, 0.36, 1);
}
.archival-item-wrap:hover .archival-expand {
  grid-template-rows: 1fr;
  opacity: 1;
}

.archival-expand-overflow {
  overflow: hidden;
}

/* Inner: indent alinhado com o título (pula a coluna do Nº) */
.archival-expand-inner {
  display: flex;
  gap: var(--space-6);
  align-items: flex-start;
  padding: var(--space-2) var(--space-5) var(--space-6) calc(60px + var(--space-7) + var(--space-4));
}

/* Esquerda: meta + excerpt + cta */
.archival-expand-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.archival-expand-meta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-ui);
  font-size: 0.68rem;
  letter-spacing: 0.1em;
  color: rgba(1,38,89,0.5);
  text-transform: lowercase;
}
.archival-expand-sep { opacity: 0.5; }

.archival-expand-excerpt {
  font-family: var(--font-body);
  font-size: 0.95rem;
  line-height: 1.6;
  color: rgba(1,38,89,0.72);
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.archival-expand-cta {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-ui);
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--cat-color);
  margin-top: var(--space-2);
  transition: gap 200ms var(--easing);
}
.archival-item-wrap:hover .archival-expand-cta {
  gap: 9px;
}

/* Direita: imagem */
.archival-expand-media {
  flex-shrink: 0;
  width: 220px;
  aspect-ratio: 16/10;
  border-radius: 10px;
  overflow: hidden;
  background: var(--rec-navy);
}
.archival-expand-media img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}
.archival-expand-placeholder {
  width: 100%; height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.archival-expand-placeholder::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 3px;
  background: var(--cat-color);
}
.archival-expand-watermark {
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  text-transform: uppercase;
  color: var(--cat-color);
  opacity: 0.35;
}

/* ============================================
   RESPONSIVO TABLET (≤ 900px)
   ============================================ */
@media (max-width: 900px) {
  .archival-row {
    grid-template-columns: 44px 1fr 24px;
    gap: 0 var(--space-3);
    padding: var(--space-5) var(--space-3);
  }
  .archival-row-cat { display: none; }
  .archival-row-number { font-size: 0.82rem; }
  .archival-row-title  { font-size: 1.1rem; }
  .archival-expand-inner {
    flex-direction: column;
    padding-left: calc(44px + var(--space-3) + var(--space-2));
  }
  .archival-expand-media { width: 100%; }
}

/* ============================================
   RESPONSIVO MOBILE (≤ 700px)
   ============================================ */
@media (max-width: 700px) {
  .archival-row {
    grid-template-columns: 1fr 24px;
    gap: 0 var(--space-3);
  }
  .archival-row-number { display: none; }
  .archival-expand-inner { padding-left: var(--space-3); }
}

@media (prefers-reduced-motion: reduce) {
  .archival-item-wrap { opacity: 1; transform: none; }
  .archival-expand {
    transition: none;
    grid-template-rows: 0fr;
  }
  .archival-item-wrap:hover .archival-expand { grid-template-rows: 1fr; }
}
</style>
