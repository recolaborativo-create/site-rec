---
// Banner de newsletter — visual por enquanto, sem backend
---

<section class="news-banner" data-reveal>
  <div class="news-banner-bg" aria-hidden="true"></div>
  <div class="news-banner-noise" aria-hidden="true"></div>

  <div class="news-banner-inner">
    <span class="news-eyebrow">curadoria semanal</span>
    <h2 class="news-title">
      Receba conteúdo <em>estratégico</em><br/>
      direto no seu e-mail.
    </h2>
    <p class="news-lead">
      Uma seleção curta de artigos, estudos e provocações sobre negócios,
      networking e crescimento — toda semana, sem ruído.
    </p>

    <form class="news-form" novalidate>
      <label class="visually-hidden" for="news-email">Seu e-mail</label>
      <input
        id="news-email"
        type="email"
        placeholder="seu@email.com"
        autocomplete="email"
        required
      />
      {/* Honeypot: invisível ao usuário, bots preenchem e são silenciados. */}
      <input
        type="text"
        name="website"
        class="hp-field"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
      />
      <button type="submit" class="news-submit">
        assinar
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </button>
    </form>

    <span class="news-disclaimer">sem spam · cancele quando quiser</span>
    <span class="news-status" aria-live="polite"></span>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>('.news-form')
  const statusEl = document.querySelector<HTMLElement>('.news-status')

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const input = form.querySelector<HTMLInputElement>('#news-email')
      const btn   = form.querySelector<HTMLButtonElement>('.news-submit')
      if (!input || !input.value.trim()) return

      // Estado: enviando
      if (btn) { btn.disabled = true; btn.textContent = 'enviando…' }
      if (input) input.disabled = true

      const hp = form.querySelector<HTMLInputElement>('input[name="website"]')

      try {
        const res  = await fetch('/api/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: input.value.trim(),
            website: hp?.value ?? '',
          }),
        })
        const data = await res.json().catch(() => ({}))

        if (res.ok) {
          // Sucesso
          form.classList.add('is-success')
          if (btn) { btn.textContent = '✓ inscrito!' }
          if (statusEl) {
            statusEl.textContent = 'Boa! Você receberá os próximos artigos por e-mail.'
            statusEl.className = 'news-status news-status--ok'
          }
        } else {
          // Erro vindo do backend
          if (btn) { btn.disabled = false; btn.innerHTML = 'assinar <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>' }
          if (input) input.disabled = false
          if (statusEl) {
            statusEl.textContent = data?.error ?? 'Algo deu errado. Tente de novo.'
            statusEl.className = 'news-status news-status--err'
          }
        }
      } catch {
        // Erro de rede
        if (btn) { btn.disabled = false; btn.textContent = 'assinar' }
        if (input) input.disabled = false
        if (statusEl) {
          statusEl.textContent = 'Erro de conexão. Verifique sua internet.'
          statusEl.className = 'news-status news-status--err'
        }
      }
    })
  }
</script>

<style>
/* Honeypot field: visualmente removido mas acessível pra bots crawlers */
.hp-field {
  position: absolute !important;
  left: -9999px !important;
  width: 1px;
  height: 1px;
  opacity: 0;
  pointer-events: none;
  tab-size: 0;
}
.news-banner {
  position: relative;
  overflow: hidden;
  padding: var(--space-20) var(--space-6);
  margin: var(--space-12) auto 0;
  max-width: var(--container-max);
  border-radius: 28px;
}
.news-banner-bg {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, var(--rec-teal) 0%, #007e7a 35%, var(--rec-blue) 100%);
}
.news-banner-noise {
  position: absolute; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 200px 200px;
  opacity: 0.08;
  mix-blend-mode: overlay;
}

.news-banner-inner {
  position: relative;
  z-index: 2;
  max-width: 640px;
  margin: 0 auto;
  text-align: center;
  color: #fff;
}

.news-eyebrow {
  display: inline-block;
  font-family: var(--font-ui);
  font-size: 0.7rem;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  font-weight: 700;
  color: rgba(255,255,255,0.85);
  margin-bottom: var(--space-4);
  padding: 6px 14px;
  border: 1px solid rgba(255,255,255,0.25);
  border-radius: 999px;
}

.news-title {
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  line-height: 1.1;
  font-weight: 300;
  letter-spacing: -0.02em;
  color: #fff;
  margin: 0 0 var(--space-4);
}
.news-title em {
  font-style: italic;
  font-weight: 400;
  color: rgba(255,255,255,0.92);
  background: linear-gradient(180deg, transparent 60%, rgba(255,255,255,0.18) 60%);
  padding: 0 4px;
}

.news-lead {
  color: rgba(255,255,255,0.82);
  font-size: 1.02rem;
  line-height: 1.65;
  margin: 0 auto var(--space-8);
  max-width: 480px;
}

.news-form {
  display: flex;
  align-items: stretch;
  gap: 8px;
  max-width: 480px;
  margin: 0 auto var(--space-4);
  background: rgba(255,255,255,0.1);
  padding: 6px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.16);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  transition: border-color 220ms var(--easing), background 220ms var(--easing);
}
.news-form:focus-within {
  border-color: rgba(255,255,255,0.42);
  background: rgba(255,255,255,0.14);
}
.news-form.is-success {
  border-color: rgba(255,255,255,0.5);
}

.news-form input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  padding: 12px 18px;
  font-family: var(--font-body);
  font-size: 0.98rem;
  color: #fff;
}
.news-form input::placeholder {
  color: rgba(255,255,255,0.55);
}

.news-submit {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 22px;
  background: #fff;
  color: var(--rec-blue);
  border: none;
  border-radius: 999px;
  font-family: var(--font-ui);
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: lowercase;
  cursor: pointer;
  transition:
    background 220ms var(--easing),
    color 220ms var(--easing),
    transform 220ms var(--easing);
}
.news-submit svg { width: 16px; height: 16px; transition: transform 220ms var(--easing); }
.news-submit:hover {
  background: var(--rec-navy);
  color: #fff;
}
.news-submit:hover svg { transform: translateX(2px); }
.news-submit:disabled { opacity: 0.7; cursor: default; }

.news-disclaimer {
  display: block;
  font-family: var(--font-ui);
  font-size: 0.7rem;
  letter-spacing: 0.06em;
  color: rgba(255,255,255,0.55);
}

.news-status {
  display: block;
  min-height: 1.2em;
  font-family: var(--font-ui);
  font-size: 0.82rem;
  font-weight: 600;
  margin-top: var(--space-3);
  transition: opacity 300ms var(--easing);
}
.news-status:empty { opacity: 0; }
.news-status--ok  { color: rgba(255,255,255,0.95); }
.news-status--err { color: rgba(255,200,180,0.95); }

.visually-hidden {
  position: absolute; width: 1px; height: 1px;
  padding: 0; margin: -1px; overflow: hidden;
  clip: rect(0,0,0,0); white-space: nowrap; border: 0;
}

@media (max-width: 600px) {
  .news-banner { border-radius: 20px; margin: var(--space-8) var(--space-3) 0; padding: var(--space-12) var(--space-5); }
  .news-form { flex-direction: column; padding: 8px; border-radius: 18px; }
  .news-form input { padding: 14px 16px; text-align: center; }
  .news-submit { justify-content: center; padding: 14px 22px; }
}
</style>
