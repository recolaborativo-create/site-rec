---
interface Props {
  icon: string
}
const { icon } = Astro.props
---
<span class="sol-icon" aria-hidden="true">
  {icon === 'globe' && (
    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="24" cy="24" r="18" />
      <ellipse cx="24" cy="24" rx="8" ry="18" />
      <line x1="6" y1="24" x2="42" y2="24" />
      <path d="M9 13 Q24 19 39 13" />
      <path d="M9 35 Q24 29 39 35" />
    </svg>
  )}
  {icon === 'target' && (
    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="24" cy="24" r="18" />
      <circle cx="24" cy="24" r="12" />
      <circle cx="24" cy="24" r="6" />
      <circle cx="24" cy="24" r="1.5" fill="currentColor" />
      <line x1="24" y1="4" x2="24" y2="10" />
      <line x1="24" y1="38" x2="24" y2="44" />
      <line x1="4" y1="24" x2="10" y2="24" />
      <line x1="38" y1="24" x2="44" y2="24" />
    </svg>
  )}
  {icon === 'chart' && (
    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="6" y1="42" x2="42" y2="42" />
      <rect x="10" y="28" width="6" height="14" />
      <rect x="21" y="20" width="6" height="22" />
      <rect x="32" y="12" width="6" height="30" />
      <polyline points="10,24 21,16 32,8 38,6" />
      <polyline points="34,6 38,6 38,10" />
    </svg>
  )}
  {icon === 'play' && (
    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="6" y="10" width="36" height="28" rx="3" />
      <polygon points="20,18 32,24 20,30" fill="currentColor" stroke="none" />
      <line x1="6" y1="16" x2="42" y2="16" />
      <circle cx="10" cy="13" r="0.8" fill="currentColor" />
      <circle cx="13" cy="13" r="0.8" fill="currentColor" />
      <circle cx="16" cy="13" r="0.8" fill="currentColor" />
    </svg>
  )}
  {icon === 'megaphone' && (
    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 19 L6 29 L14 29 L34 38 L34 10 L14 19 Z" />
      <path d="M14 19 L14 29" />
      <path d="M38 17 Q42 24 38 31" />
      <path d="M14 29 L17 38 L21 38 L19 29" />
    </svg>
  )}
  {icon === 'trend' && (
    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6,36 16,26 24,32 38,12" />
      <polyline points="30,12 38,12 38,20" />
      <line x1="6" y1="42" x2="42" y2="42" />
      <circle cx="16" cy="26" r="1.5" fill="currentColor" />
      <circle cx="24" cy="32" r="1.5" fill="currentColor" />
    </svg>
  )}
  {icon === 'heart' && (
    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M24 40 C 6 27, 6 12, 16 12 C 20 12, 24 16, 24 18 C 24 16, 28 12, 32 12 C 42 12, 42 27, 24 40 Z" />
      <polyline points="10,24 16,24 19,20 23,28 26,24 38,24" />
    </svg>
  )}
  {icon === 'cap' && (
    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="24,10 44,18 24,26 4,18" />
      <path d="M12 22 L12 32 Q24 38 36 32 L36 22" />
      <line x1="42" y1="19" x2="42" y2="30" />
      <circle cx="42" cy="32" r="1.5" fill="currentColor" />
    </svg>
  )}
  {icon === 'chat' && (
    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M8 10 L36 10 Q40 10 40 14 L40 28 Q40 32 36 32 L20 32 L12 40 L12 32 Q8 32 8 28 Z" />
      <circle cx="18" cy="21" r="1.5" fill="currentColor" />
      <circle cx="24" cy="21" r="1.5" fill="currentColor" />
      <circle cx="30" cy="21" r="1.5" fill="currentColor" />
    </svg>
  )}
</span>

<style>
.sol-icon { display: inline-flex; }
.sol-icon svg { width: 100%; height: 100%; }
</style>
