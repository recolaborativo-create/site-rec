---
import IllustrativeImg from '../ui/IllustrativeImg.astro'
interface Props {
  number: string
  headline: string
  body: string
  image?: string
  imageAlt?: string
  mood?: 'warm' | 'cool' | 'neutral'
}
const { number, headline, body, image, imageAlt = '', mood = 'warm' } = Astro.props
---
<article class="hub-chapter" data-reveal>
  <div class="chapter-icon">{number}</div>
  <div class="chapter-text">
    <h3>{headline}</h3>
    <p>{body}</p>
  </div>
  {image && (
    <div class="chapter-image">
      <IllustrativeImg src={image} alt={imageAlt} ratio="16/9" mood={mood} />
    </div>
  )}
</article>

<style>
.hub-chapter { display: grid; grid-template-columns: 64px 1fr; gap: var(--space-6); padding: var(--space-8) 0; border-bottom: 1px solid rgba(37,52,57,0.06); opacity: 0; transform: translateY(20px); transition: opacity var(--motion-medium) var(--easing), transform var(--motion-medium) var(--easing); }
.hub-chapter.in-view { opacity: 1; transform: translateY(0); }
.hub-chapter:last-child { border-bottom: none; }
.chapter-icon { width: 56px; height: 56px; border-radius: 14px; background: linear-gradient(135deg, var(--rec-purple) 0%, var(--rec-teal) 100%); display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 800; font-size: var(--type-body); flex-shrink: 0; }
.chapter-text h3 { font-size: clamp(1.2rem, 2.5vw, 1.6rem); color: var(--rec-dark); margin-bottom: var(--space-3); line-height: 1.2; }
.chapter-text p { font-size: var(--type-body); color: #556; line-height: 1.65; max-width: 520px; }
.chapter-image { grid-column: 2; margin-top: var(--space-4); }
@media (max-width: 600px) { .hub-chapter { grid-template-columns: 1fr; gap: var(--space-3); } .chapter-image { grid-column: 1; } }
</style>
