---
import { instagramFeed } from '../../data/instagram-feed'
import { externalLinks } from '../../data/nav'

interface Props {
  heading?: string
  subheading?: string
}
const {
  heading = 'O movimento em tempo real.',
  subheading = 'Os bastidores, os encontros e as histórias. Desliza pra ver os últimos posts.',
} = Astro.props

const beholdFeedId = import.meta.env.PUBLIC_BEHOLD_FEED_ID || ''

function staticImg(id: string): string {
  return `/instagram/${id}.jpg`
}
---
<section class="ig-section" data-reveal data-behold-feed={beholdFeedId}>
  <div class="ig-section-inner">
    <header class="ig-header">
      <span class="ig-eyebrow">
        <svg class="ig-eyebrow-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        instagram
      </span>
      <h2 class="ig-title">@somosrecoficial</h2>
      <p class="ig-sub">{subheading}</p>
    </header>

    <div class="ig-frame">
      <div class="ig-track" data-ig-track>
        {instagramFeed.map(post => (
          <a
            href={post.url}
            target="_blank"
            rel="noopener"
            class:list={['ig-post', `ratio-${(post.ratio || '4/5').replace('/', '-')}`]}
            aria-label={`post no instagram do REC`}
          >
            <div class="ig-image">
              <img src={staticImg(post.id)} alt="" loading="lazy" onerror="this.classList.add('missing')" />
              <div class="ig-fallback" aria-hidden="true">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                  <rect x="3" y="3" width="18" height="18" rx="5" ry="5"/>
                  <circle cx="12" cy="12" r="4"/>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              </div>
              <div class="ig-overlay" aria-hidden="true">
                <span class="ig-overlay-icon">↗</span>
              </div>
            </div>
            <span class="ig-rec-mark" aria-hidden="true">
              <i></i><i></i><i></i>
            </span>
          </a>
        ))}
      </div>
      <button class="ig-nav prev" data-ig-prev aria-label="anterior">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="ig-nav next" data-ig-next aria-label="próximo">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>

    <div class="ig-cta-wrap">
      <a href={externalLinks.instagram.url} target="_blank" rel="noopener" class="ig-follow-cta">
        seguir <strong>@somosrecoficial</strong>
        <span class="ig-cta-arrow">→</span>
      </a>
    </div>
  </div>
</section>

<script>
  type BeholdPost = {
    id: string
    permalink: string
    mediaType: 'IMAGE' | 'VIDEO' | 'CAROUSEL_ALBUM'
    mediaUrl: string
    sizes?: { medium?: { mediaUrl?: string } }
    caption?: string
    timestamp?: string
  }

  const root = document.querySelector<HTMLElement>('.ig-section')
  const track = document.querySelector<HTMLElement>('[data-ig-track]')
  const prev = document.querySelector<HTMLButtonElement>('[data-ig-prev]')
  const next = document.querySelector<HTMLButtonElement>('[data-ig-next]')
  const feedId = root?.dataset.beholdFeed || ''

  type BeholdSize = { mediaUrl?: string; width?: number; height?: number }

  function pickAspect(post: BeholdPost): string {
    const sz = (post.sizes as Record<string, BeholdSize> | undefined)
    const s = sz?.medium || sz?.large || sz?.full || sz?.small
    if (s?.width && s?.height) return `${s.width} / ${s.height}`
    return post.mediaType === 'VIDEO' ? '9 / 16' : '4 / 5'
  }

  // Build a card element for a Behold post (no captions, just visual).
  // We clone the first server-rendered .ig-post so scoped CSS (Astro
  // data-astro-cid) carries over to the dynamic cards.
  function buildCard(post: BeholdPost, template: HTMLAnchorElement): HTMLAnchorElement {
    const a = template.cloneNode(true) as HTMLAnchorElement
    a.href = post.permalink
    a.setAttribute('aria-label', 'post no instagram do REC')
    a.className = template.className.replace(/\bratio-\S+/g, '').trim() + ' is-behold'
    if (post.mediaType === 'VIDEO') a.classList.add('is-video')

    const wrap = a.querySelector('.ig-image') as HTMLElement
    if (wrap) {
      // Clear template media; we'll inject the real one
      wrap.querySelectorAll('img, video, .ig-type-badge').forEach(el => el.remove())

      if (post.mediaType === 'VIDEO') {
        // Card stays at 4:5 (same as photos); video is drawn entirely inside
        // via object-fit: contain. Inline styles bypass any Astro CSS
        // scoping issue with elements created at runtime.
        wrap.style.aspectRatio = '4 / 5'
        wrap.style.background = '#000'
        const vid = document.createElement('video')
        vid.src = post.mediaUrl
        vid.muted = true
        vid.loop = true
        vid.playsInline = true
        vid.autoplay = true
        vid.preload = 'metadata'
        vid.style.width = '100%'
        vid.style.height = '100%'
        vid.style.objectFit = 'contain'
        vid.style.display = 'block'
        wrap.prepend(vid)
      } else {
        // Photos: set wrap aspect from the post's actual thumbnail size so
        // the moldura matches whatever ratio Instagram delivered.
        wrap.style.aspectRatio = pickAspect(post)
        const img = document.createElement('img')
        img.src = (post.sizes?.medium?.mediaUrl) || post.mediaUrl
        img.alt = ''
        img.loading = 'lazy'
        img.decoding = 'async'
        wrap.prepend(img)
      }

      if (post.mediaType === 'VIDEO' || post.mediaType === 'CAROUSEL_ALBUM') {
        const badge = document.createElement('span')
        badge.className = 'ig-type-badge'
        badge.setAttribute('aria-hidden', 'true')
        badge.innerHTML = post.mediaType === 'VIDEO'
          ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>'
          : '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="7" y="7" width="14" height="14" rx="2"/><path d="M3 17V5a2 2 0 0 1 2-2h12"/></svg>'
        wrap.appendChild(badge)
      }
    }
    return a
  }

  async function loadBeholdFeed(id: string) {
    try {
      const res = await fetch(`https://feeds.behold.so/${id}`, { mode: 'cors' })
      if (!res.ok) throw new Error('feed fetch failed')
      const data = await res.json() as { posts?: BeholdPost[] }
      const posts = (data.posts || []).slice(0, 8)
      if (posts.length === 0) return
      const template = track?.querySelector<HTMLAnchorElement>('.ig-post')
      if (track && template) {
        track.replaceChildren(...posts.map(p => buildCard(p, template)))
      }
    } catch {
      // Network or CORS failure — keep the static seed posts visible
    }
  }

  if (feedId) {
    loadBeholdFeed(feedId)
  }

  if (track && prev && next) {
    const step = () => {
      const card = track.querySelector<HTMLElement>('.ig-post')
      if (!card) return 320
      const rect = card.getBoundingClientRect()
      const styles = getComputedStyle(track)
      const gap = parseFloat(styles.gap || '16')
      return rect.width + gap
    }
    prev.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }))
    next.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }))
  }
</script>

<style>
.ig-section {
  padding: var(--space-16) var(--space-6) var(--space-12);
  background: linear-gradient(180deg, #fff 0%, rgba(0,161,152,0.03) 50%, #fff 100%);
  opacity: 0;
  transform: translateY(20px);
  transition: opacity var(--motion-slow) var(--easing), transform var(--motion-slow) var(--easing);
}
.ig-section.in-view { opacity: 1; transform: translateY(0); }
.ig-section-inner { max-width: var(--container-max); margin: 0 auto; }

/* ============ HEADER ============ */
.ig-header { text-align: center; margin-bottom: var(--space-10); }
.ig-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 14px;
  border-radius: 999px;
  background: linear-gradient(135deg, rgba(0,161,152,0.1), rgba(108,90,178,0.1));
  border: 1px solid rgba(0,161,152,0.2);
  color: var(--rec-teal);
  font-size: var(--type-micro);
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  margin-bottom: var(--space-4);
}
.ig-eyebrow-icon { color: var(--rec-teal); }
.ig-title {
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 800;
  letter-spacing: var(--letter-tight);
  background: linear-gradient(135deg, var(--rec-teal) 0%, var(--rec-purple) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  margin: 0 0 var(--space-3);
  line-height: 1.1;
}
.ig-sub {
  max-width: 540px;
  margin: 0 auto;
  color: #556;
  line-height: 1.65;
  font-size: var(--type-body);
}

/* ============ OUTER FRAME (just spacing — each post has its own moldura) ============ */
.ig-frame {
  position: relative;
  padding: var(--space-3) var(--space-4);
  background: transparent;
  overflow: visible;
}

.ig-track {
  display: flex;
  gap: var(--space-4);
  align-items: flex-start;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-padding-inline: var(--space-2);
  padding: var(--space-2);
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.ig-track::-webkit-scrollbar { display: none; }

/* Per-post REC moldura: gradient border that adapts to whatever ratio the post has */
.ig-post {
  flex: 0 0 calc((100% - 3 * var(--space-4)) / 4);
  min-width: 0;
  scroll-snap-align: start;
  display: block;
  border-radius: 14px;
  position: relative;
  isolation: isolate;
  background: #fff;
  padding: 3px;
  transition: transform var(--motion-fast) var(--easing), box-shadow var(--motion-fast) var(--easing), filter var(--motion-fast) var(--easing);
}
/* Gradient border (REC brand) drawn via mask — molds to whatever size the post is */
.ig-post::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 14px;
  padding: 2px;
  background: linear-gradient(135deg, var(--rec-blue) 0%, var(--rec-teal) 50%, var(--rec-blue) 100%);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
          mask-composite: exclude;
  pointer-events: none;
  z-index: 2;
}
.ig-post:hover { transform: translateY(-3px); box-shadow: 0 10px 22px rgba(1,38,89,0.18); }

/* Tiny REC mark (3 bars) in the top-right corner of each post */
.ig-rec-mark {
  position: absolute;
  top: 8px;
  right: 8px;
  z-index: 3;
  display: flex;
  flex-direction: column;
  gap: 2px;
  align-items: flex-end;
  padding: 4px 6px;
  border-radius: 6px;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(6px);
  pointer-events: none;
}
.ig-rec-mark i { display: block; height: 3px; border-radius: 999px; }
.ig-rec-mark i:nth-child(1) { width: 18px; background: var(--rec-blue); }
.ig-rec-mark i:nth-child(2) { width: 13px; background: var(--rec-teal); }
.ig-rec-mark i:nth-child(3) { width: 7px;  background: var(--rec-blue); }

/* Aspect ratio variants — moldura adapts because it follows the post's box size */
.ig-image {
  position: relative;
  width: 100%;
  overflow: hidden;
  border-radius: 11px;
  background: linear-gradient(135deg, #00a198 0%, #3e4095 100%);
}
.ig-post.ratio-4-5 .ig-image { aspect-ratio: 4/5; }
.ig-post.ratio-1-1 .ig-image { aspect-ratio: 1/1; }
.ig-post.ratio-3-4 .ig-image { aspect-ratio: 3/4; }
.ig-post.ratio-9-16 .ig-image { aspect-ratio: 9/16; }
/* Videos: card mantém o mesmo tamanho/aspecto das fotos (4:5), mas o vídeo
   é desenhado por inteiro dentro (object-fit: contain) com fundo preto nas
   laterais — preserva o conteúdo do reel sem crop. */
.ig-post.is-video .ig-image {
  aspect-ratio: 4 / 5;
  background: #000;
}
.ig-post.is-video .ig-image video {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.ig-image img,
.ig-image video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  transition: transform var(--motion-medium) var(--easing);
}
.ig-image img.missing { opacity: 0; }
.ig-image img.missing + .ig-fallback { opacity: 1; }
.ig-fallback {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.55);
  background: linear-gradient(135deg, #00a198 0%, #006d68 50%, #3e4095 100%);
  opacity: 0;
  transition: opacity var(--motion-fast) var(--easing);
}
.ig-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.4) 0%, transparent 50%);
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
  padding: var(--space-3);
  opacity: 0;
  transition: opacity var(--motion-fast) var(--easing);
}
.ig-post:hover .ig-overlay { opacity: 1; }
.ig-post:hover .ig-image img,
.ig-post:hover .ig-image video { transform: scale(1.04); }
.ig-overlay-icon { color: #fff; font-size: 1.4rem; font-weight: 300; }

.ig-type-badge {
  position: absolute;
  top: var(--space-3);
  right: var(--space-3);
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: rgba(0,0,0,0.55);
  backdrop-filter: blur(6px);
  color: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

/* ============ NAV ARROWS (overlaid on frame) ============ */
.ig-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: #fff;
  border: 1px solid rgba(37,52,57,0.1);
  color: var(--rec-purple);
  cursor: pointer;
  transition: all var(--motion-fast) var(--easing);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
  box-shadow: 0 4px 12px rgba(37,52,57,0.1);
}
.ig-nav.prev { left: -8px; }
.ig-nav.next { right: -8px; }
.ig-nav:hover { background: var(--rec-teal); color: #fff; border-color: var(--rec-teal); transform: translateY(-50%) scale(1.08); }

/* ============ CTA ============ */
.ig-cta-wrap { text-align: center; margin-top: var(--space-8); }
.ig-follow-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 28px;
  border-radius: 999px;
  background: transparent;
  border: 1.5px solid var(--rec-teal);
  color: var(--rec-teal);
  font-weight: 700;
  font-size: var(--type-small);
  letter-spacing: 0.05em;
  transition: all var(--motion-fast) var(--easing);
}
.ig-follow-cta:hover {
  background: var(--rec-teal);
  color: #fff;
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0,161,152,0.25);
}
.ig-follow-cta strong { font-weight: 800; }
.ig-cta-arrow { transition: transform var(--motion-fast) var(--easing); }
.ig-follow-cta:hover .ig-cta-arrow { transform: translateX(4px); }

@media (max-width: 900px) {
  /* 3 cards visible on tablet */
  .ig-post { flex-basis: calc((100% - 2 * var(--space-4)) / 3); }
}
@media (max-width: 600px) {
  .ig-section { padding: var(--space-12) var(--space-4) var(--space-8); }
  .ig-frame { padding: var(--space-2); }
  .ig-nav { width: 38px; height: 38px; }
  .ig-nav.prev { left: -4px; }
  .ig-nav.next { right: -4px; }
  /* ~1.7 cards visible on mobile so the next one peeks */
  .ig-post { flex-basis: 60vw; }
  .ig-rec-mark i:nth-child(1) { width: 14px; }
  .ig-rec-mark i:nth-child(2) { width: 10px; }
  .ig-rec-mark i:nth-child(3) { width: 6px; }
}
</style>
