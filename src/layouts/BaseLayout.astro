---
import '../styles/globals.css'
import SeoHead from '../components/seo/SeoHead.astro'
import AdaptiveNav from '../components/nav/AdaptiveNav.astro'
import NavDrawer from '../components/nav/NavDrawer.astro'
import ManifestoFooter from '../components/footer/ManifestoFooter.astro'

interface Props {
  title: string
  description: string
  path: string
  currentSection?: string
  /** Schemas JSON-LD adicionais (Event, BlogPosting, BreadcrumbList…) injetados no <head> */
  schemas?: Array<Record<string, unknown>>
}
const { title, description, path, currentSection, schemas } = Astro.props
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <SeoHead {title} {description} {path} {schemas} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Fraunces:ital,opsz,wght@0,9..144,200;0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;0,9..144,800;0,9..144,900;1,9..144,300;1,9..144,400;1,9..144,600;1,9..144,700&family=Space+Grotesk:wght@400;500;600;700&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <AdaptiveNav current={currentSection} />
  <NavDrawer current={currentSection} />
  <main>
    <slot />
  </main>
  <ManifestoFooter />
</body>
</html>
