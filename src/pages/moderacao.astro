---
export const prerender = false

// Página de login interno — URL secreta, não linkada no site.
// Avaliações de empresas agora são auto-aprovadas (sem painel de moderação).
// Esta página segue existindo só como porta de login: seta o cookie `rec_mod`
// usado pela aprovação de blog (/aprovacao-blog/*).
// Fluxo (NÃO usa secret na URL além do primeiro acesso, evita vazamento por logs):
//   1) GET /moderacao?s=SEU_TOKEN  → valida, seta cookie httpOnly, redireciona p/ /moderacao
//   2) GET /moderacao              → valida cookie e mostra atalho pro painel de blog

const COOKIE_NAME = 'rec_mod'
// Usa || pra descartar string vazia — mesmo padrão de reviews.ts
const MOD_SECRET = process.env.MOD_SECRET || import.meta.env.MOD_SECRET
const secretParam = Astro.url.searchParams.get('s')

// Lê cookie (sem dependência de bibliotecas)
function readCookie(name: string): string | null {
  const raw = Astro.request.headers.get('cookie') ?? ''
  for (const part of raw.split(';')) {
    const [k, ...v] = part.trim().split('=')
    if (k === name) return decodeURIComponent(v.join('='))
  }
  return null
}

if (!MOD_SECRET) {
  return new Response(null, { status: 404 })
}

// Fluxo 1: query param presente → seta cookie e remove da URL
if (secretParam) {
  if (secretParam !== MOD_SECRET) {
    return new Response(null, { status: 404 })
  }
  // Cookie httpOnly + Secure + SameSite=Strict, validade 12h
  const cookie = `${COOKIE_NAME}=${encodeURIComponent(secretParam)}; Path=/; HttpOnly; SameSite=Strict; Secure; Max-Age=${60 * 60 * 12}`
  return new Response(null, {
    status: 302,
    headers: {
      Location: '/moderacao',
      'Set-Cookie': cookie,
    },
  })
}

// Fluxo 2: sem query, valida cookie
const cookieToken = readCookie(COOKIE_NAME)
if (!cookieToken || cookieToken !== MOD_SECRET) {
  return new Response(null, { status: 404 })
}
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Acesso interno — REC</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --blue: #012659; --teal: #00a198; --bg: #f8fafc; --card: #fff; --border: rgba(1,38,89,0.1); --muted: rgba(1,38,89,0.55); }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--blue); min-height: 100vh; display: grid; place-items: center; padding: 24px; }
    .card { background: var(--card); border: 1px solid var(--border); border-radius: 20px; padding: 40px 36px; max-width: 440px; text-align: center; box-shadow: 0 4px 24px rgba(1,38,89,0.06); }
    .logo { width: 44px; height: 44px; background: var(--teal); border-radius: 10px; display: grid; place-items: center; color: #fff; font-weight: 800; font-size: 1.2rem; margin: 0 auto 20px; }
    h1 { font-size: 1.25rem; font-weight: 600; margin-bottom: 8px; }
    p { font-size: 0.9rem; color: var(--muted); line-height: 1.6; margin-bottom: 24px; }
    .btn { display: inline-block; background: var(--blue); color: #fff; padding: 13px 26px; border-radius: 10px; text-decoration: none; font-weight: 700; font-size: 0.85rem; letter-spacing: 0.04em; }
    .btn:hover { background: #023a82; }
  </style>
</head>
<body>
  <main class="card">
    <div class="logo">R</div>
    <h1>Acesso interno liberado</h1>
    <p>Você está logado. As avaliações de empresas agora sobem automaticamente — não há mais painel de moderação.<br><br>O acesso ao painel de aprovação de blog usa este mesmo login (link enviado por email a cada lote).</p>
    <a class="btn" href="/blog">ver o blog →</a>
  </main>
</body>
</html>
