---
export const prerender = false

// Página de moderação de avaliações — URL secreta, não linkada no site.
// Fluxo de acesso (NÃO usa secret na URL, evita vazamento por logs/referer/histórico):
//   1) GET /moderacao?s=SEU_TOKEN  → valida, seta cookie httpOnly, redireciona p/ /moderacao
//   2) GET /moderacao              → valida cookie e renderiza painel
//   3) APIs em /api/mod/*          → autenticadas pelo mesmo cookie (não mais por ?s=)
//
// Esquema mantém compatibilidade com link existente — basta usar ?s= UMA vez pra
// "fazer login" e o cookie passa a substituir.

const COOKIE_NAME = 'rec_mod'
const MOD_SECRET = import.meta.env.MOD_SECRET
const secretParam = Astro.url.searchParams.get('s')

// Lê cookie (sem dependência de bibliotecas)
function readCookie(name: string): string | null {
  const raw = Astro.request.headers.get('cookie') ?? ''
  for (const part of raw.split(';')) {
    const [k, ...v] = part.trim().split('=')
    if (k === name) return decodeURIComponent(v.join('='))
  }
  return null
}

if (!MOD_SECRET) {
  return new Response(null, { status: 404 })
}

// Fluxo 1: query param presente → seta cookie e remove da URL
if (secretParam) {
  if (secretParam !== MOD_SECRET) {
    return new Response(null, { status: 404 })
  }
  // Cookie httpOnly + Secure + SameSite=Strict, validade 12h
  const cookie = `${COOKIE_NAME}=${encodeURIComponent(secretParam)}; Path=/; HttpOnly; SameSite=Strict; Secure; Max-Age=${60 * 60 * 12}`
  return new Response(null, {
    status: 302,
    headers: {
      Location: '/moderacao',
      'Set-Cookie': cookie,
    },
  })
}

// Fluxo 2: sem query, valida cookie
const cookieToken = readCookie(COOKIE_NAME)
if (!cookieToken || cookieToken !== MOD_SECRET) {
  return new Response(null, { status: 404 })
}
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Moderação — REC</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue: #012659;
      --teal: #00a198;
      --green: #16a34a;
      --red: #dc2626;
      --bg: #f8fafc;
      --card: #ffffff;
      --border: rgba(1,38,89,0.1);
      --text: #012659;
      --muted: rgba(1,38,89,0.55);
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    /* ===== HEADER ===== */
    .topbar {
      background: var(--blue);
      padding: 16px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }
    .topbar-brand {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .topbar-logo {
      width: 36px;
      height: 36px;
      background: var(--teal);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 1rem;
      color: #fff;
      letter-spacing: -0.04em;
    }
    .topbar-title {
      color: #fff;
      font-size: 0.95rem;
      font-weight: 600;
    }
    .topbar-sub {
      color: rgba(255,255,255,0.55);
      font-size: 0.75rem;
    }
    .topbar-badge {
      background: rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.8);
      border: 1px solid rgba(255,255,255,0.18);
      border-radius: 999px;
      padding: 4px 12px;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.06em;
    }

    /* ===== MAIN ===== */
    .main {
      max-width: 760px;
      margin: 0 auto;
      padding: 32px 20px 64px;
    }

    /* ===== STATS ===== */
    .stats-row {
      display: flex;
      gap: 12px;
      margin-bottom: 28px;
      flex-wrap: wrap;
    }
    .stat-pill {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 14px 20px;
      display: flex;
      align-items: center;
      gap: 10px;
      flex: 1;
      min-width: 140px;
    }
    .stat-icon {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      flex-shrink: 0;
    }
    .stat-icon.pending { background: rgba(251,191,36,0.15); }
    .stat-icon.approved { background: rgba(22,163,74,0.12); }
    .stat-icon.total { background: rgba(0,161,152,0.1); }
    .stat-num {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--blue);
      line-height: 1;
    }
    .stat-label {
      font-size: 0.68rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
      margin-top: 2px;
    }

    /* ===== SECTION HEADER ===== */
    .section-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }
    .section-title {
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--muted);
    }
    .refresh-btn {
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 6px 12px;
      font-size: 0.72rem;
      font-weight: 600;
      color: var(--muted);
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: all 0.15s;
    }
    .refresh-btn:hover { background: var(--blue); color: #fff; border-color: var(--blue); }

    /* ===== REVIEW CARDS ===== */
    .reviews-list {
      display: grid;
      gap: 14px;
    }

    .review-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 20px 22px;
      transition: box-shadow 0.15s;
    }
    .review-card:hover {
      box-shadow: 0 4px 20px rgba(1,38,89,0.08);
    }

    .review-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 10px;
    }
    .review-partner {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--teal);
      background: rgba(0,161,152,0.1);
      padding: 3px 10px;
      border-radius: 999px;
    }
    .review-date {
      font-size: 0.7rem;
      color: var(--muted);
      white-space: nowrap;
    }

    .review-author {
      font-weight: 600;
      font-size: 0.9rem;
      color: var(--blue);
      margin-bottom: 4px;
    }
    .review-stars {
      color: #f5b400;
      font-size: 1rem;
      letter-spacing: 2px;
      margin-bottom: 8px;
    }
    .review-comment {
      font-size: 0.87rem;
      line-height: 1.55;
      color: rgba(1,38,89,0.82);
      margin: 0;
    }
    .review-comment:empty { display: none; }

    .review-actions {
      display: flex;
      gap: 10px;
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid var(--border);
    }
    .btn {
      flex: 1;
      padding: 10px 0;
      border-radius: 10px;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: lowercase;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      transition: all 0.15s;
    }
    .btn-approve {
      background: rgba(22,163,74,0.1);
      color: var(--green);
      border: 1px solid rgba(22,163,74,0.25);
    }
    .btn-approve:hover {
      background: var(--green);
      color: #fff;
      border-color: var(--green);
    }
    .btn-reject {
      background: rgba(220,38,38,0.07);
      color: var(--red);
      border: 1px solid rgba(220,38,38,0.2);
    }
    .btn-reject:hover {
      background: var(--red);
      color: #fff;
      border-color: var(--red);
    }
    .btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      pointer-events: none;
    }

    /* ===== STATES ===== */
    .state-box {
      text-align: center;
      padding: 56px 24px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 16px;
    }
    .state-icon {
      font-size: 2.5rem;
      margin-bottom: 16px;
    }
    .state-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--blue);
      margin-bottom: 6px;
    }
    .state-sub {
      font-size: 0.85rem;
      color: var(--muted);
    }

    /* ===== TOAST ===== */
    .toast {
      position: fixed;
      bottom: 28px;
      right: 28px;
      background: var(--blue);
      color: #fff;
      padding: 12px 20px;
      border-radius: 12px;
      font-size: 0.84rem;
      font-weight: 600;
      box-shadow: 0 8px 30px rgba(1,38,89,0.3);
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 0.2s, transform 0.2s;
      pointer-events: none;
      z-index: 100;
    }
    .toast.show { opacity: 1; transform: translateY(0); }
    .toast.ok { background: var(--green); }
    .toast.err { background: var(--red); }

    /* ===== LOADING ===== */
    .spinner {
      display: inline-block;
      width: 18px; height: 18px;
      border: 2px solid rgba(1,38,89,0.15);
      border-top-color: var(--teal);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      vertical-align: middle;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    @media (max-width: 520px) {
      .stats-row { flex-direction: column; }
      .stat-pill { min-width: 0; }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="topbar-brand">
      <div class="topbar-logo">R</div>
      <div>
        <div class="topbar-title">REC — Moderação</div>
        <div class="topbar-sub">avaliações pendentes de aprovação</div>
      </div>
    </div>
    <div class="topbar-badge" id="auth-pill">● acesso interno</div>
  </header>

  <main class="main">
    <div class="stats-row">
      <div class="stat-pill">
        <div class="stat-icon pending">⏳</div>
        <div>
          <div class="stat-num" id="count-pending">—</div>
          <div class="stat-label">pendentes</div>
        </div>
      </div>
      <div class="stat-pill">
        <div class="stat-icon approved">✅</div>
        <div>
          <div class="stat-num" id="count-session">0</div>
          <div class="stat-label">aprovadas hoje</div>
        </div>
      </div>
      <div class="stat-pill">
        <div class="stat-icon total">🚫</div>
        <div>
          <div class="stat-num" id="count-rejected">0</div>
          <div class="stat-label">rejeitadas hoje</div>
        </div>
      </div>
    </div>

    <div class="section-head">
      <span class="section-title">aguardando revisão</span>
      <button class="refresh-btn" id="refresh-btn" type="button">
        <span>↺</span> atualizar
      </button>
    </div>

    <div id="reviews-container">
      <div class="state-box">
        <div class="state-icon"><span class="spinner"></span></div>
        <div class="state-title">carregando…</div>
      </div>
    </div>
  </main>

  <div class="toast" id="toast"></div>

  <script>
    // ===== PARTNERS MAP (para exibir nome legível) =====
    // Carregado assincronamente via fetch do próprio site
    let partnerNames: Record<string, string> = {}

    async function loadPartnerNames() {
      try {
        const res = await fetch('/api/partners-list')
        if (res.ok) partnerNames = await res.json()
      } catch {
        // silencioso — mostra ID se falhar
      }
    }

    function partnerLabel(id: string): string {
      return partnerNames[id] || id
    }

    // ===== STATE =====
    // (autenticação agora é via cookie httpOnly — nada de token no client)
    let approvedCount = 0
    let rejectedCount = 0

    // Helper escape HTML real (não só remoção)
    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;')
    }

    // ===== UTILS =====
    function toast(msg: string, type: 'ok' | 'err' | '' = '') {
      const el = document.getElementById('toast')!
      el.textContent = msg
      el.className = `toast ${type} show`
      clearTimeout((el as any)._t)
      ;(el as any)._t = setTimeout(() => el.classList.remove('show'), 3000)
    }

    function formatDate(iso: string): string {
      return new Intl.DateTimeFormat('pt-BR', {
        day: '2-digit', month: 'short', year: 'numeric',
        hour: '2-digit', minute: '2-digit',
      }).format(new Date(iso))
    }

    function stars(n: number): string {
      return '★'.repeat(n) + '☆'.repeat(5 - n)
    }

    // ===== LOAD REVIEWS =====
    async function loadReviews() {
      const container = document.getElementById('reviews-container')!
      container.innerHTML = `
        <div class="state-box">
          <div class="state-icon"><span class="spinner"></span></div>
          <div class="state-title">carregando…</div>
        </div>`

      try {
        const res = await fetch('/api/mod/reviews', { credentials: 'same-origin' })
        if (res.status === 403 || res.status === 401) {
          container.innerHTML = `<div class="state-box"><div class="state-icon">🔒</div><div class="state-title">acesso negado</div></div>`
          return
        }
        const data: any[] = await res.json()
        document.getElementById('count-pending')!.textContent = String(data.length)

        if (data.length === 0) {
          container.innerHTML = `
            <div class="state-box">
              <div class="state-icon">🎉</div>
              <div class="state-title">tudo revisado!</div>
              <div class="state-sub">nenhuma avaliação pendente no momento.</div>
            </div>`
          return
        }

        container.innerHTML = `<div class="reviews-list">${data.map(r => `
          <div class="review-card" data-id="${escapeHtml(String(r.id))}">
            <div class="review-top">
              <span class="review-partner">${escapeHtml(partnerLabel(r.partner_id))}</span>
              <span class="review-date">${escapeHtml(formatDate(r.created_at))}</span>
            </div>
            <div class="review-author">${escapeHtml(r.author_name || 'anônimo')}</div>
            <div class="review-stars">${stars(r.rating)}</div>
            <p class="review-comment">${escapeHtml(r.comment || '')}</p>
            <div class="review-actions">
              <button class="btn btn-approve" data-action="approve" data-id="${escapeHtml(String(r.id))}">
                ✓ aprovar
              </button>
              <button class="btn btn-reject" data-action="reject" data-id="${escapeHtml(String(r.id))}">
                ✕ rejeitar
              </button>
            </div>
          </div>`).join('')}</div>`

        // Bind botões
        container.querySelectorAll<HTMLButtonElement>('[data-action]').forEach(btn => {
          btn.addEventListener('click', () => handleAction(btn.dataset.id!, btn.dataset.action as 'approve' | 'reject'))
        })
      } catch {
        container.innerHTML = `
          <div class="state-box">
            <div class="state-icon">⚠️</div>
            <div class="state-title">erro ao carregar</div>
            <div class="state-sub">tente atualizar a página.</div>
          </div>`
      }
    }

    // ===== ACTION =====
    async function handleAction(id: string, action: 'approve' | 'reject') {
      const card = document.querySelector<HTMLElement>(`.review-card[data-id="${id}"]`)
      if (!card) return

      // Desabilita botões do card
      card.querySelectorAll<HTMLButtonElement>('button').forEach(b => b.disabled = true)

      try {
        const res = await fetch('/api/mod/reviews', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({ id, action }),
        })
        if (!res.ok) throw new Error('falhou')

        // Animação de saída
        card.style.transition = 'opacity 0.3s, transform 0.3s'
        card.style.opacity = '0'
        card.style.transform = 'translateX(20px)'
        setTimeout(() => card.remove(), 320)

        if (action === 'approve') {
          approvedCount++
          document.getElementById('count-session')!.textContent = String(approvedCount)
          toast('avaliação aprovada ✓', 'ok')
        } else {
          rejectedCount++
          document.getElementById('count-rejected')!.textContent = String(rejectedCount)
          toast('avaliação rejeitada', '')
        }

        // Atualiza contador pendentes
        const remaining = document.querySelectorAll('.review-card').length - 1
        document.getElementById('count-pending')!.textContent = String(remaining)
        if (remaining === 0) {
          setTimeout(() => {
            document.getElementById('reviews-container')!.innerHTML = `
              <div class="state-box">
                <div class="state-icon">🎉</div>
                <div class="state-title">tudo revisado!</div>
                <div class="state-sub">nenhuma avaliação pendente no momento.</div>
              </div>`
          }, 400)
        }
      } catch {
        card.querySelectorAll<HTMLButtonElement>('button').forEach(b => b.disabled = false)
        toast('erro ao processar. tenta de novo.', 'err')
      }
    }

    // ===== INIT =====
    document.getElementById('refresh-btn')!.addEventListener('click', loadReviews)

    loadPartnerNames().then(() => loadReviews())
  </script>
</body>
</html>
