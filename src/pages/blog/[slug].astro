---
import BaseLayout from '../../layouts/BaseLayout.astro'
import ReadingProgress from '../../components/blog/ReadingProgress.astro'
import ArticleSidebar from '../../components/blog/ArticleSidebar.astro'
import ShareBar from '../../components/blog/ShareBar.astro'
import { getCategoryInfo, pillarToCategory, readingTime } from '../../utils/blog-category'
import { getCollection, render, type CollectionEntry } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }))
}

const { post } = Astro.props as { post: CollectionEntry<'blog'> }
const { Content } = await render(post)

const cat = getCategoryInfo(post.data.pillar)
const catSlug = pillarToCategory(post.data.pillar)
const dateStr = post.data.publishedAt.toLocaleDateString('pt-BR', {
  day: '2-digit', month: 'long', year: 'numeric',
})
const minutes = readingTime(post.body || '')

// Variante do hero: todos os posts com imagem ganham o hero visual
const hasImageHero = !!post.data.cover

// Artigos relacionados (mesma categoria visual, exceto o atual)
const allPosts = await getCollection('blog')
const related = allPosts
  .filter(p => p.id !== post.id && pillarToCategory(p.data.pillar) === catSlug)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3)

// URL canônica para compartilhamento
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://somosrecoficial.com.br'
const fullUrl = `${siteUrl}/blog/${post.id}`

// JSON-LD: BlogPosting + Breadcrumb (rich results no Google)
const articleSchemas: Array<Record<string, unknown>> = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.excerpt,
    image: post.data.cover ? `${siteUrl}${post.data.cover}` : `${siteUrl}/NORMAL - FT.png`,
    datePublished: post.data.publishedAt.toISOString(),
    author: post.data.author
      ? { '@type': 'Person', name: post.data.author }
      : { '@type': 'Organization', name: 'REC Colaborativo' },
    publisher: {
      '@type': 'Organization',
      name: 'REC Colaborativo',
      logo: { '@type': 'ImageObject', url: `${siteUrl}/logo-icon-white.png` },
    },
    mainEntityOfPage: { '@type': 'WebPage', '@id': fullUrl },
    articleSection: cat.label,
    wordCount: (post.body || '').split(/\s+/).length,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Início', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog` },
      { '@type': 'ListItem', position: 3, name: post.data.title, item: fullUrl },
    ],
  },
]
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt}
  path={`/blog/${post.id}`}
  currentSection="Blog"
  schemas={articleSchemas}
>

  <ReadingProgress />

  <!-- ============================================
       HERO DO ARTIGO — variante por categoria
       ============================================ -->
  <header
    class:list={['article-hero', hasImageHero ? 'article-hero--image' : 'article-hero--text']}
    style={`--cat-color: ${cat.color};`}
  >
    {hasImageHero && post.data.cover && (
      <div class="article-hero-media" aria-hidden="true">
        <img src={post.data.cover} alt={post.data.coverAlt ?? ''} />
        <div class="article-hero-overlay"></div>
      </div>
    )}

    <div class="article-hero-inner">
      <a href="/blog" class="article-back">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="19" y1="12" x2="5" y2="12"/>
          <polyline points="12 19 5 12 12 5"/>
        </svg>
        voltar para o blog
      </a>

      <div class="article-hero-meta">
        <span class="article-hero-cat">
          <span class="article-hero-cat-dot" aria-hidden="true"></span>
          {cat.label}
        </span>
        <time class="article-hero-date" datetime={post.data.publishedAt.toISOString()}>
          {dateStr}
        </time>
        <span class="article-hero-sep" aria-hidden="true">·</span>
        <span class="article-hero-read">{minutes} min de leitura</span>
      </div>

      <h1 class="article-hero-title">{post.data.title}</h1>
      <p class="article-hero-excerpt">{post.data.excerpt}</p>

      {post.data.author && (
        <span class="article-hero-author">
          por <strong>{post.data.author}</strong>
        </span>
      )}
    </div>
  </header>

  <!-- ============================================
       LAYOUT ARTIGO + SIDEBAR
       ============================================ -->
  <div class="article-layout">

    <article class="article-body">
      <Content />
    </article>

    <ArticleSidebar related={related} />

  </div>

  <!-- ============================================
       SHARE BAR
       ============================================ -->
  <ShareBar url={fullUrl} title={post.data.title} />

  <!-- ============================================
       CTA FINAL — padrão das outras páginas
       ============================================ -->
  <section class="article-final" data-reveal>
    <div class="article-final-bars" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>
    <div class="article-final-inner">
      <h2>Quer continuar a conversa <em>com a gente?</em></h2>
      <p>O conteúdo aqui é uma amostra. A comunidade REC é onde as conexões viram negócio.</p>
      <div class="article-final-actions">
        <a href="/blog" class="article-final-btn article-final-btn--ghost">ver mais artigos</a>
        <a href="/eventos#proximos" class="article-final-btn">próximos eventos →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // ── Smooth scroll para links de âncora dentro do artigo ───
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement
    const link = target.closest<HTMLAnchorElement>('a[href^="#"]')
    if (!link) return
    const id = link.getAttribute('href')?.slice(1)
    if (!id) return
    const el = document.getElementById(id)
    if (el) {
      e.preventDefault()
      const top = el.getBoundingClientRect().top + window.scrollY - 90
      window.scrollTo({ top, behavior: 'smooth' })
      history.replaceState(null, '', `#${id}`)
    }
  })
</script>

<style>
:global(main) { overflow: visible !important; }

/* ============================================
   HERO — TEXTO PURO (educacional/histórias)
   ============================================ */
.article-hero {
  --cat-color: var(--rec-teal);
  position: relative;
  overflow: hidden;
  padding: var(--space-20) var(--space-6) var(--space-12);
  background: var(--rec-navy);
  color: #fff;
}
.article-hero--text {
  padding-top: calc(var(--space-20) + var(--space-6));
}

.article-hero-inner {
  position: relative;
  max-width: 760px;
  margin: 0 auto;
  z-index: 2;
}

.article-back {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-ui);
  font-size: 0.72rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  font-weight: 600;
  color: rgba(255,255,255,0.55);
  text-decoration: none;
  margin-bottom: var(--space-8);
  transition: color 220ms var(--easing), gap 220ms var(--easing);
}
.article-back svg { width: 14px; height: 14px; transition: transform 220ms var(--easing); }
.article-back:hover { color: var(--rec-teal); gap: 12px; }
.article-back:hover svg { transform: translateX(-3px); }

.article-hero-meta {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-bottom: var(--space-5);
  flex-wrap: wrap;
}
.article-hero-cat {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,255,255,0.96);
  color: var(--cat-color);
  padding: 6px 14px;
  border-radius: 999px;
  font-family: var(--font-ui);
  font-size: 0.68rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  font-weight: 700;
}
.article-hero-cat-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--cat-color); }
.article-hero-date,
.article-hero-read {
  font-family: var(--font-ui);
  font-size: 0.78rem;
  letter-spacing: 0.06em;
  color: rgba(255,255,255,0.6);
}
.article-hero-sep { color: rgba(255,255,255,0.4); }

.article-hero-title {
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 5.5vw, 4.4rem);
  font-weight: 300;
  line-height: 1.05;
  letter-spacing: -0.025em;
  color: #fff;
  margin: 0 0 var(--space-5);
}

.article-hero-excerpt {
  font-size: 1.18rem;
  line-height: 1.6;
  color: rgba(255,255,255,0.78);
  max-width: 620px;
  margin: 0 0 var(--space-6);
}

.article-hero-author {
  display: inline-block;
  font-family: var(--font-ui);
  font-size: 0.82rem;
  letter-spacing: 0.04em;
  color: rgba(255,255,255,0.55);
}
.article-hero-author strong { color: var(--rec-teal); font-weight: 600; letter-spacing: 0.06em; }

/* ============================================
   HERO — VARIANTE COM IMAGEM (eventos)
   ============================================ */
.article-hero--image {
  background: var(--rec-navy);
  min-height: 70vh;
  display: flex;
  align-items: flex-end;
  padding: var(--space-24) var(--space-6) var(--space-12);
}
.article-hero-media {
  position: absolute; inset: 0;
  z-index: 0;
}
.article-hero-media img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}
.article-hero-overlay {
  position: absolute; inset: 0;
  background:
    linear-gradient(180deg, rgba(1,14,42,0) 0%, rgba(1,14,42,0.5) 50%, rgba(1,14,42,0.92) 100%),
    linear-gradient(135deg, rgba(1,38,89,0.4) 0%, transparent 60%);
}

/* ============================================
   LAYOUT (corpo + sidebar)
   ============================================ */
.article-layout {
  display: flex;
  gap: var(--space-12);
  max-width: var(--container-max);
  margin: 0 auto;
  padding: var(--space-14) var(--space-6) var(--space-12);
}

.article-body {
  flex: 1;
  max-width: 680px;
  margin: 0 auto;
  font-family: var(--font-body);
  font-size: 1.08rem;
  line-height: 1.8;
  color: rgba(1,38,89,0.85);
}

@media (min-width: 1100px) {
  .article-layout {
    align-items: flex-start;
  }
  .article-body { margin: 0; }
}

/* ============================================
   TIPOGRAFIA DO CORPO DO ARTIGO
   ============================================ */
.article-body :global(p) {
  margin: 0 0 var(--space-5);
}
.article-body :global(p:first-of-type) {
  font-size: 1.18rem;
  line-height: 1.65;
  color: var(--rec-blue);
  font-weight: 400;
}

.article-body :global(h2) {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 2.6vw, 2rem);
  font-weight: 400;
  line-height: 1.2;
  letter-spacing: -0.02em;
  color: var(--rec-blue);
  margin: var(--space-12) 0 var(--space-5);
  scroll-margin-top: 100px;
}
.article-body :global(h3) {
  font-family: var(--font-ui);
  font-size: 1.15rem;
  font-weight: 600;
  letter-spacing: 0.01em;
  color: var(--rec-blue);
  margin: var(--space-8) 0 var(--space-3);
  scroll-margin-top: 100px;
}

.article-body :global(a) {
  color: var(--rec-teal);
  text-decoration: none;
  background-image: linear-gradient(180deg, transparent 65%, rgba(0,161,152,0.25) 65%);
  transition: background-color 220ms var(--easing);
  padding: 0 2px;
}
.article-body :global(a:hover) {
  background-color: rgba(0,161,152,0.18);
}

.article-body :global(strong) { color: var(--rec-blue); font-weight: 600; }
.article-body :global(em) { font-style: italic; }

.article-body :global(blockquote) {
  margin: var(--space-10) 0;
  padding: var(--space-5) 0 var(--space-5) var(--space-6);
  border-left: 3px solid var(--rec-teal);
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.42rem;
  font-weight: 400;
  line-height: 1.45;
  color: var(--rec-teal);
  letter-spacing: -0.005em;
}
.article-body :global(blockquote p) { margin: 0; }
.article-body :global(blockquote p + p) { margin-top: var(--space-3); }

.article-body :global(ul),
.article-body :global(ol) {
  padding-left: var(--space-6);
  margin: 0 0 var(--space-6);
}
.article-body :global(li) {
  margin-bottom: var(--space-3);
  line-height: 1.7;
}
.article-body :global(li::marker) { color: var(--rec-teal); }

.article-body :global(img) {
  max-width: 100%;
  height: auto;
  border-radius: 14px;
  margin: var(--space-8) 0;
  box-shadow: 0 12px 40px rgba(1,38,89,0.08);
}

.article-body :global(hr) {
  border: none;
  height: 1px;
  background: linear-gradient(90deg, transparent 0%, rgba(1,38,89,0.15) 50%, transparent 100%);
  margin: var(--space-12) 0;
}

.article-body :global(code) {
  background: rgba(0,161,152,0.08);
  color: var(--rec-blue);
  padding: 2px 6px;
  border-radius: 4px;
  font-family: 'Space Mono', ui-monospace, monospace;
  font-size: 0.88em;
}
.article-body :global(pre) {
  background: var(--rec-navy);
  color: #e6edf3;
  padding: var(--space-5);
  border-radius: 12px;
  overflow-x: auto;
  margin: var(--space-8) 0;
  font-family: 'Space Mono', ui-monospace, monospace;
  font-size: 0.92rem;
  line-height: 1.6;
}
.article-body :global(pre code) { background: none; color: inherit; padding: 0; }

/* ============================================
   CTA FINAL — mesmo padrão de comunidade/hub
   ============================================ */
.article-final {
  position: relative;
  z-index: 5;
  overflow: hidden;
  padding: var(--space-24) var(--space-6);
  background: linear-gradient(
    180deg,
    #fbfcfe  0%,
    #f5fafd  3%,
    #eef6fc  6%,
    #e4f0fa  9%,
    #d6e9f7 12%,
    #c5dff3 16%,
    #b0d2ee 20%,
    #97c3e7 24%,
    #7ab0de 29%,
    #5d9cd3 34%,
    #4287c5 39%,
    #2c73b6 45%,
    #1a60a6 51%,
    #0f4e95 57%,
    #083e81 63%,
    #052e6a 70%,
    #031f52 79%,
    #031548 89%,
    #042050 100%
  );
  text-align: center;
}
.article-final::after {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: 0.06;
  z-index: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 180px 180px;
  mix-blend-mode: overlay;
}
.article-final::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 22%;
  pointer-events: none;
  z-index: 1;
  background: linear-gradient(to bottom, #fbfcfe 0%, #fbfcfe 30%, rgba(251,252,254,0) 100%);
}

.article-final-bars {
  position: absolute;
  top: 32px;
  right: 5vw;
  display: flex;
  flex-direction: column;
  gap: 6px;
  pointer-events: none;
  z-index: 2;
  mix-blend-mode: multiply;
}
.article-final-bars span { display: block; border-radius: 999px; height: 10px; }
.article-final-bars span:nth-child(1) { width: 95px; background: var(--rec-blue); }
.article-final-bars span:nth-child(2) { width: 78px; background: var(--rec-teal); }
.article-final-bars span:nth-child(3) { width: 48px; background: var(--rec-blue); }
@media (max-width: 768px) { .article-final-bars { display: none; } }

.article-final-inner {
  position: relative;
  z-index: 2;
  max-width: 680px;
  margin: 0 auto;
}
.article-final h2 {
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 5vw, 3.8rem);
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1.1;
  margin-bottom: var(--space-4);
  color: var(--rec-blue);
}
.article-final h2 em { color: var(--rec-blue); font-style: normal; font-weight: 800; }
.article-final p {
  color: rgba(255,255,255,0.85);
  line-height: 1.7;
  margin-bottom: var(--space-8);
  font-size: var(--type-body);
}
.article-final-actions {
  display: flex;
  gap: var(--space-3);
  justify-content: center;
  flex-wrap: wrap;
}
.article-final-btn {
  display: inline-block;
  padding: 18px 48px;
  border-radius: 999px;
  font-family: var(--font-ui);
  font-size: 1.02rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: lowercase;
  text-decoration: none;
  background: transparent;
  color: var(--rec-teal);
  border: 2px solid var(--rec-teal);
  transition:
    background var(--motion-fast) var(--easing),
    color var(--motion-fast) var(--easing),
    box-shadow var(--motion-fast) var(--easing),
    transform var(--motion-fast) var(--easing);
  animation: cta-pulse 2.8s ease-in-out infinite;
}
.article-final-btn:hover {
  background: var(--rec-teal);
  color: #fff;
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(0,161,152,0.45);
  animation: none;
}
.article-final-btn--ghost {
  color: rgba(255,255,255,0.7);
  border-color: rgba(255,255,255,0.3);
  animation: none;
}
.article-final-btn--ghost:hover {
  background: rgba(255,255,255,0.12);
  color: #fff;
  border-color: rgba(255,255,255,0.6);
  box-shadow: none;
}
@keyframes cta-pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(0,161,152,0); }
  50% { box-shadow: 0 0 0 10px rgba(0,161,152,0.18); }
}

@media (max-width: 600px) {
  .article-hero { padding: var(--space-16) var(--space-5) var(--space-10); }
  .article-hero--image { min-height: 60vh; padding-top: var(--space-20); }
  .article-layout { padding: var(--space-10) var(--space-5); }
  .article-body { font-size: 1.02rem; }
  .article-body :global(p:first-of-type) { font-size: 1.1rem; }
  .article-body :global(blockquote) { font-size: 1.2rem; padding-left: var(--space-5); margin: var(--space-8) 0; }
  .article-final { padding: var(--space-16) var(--space-5); }
  .article-final-actions { flex-direction: column; align-items: center; }
  .article-final-btn { width: 100%; max-width: 320px; text-align: center; }
}
@media (prefers-reduced-motion: reduce) {
  .article-final-btn { animation: none; }
}

@media (prefers-reduced-motion: reduce) {
  .article-footer-btn:hover { transform: none; }
}
</style>
