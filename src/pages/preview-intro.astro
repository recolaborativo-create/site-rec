---
import BaseLayout from '../layouts/BaseLayout.astro'
import WelcomeAnimationV2 from '../components/hero/WelcomeAnimationV2.astro'
import HeroManifesto from '../components/hero/HeroManifesto.astro'
---
<BaseLayout
  title="Preview — animação V2"
  description="Página de preview da nova animação de abertura. Não está em produção."
  path="/preview-intro"
>
  <!-- Banner explicativo no topo (só aparece depois que a animação revelar o site) -->
  <div class="preview-banner">
    <div class="preview-banner-inner">
      <strong>Preview da animação V2</strong>
      <span class="preview-banner-sub">Recarregue a página para reassistir. Clique / Esc / Enter para pular.</span>
      <button class="preview-replay" onclick="window.location.reload()" aria-label="reassistir animação">↻ reassistir</button>
    </div>
  </div>

  <WelcomeAnimationV2 />
  <HeroManifesto />

  <!-- Seção placeholder pra você ver o site sendo revelado da esquerda → direita -->
  <section class="preview-content">
    <div class="preview-content-inner">
      <span class="uppercase-label" style="color: var(--rec-teal)">site revelado</span>
      <h2>O movimento <em>continua aqui.</em></h2>
      <p>Esta é uma página de preview. A home real está em <a href="/">/</a> e ainda usa a animação anterior. Quando você aprovar a V2, eu integro na home oficial.</p>
      <a href="/" class="preview-cta">voltar pra home →</a>
    </div>
  </section>
</BaseLayout>

<style>
.preview-banner {
  position: fixed;
  top: 80px;
  right: 16px;
  z-index: 200;
  pointer-events: auto;
}
.preview-banner-inner {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 14px 18px;
  background: var(--rec-blue);
  color: #fff;
  border-radius: 12px;
  box-shadow: 0 12px 28px rgba(1,38,89,0.22);
  max-width: 280px;
}
.preview-banner-inner strong {
  font-size: var(--type-small);
  font-weight: 700;
  letter-spacing: 0.02em;
}
.preview-banner-sub {
  font-size: var(--type-micro);
  color: rgba(255,255,255,0.78);
  line-height: 1.4;
}
.preview-replay {
  align-self: flex-start;
  margin-top: 6px;
  background: var(--rec-teal);
  color: #fff;
  border: none;
  padding: 6px 12px;
  border-radius: 8px;
  font-weight: 700;
  font-size: var(--type-micro);
  letter-spacing: 0.06em;
  cursor: pointer;
  transition: transform var(--motion-fast) var(--easing);
}
.preview-replay:hover { transform: translateY(-1px); }

.preview-content {
  padding: var(--space-16) var(--space-6);
  background: linear-gradient(180deg, #ffffff 0%, rgba(184,224,221,0.18) 100%);
  text-align: center;
}
.preview-content-inner {
  max-width: 640px;
  margin: 0 auto;
  position: relative;
  z-index: 5;
}
.preview-content h2 {
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 800;
  letter-spacing: var(--letter-tight);
  color: var(--rec-blue);
  margin: var(--space-3) 0 var(--space-4);
  line-height: 1.05;
}
.preview-content h2 em { color: var(--rec-teal); font-style: italic; }
.preview-content p { color: #2c3a48; line-height: 1.7; margin-bottom: var(--space-6); }
.preview-content a { color: var(--rec-teal); font-weight: 700; }
.preview-cta {
  display: inline-block;
  padding: 12px 24px;
  border: 1.5px solid var(--rec-teal);
  border-radius: 8px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-size: var(--type-small);
  transition: background var(--motion-fast) var(--easing), color var(--motion-fast) var(--easing);
}
.preview-cta:hover { background: var(--rec-teal); color: #fff; }

@media (max-width: 600px) {
  .preview-banner { right: 8px; top: 76px; }
  .preview-banner-inner { padding: 10px 14px; max-width: 220px; }
}
</style>
