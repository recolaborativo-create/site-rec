---
import BaseLayout from '../layouts/BaseLayout.astro'
import HeroManifesto from '../components/hero/HeroManifesto.astro'
import IllustrativeImg from '../components/ui/IllustrativeImg.astro'
import InstagramFeed from '../components/instagram/InstagramFeed.astro'
import PillarChip from '../components/blog/PillarChip.astro'
import ScrollGraphics from '../components/ui/ScrollGraphics.astro'
import { whatsappLink, messages } from '../utils/whatsapp'
import { getCollection } from 'astro:content'

const allPosts = await getCollection('blog')
const recentPosts = allPosts
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3)
---
<BaseLayout
  title="REC"
  description="Movimento gera movimento. Ecossistema de empresas que crescem porque se movem juntas."
  path="/"
>
  <ScrollGraphics />
  <HeroManifesto />

  <!-- TRES PORTAS: Comunidade + HUB Digital + Eventos -->
  <section class="home-paths">
    <div class="paths-inner">
      <!-- Stats compactos — só mobile, em cima do título -->
      <div class="paths-stats-mobile" aria-hidden="false">
        <div class="paths-stat"><span class="paths-stat-num">+10mil</span><span class="paths-stat-label">conexões</span></div>
        <div class="paths-stat"><span class="paths-stat-num">+90</span><span class="paths-stat-label">empresas</span></div>
        <div class="paths-stat"><span class="paths-stat-num">8</span><span class="paths-stat-label">anos</span></div>
        <div class="paths-stat"><span class="paths-stat-num">+R$30M</span><span class="paths-stat-label">receita</span></div>
      </div>

      <header class="paths-header" data-reveal>
        <span class="uppercase-label" style="color: var(--rec-teal)">três portas, um movimento</span>
        <h2>Como você quer <em>se mover?</em></h2>
      </header>

      <div class="paths-grid">
        <article class="path path-comunidade" data-reveal>
          <span class="path-num">01</span>
          <span class="path-tag">comunidade</span>
          <h3>Entrar na rede.</h3>
          <p class="path-text-long">Empresas conectadas por um mesmo propósito: crescer através de relações verdadeiras, networking qualificado, parcerias estratégicas e oportunidades que geram resultados reais.</p>
          <p class="path-text-short">Empresas conectadas pra crescer: networking, parcerias e resultados reais.</p>
          <ul class="path-bullets">
            <li>Realização de negócios</li>
            <li>Acesso a diversas empresas</li>
            <li>Benefícios exclusivos da rede</li>
          </ul>
          <a href="/comunidade" class="path-cta">conhecer a comunidade →</a>
        </article>

        <article class="path path-hub" data-reveal>
          <span class="path-num">02</span>
          <span class="path-tag">hub</span>
          <h3>Soluções empresariais.</h3>
          <p class="path-text-long">Desenvolvido para auxiliar empresas no fortalecimento do crescimento estruturado e aumento de faturamento através de estratégias inteligentes e alinhadas ao mercado atual.</p>
          <p class="path-text-short">Soluções pra crescer com estratégia e aumentar faturamento.</p>
          <ul class="path-bullets">
            <li>Social Media estratégico</li>
            <li>Tráfego pago Meta + Google</li>
            <li>Captação de mídia</li>
          </ul>
          <a href="/hub" class="path-cta">conhecer o hub →</a>
        </article>

        <article class="path path-eventos" data-reveal>
          <span class="path-num">03</span>
          <span class="path-tag">eventos</span>
          <h3>Viver o movimento.</h3>
          <p class="path-text-long">Eventos presenciais pensados para aproximar empresários, criar soluções estratégicas e transformar encontros em oportunidades reais de negócio. Confira a agenda e faça parte.</p>
          <p class="path-text-short">Encontros presenciais que viram oportunidades reais de negócio.</p>
          <ul class="path-bullets">
            <li>Conexões de negócios</li>
            <li>Mentoria e workshops</li>
            <li>Relacionamento entre marcas</li>
          </ul>
          <a href="/eventos" class="path-cta">ver a agenda →</a>
        </article>
      </div>
    </div>
  </section>

  <!-- FUNDADORA -->
  <section class="home-fundadora" data-reveal>
    <div class="fund-inner">
      <!-- HEADER (aparece acima da imagem no mobile) -->
      <div class="fund-header">
        <span class="uppercase-label" style="color: var(--rec-teal)">fundadora</span>
        <h2>Francielle Caleffi.</h2>
        <p class="fund-role">CEO e fundadora</p>
      </div>

      <div class="fund-image" data-fund-image>
        <picture>
          <img src="/fundadora/fundadora-home.jpg" alt="Francielle Caleffi, fundadora REC" loading="lazy" decoding="async" onerror="this.parentElement.classList.add('fund-image-fallback'); this.style.display='none'" />
        </picture>
        <!-- Overlay com degradê + texto sobreposto + ver mais (só mobile)
             ORDEM IMPORTA: text-2 fica no TOPO (cresce pra cima quando expande, não desloca text-1).
             text-1, IG e botão ficam ancorados no bottom via justify-content: flex-end. -->
        <div class="fund-overlay-mobile">
          <p class="fund-overlay-text fund-overlay-text-1">Empreendedora, visionária e idealizadora do REC. Em 2018 começou um movimento que virou ecossistema.</p>
          <button type="button" class="fund-expand-btn" data-fund-expand>ver mais →</button>
        </div>
      </div>

      <!-- Texto longo: visível no desktop, expandível no mobile -->
      <div class="fund-text" data-fund-text>
        <span class="uppercase-label fund-header-desktop" style="color: var(--rec-teal)">fundadora</span>
        <h2 class="fund-header-desktop">Francielle Caleffi.</h2>
        <p class="fund-role fund-header-desktop">CEO e fundadora</p>
        <p>Empreendedora, visionária e idealizadora do REC. Em 2018 começou um movimento de empresas no Rio Grande do Sul que virou um ecossistema. Hoje conectando mais de 90 empresas e com mais de 10 mil conexões geradas.</p>
        <p>Acredita que <em>movimento gera movimento</em>. Que ecossistemas fortes nascem quando pessoas, empresas e oportunidades se conectam com intenção, visão e confiança.</p>
        <a href="https://instagram.com/francicaleffi" target="_blank" rel="noopener" class="fund-cta">@francicaleffi →</a>
      </div>
    </div>
  </section>

  <!-- IMPACT FEATURE — removida no mobile a pedido do usuário; mantém no desktop -->
  <section class="home-impact desktop-only" data-reveal>
    <div class="impact-inner">
      <div class="impact-text">
        <span class="uppercase-label" style="color: var(--rec-teal)">oito anos</span>
        <h2>O movimento <em>cresce</em> com quem se move.</h2>
        <p>Nascemos conectando empresas. Hoje, somos um ecossistema que envolve negócios, marketing, eventos e parcerias estratégicas impulsionando conexões que geram crescimento real.</p>
        <a href="/eventos" class="impact-cta">ver a linha do tempo →</a>
      </div>
      <div class="impact-image">
        <IllustrativeImg src="/illustrative/comunidade-hero.jpg" alt="Empresas REC reunidas em encontro presencial" ratio="4/5" mood="warm" />
      </div>
    </div>
  </section>

  <!-- INSTAGRAM FEED -->
  <InstagramFeed />

  <!-- LATEST FROM THE BLOG -->
  <section class="home-blog" data-reveal>
    <div class="blog-inner">
      <header class="blog-header">
        <span class="uppercase-label" style="color: var(--rec-teal)">do nosso blog</span>
        <h2>Pensamento <em>sem a pressa do feed.</em></h2>
        <a href="/blog" class="blog-all">ver todos os posts →</a>
      </header>
      <div class="blog-grid">
        {recentPosts.map(post => {
          const dateStr = post.data.publishedAt.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' }).replace('.', '')
          return (
            <a href={`/blog/${post.id}/`} class="home-post-card">
              {post.data.cover ? (
                <div class="home-post-cover">
                  <IllustrativeImg src={post.data.cover} alt={post.data.coverAlt || ''} ratio="16/9" mood="warm" />
                </div>
              ) : (
                <div class="home-post-cover home-post-cover--placeholder" aria-hidden="true">
                  <span class="home-post-placeholder-label">{post.data.pillar}</span>
                </div>
              )}
              <div class="home-post-body">
                <div class="home-post-meta">
                  <PillarChip pillar={post.data.pillar} />
                  <time datetime={post.data.publishedAt.toISOString()}>{dateStr}</time>
                </div>
                <h3>{post.data.title}</h3>
                <p>{post.data.excerpt}</p>
                <span class="home-post-cta">ler →</span>
              </div>
            </a>
          )
        })}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="home-final" data-reveal>
    <div class="final-inner">
      <h2><em>Pronto pra</em> entrar no <span class="final-light">movimento?</span></h2>
      <p>Fale com a gente e descubra se o REC é o seu lugar.</p>
      <a href={whatsappLink(messages.homeCta)} target="_blank" rel="noopener" class="final-cta">Entrar no ecossistema →</a>
    </div>
  </section>
</BaseLayout>

<style>
/* Reveal-on-scroll baseline */
[data-reveal] { opacity: 0; transform: translateY(28px); transition: opacity var(--motion-slow) var(--easing), transform var(--motion-slow) var(--easing); }
[data-reveal].in-view { opacity: 1; transform: translateY(0); }

/* Lift section content above the scroll-graphics layer (which lives at z-index: 1
   inside <main> with mix-blend-mode: multiply). Keeps headlines/text crisp. */
.paths-inner,
.fund-inner,
.impact-inner,
.blog-inner,
.final-inner { position: relative; z-index: 5; }

/* THREE PATHS */
.home-paths { padding: var(--space-16) var(--space-6); background: linear-gradient(180deg, #ffffff 0%, rgba(184,224,221,0.18) 100%); }
.paths-inner { max-width: var(--container-max); margin: 0 auto; }
/* Stats compactos — APENAS mobile (desktop tem stats no hero do vídeo) */
.paths-stats-mobile { display: none; }
@media (max-width: 640px) {
  .paths-stats-mobile {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-2);
    padding: var(--space-3) var(--space-2);
    margin-bottom: var(--space-6);
    border-bottom: 1px solid rgba(0,161,152,0.18);
  }
  .paths-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    text-align: center;
  }
  .paths-stat-num {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--rec-blue);
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .paths-stat-label {
    font-family: var(--font-ui);
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(1,38,89,0.55);
  }
}
.paths-header { text-align: center; margin-bottom: var(--space-12); }
.paths-header h2 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; letter-spacing: var(--letter-tight); margin-top: var(--space-3); line-height: 1.1; color: var(--rec-blue); }
.paths-header h2 em { color: var(--rec-teal); font-style: italic; }
.paths-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); max-width: 1140px; margin: 0 auto; }
.path { position: relative; padding: var(--space-12) var(--space-7) var(--space-8); border-radius: 20px; display: flex; flex-direction: column; gap: var(--space-3); transition: transform var(--motion-fast) var(--easing), box-shadow var(--motion-fast) var(--easing); overflow: hidden; }
.path:hover { transform: translateY(-6px); }
.path-comunidade { background: linear-gradient(160deg, rgba(0,161,152,0.10) 0%, rgba(0,161,152,0.02) 100%); border: 1px solid rgba(0,161,152,0.22); }
.path-comunidade:hover { box-shadow: 0 16px 40px rgba(0,161,152,0.20); }
.path-hub { background: linear-gradient(160deg, rgba(1,38,89,0.08) 0%, rgba(1,38,89,0.02) 100%); border: 1px solid rgba(1,38,89,0.22); }
.path-hub:hover { box-shadow: 0 16px 40px rgba(1,38,89,0.20); }
.path-eventos { background: linear-gradient(160deg, rgba(184,224,221,0.45) 0%, rgba(244,239,230,0.45) 100%); border: 1px solid rgba(0,161,152,0.30); }
.path-eventos:hover { box-shadow: 0 16px 40px rgba(0,161,152,0.18); }
.path-num { position: absolute; top: var(--space-4); right: var(--space-6); font-size: 4rem; font-weight: 800; color: rgba(1,38,89,0.10); line-height: 1; letter-spacing: var(--letter-tight); pointer-events: none; }
.path-tag { font-size: var(--type-micro); letter-spacing: 0.18em; text-transform: uppercase; font-weight: 700; }
.path-comunidade .path-tag { color: var(--rec-teal); }
.path-hub .path-tag { color: var(--rec-blue); }
.path-eventos .path-tag { color: var(--rec-blue); }
.path h3 { font-size: clamp(1.4rem, 2.5vw, 1.85rem); font-weight: 800; letter-spacing: var(--letter-tight); margin-top: var(--space-2); color: var(--rec-blue); }
.path p { color: #2c3a48; line-height: 1.6; font-size: var(--type-small); }
.path-bullets { list-style: none; padding: 0; margin: var(--space-3) 0; display: flex; flex-direction: column; gap: var(--space-2); }
.path-bullets li { font-size: var(--type-small); color: #2c3a48; padding-left: 18px; position: relative; }
.path-bullets li::before { content: ''; position: absolute; left: 0; top: 8px; width: 8px; height: 8px; border-radius: 50%; background: var(--rec-teal); }
.path-hub .path-bullets li::before { background: var(--rec-blue); }
.path-eventos .path-bullets li::before { background: var(--rec-blue); }
.path-cta { margin-top: auto; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; font-size: var(--type-micro); padding-top: var(--space-4); border-top: 1px solid rgba(1,38,89,0.10); transition: color var(--motion-fast) var(--easing); }
.path-comunidade .path-cta { color: var(--rec-teal); }
.path-hub .path-cta { color: var(--rec-blue); }
.path-eventos .path-cta { color: var(--rec-teal); }
.path-cta:hover { color: var(--rec-blue); }
@media (max-width: 980px) { .paths-grid { grid-template-columns: 1fr; max-width: 560px; } }

/* FUNDADORA */
.home-fundadora { padding: var(--space-16) var(--space-6); background: linear-gradient(180deg, rgba(184,224,221,0.18) 0%, rgba(244,239,230,0.45) 100%); }
.fund-inner { max-width: var(--container-max); margin: 0 auto; display: grid; grid-template-columns: 1fr 1.2fr; gap: var(--space-12); align-items: center; }
/* Header e overlay mobile escondidos no desktop (default) */
.fund-header { display: none; }
.fund-overlay-mobile { display: none; }
.fund-image { position: relative; aspect-ratio: 4/5; max-width: 440px; border-radius: 16px; overflow: hidden; background: linear-gradient(135deg, #006d68 0%, #1cc4ba 100%); box-shadow: 0 16px 48px rgba(0,109,104,0.18); }
.fund-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
.fund-image.fund-image-fallback::after {
  content: 'foto da fundadora';
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.7);
  font-size: var(--type-micro);
  letter-spacing: 0.18em;
  text-transform: uppercase;
}
.fund-text h2 { font-size: clamp(2.5rem, 5vw, 3.5rem); font-weight: 800; letter-spacing: var(--letter-tight); margin: var(--space-3) 0 var(--space-2); line-height: 1; }
.fund-role { font-size: var(--type-micro); letter-spacing: 0.15em; text-transform: uppercase; color: var(--rec-purple); font-weight: 700; margin-bottom: var(--space-5); }
.fund-text p { color: #556; line-height: 1.7; max-width: 540px; margin-bottom: var(--space-3); font-size: var(--type-body); }
.fund-text p em { color: var(--rec-teal); font-weight: 600; font-style: italic; }
.fund-cta { display: inline-block; margin-top: var(--space-3); color: var(--rec-purple); font-weight: 700; letter-spacing: 0.05em; transition: color var(--motion-fast) var(--easing); }
.fund-cta:hover { color: var(--rec-teal); }
@media (max-width: 800px) {
  .fund-inner { grid-template-columns: 1fr; gap: var(--space-8); }
  .fund-image { max-width: 320px; margin: 0 auto; }
}

/* IMPACT WITH IMAGE */
.home-impact { padding: var(--space-16) var(--space-6); background: linear-gradient(180deg, rgba(244,239,230,0.45) 0%, rgba(0,161,152,0.10) 100%); }
.impact-inner { max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: 1.7fr 1fr; gap: var(--space-12); align-items: center; }
.impact-text h2 { font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 800; letter-spacing: var(--letter-tight); margin: var(--space-3) 0 var(--space-4); line-height: 1.05; }
.impact-text h2 em { color: var(--rec-teal); font-style: italic; }
.impact-text p { color: #556; line-height: 1.7; max-width: 480px; margin-bottom: var(--space-6); }
.impact-image { max-width: 320px; justify-self: end; width: 100%; }
.impact-cta { color: var(--rec-purple); font-weight: 700; letter-spacing: 0.05em; transition: color var(--motion-fast) var(--easing); }
.impact-cta:hover { color: var(--rec-teal); }
@media (max-width: 760px) {
  .impact-inner { grid-template-columns: 1fr; gap: var(--space-8); }
  .impact-image { order: -1; max-width: 280px; justify-self: center; }
}

/* BLOG */
.home-blog { padding: var(--space-16) var(--space-6); background: linear-gradient(180deg, #ffffff 0%, #eaf3f8 100%); }
.blog-inner { max-width: var(--container-max); margin: 0 auto; }
.blog-header { display: flex; flex-direction: column; align-items: center; text-align: center; margin-bottom: var(--space-8); position: relative; }
.blog-header h2 { font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 800; letter-spacing: var(--letter-tight); margin: var(--space-3) 0; }
.blog-header h2 em { color: var(--rec-teal); font-style: italic; }
.blog-all { color: var(--rec-purple); font-weight: 600; font-size: var(--type-small); transition: color var(--motion-fast) var(--easing); }
.blog-all:hover { color: var(--rec-teal); }
.blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
.home-post-card { display: flex; flex-direction: column; gap: var(--space-3); border-radius: 12px; overflow: hidden; background: #fff; border: 1px solid rgba(37,52,57,0.08); transition: transform var(--motion-fast) var(--easing), box-shadow var(--motion-fast) var(--easing); }
.home-post-card:hover { transform: translateY(-4px); box-shadow: 0 12px 28px rgba(62,64,149,0.1); border-color: var(--rec-teal); }
.home-post-cover { width: 100%; aspect-ratio: 16/9; overflow: hidden; }
.home-post-cover--placeholder {
  background: var(--rec-navy);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.home-post-cover--placeholder::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 3px;
  background: var(--rec-teal);
}
.home-post-placeholder-label {
  font-family: var(--font-display, serif);
  font-size: clamp(1rem, 3vw, 1.8rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  text-transform: uppercase;
  color: var(--rec-teal);
  opacity: 0.35;
}
.home-post-body { padding: var(--space-4) var(--space-5) var(--space-5); display: flex; flex-direction: column; gap: var(--space-3); }
.home-post-meta { display: flex; align-items: center; gap: var(--space-3); }
.home-post-meta time { font-size: var(--type-micro); color: #667; letter-spacing: 0.05em; }
.home-post-body h3 { font-size: 1.15rem; line-height: 1.3; color: var(--rec-dark); font-weight: 800; letter-spacing: var(--letter-tight); }
.home-post-body p { font-size: var(--type-small); color: #556; line-height: 1.55; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.home-post-cta { font-size: var(--type-micro); font-weight: 700; letter-spacing: 0.12em; color: var(--rec-purple); text-transform: uppercase; margin-top: auto; }
.home-post-card:hover .home-post-cta { color: var(--rec-teal); }
@media (max-width: 900px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
/* MOBILE — blog vira carrossel horizontal scroll-snap (1.15 cards visíveis) */
@media (max-width: 640px) {
  .home-blog { padding: var(--space-12) 0 var(--space-12) var(--space-4); }
  .blog-header { padding-right: var(--space-4); margin-bottom: var(--space-6); }
  .blog-grid {
    display: flex;
    grid-template-columns: none;
    gap: var(--space-4);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: var(--space-2) var(--space-4) var(--space-2) 0;
  }
  .blog-grid::-webkit-scrollbar { display: none; }
  .home-post-card {
    flex: 0 0 82vw;
    scroll-snap-align: start;
  }
}

/* FINAL CTA — smooth gradient continues from blog (light blue) into deep navy.
   Transitions to dark fast so the white h2/p stay legible inside the section. */
.home-final {
  padding: var(--space-24) var(--space-6);
  background: linear-gradient(
    180deg,
    #eaf3f8  0%,
    #d9ecf5  3%,
    #c5e2f1  6%,
    #acd5ec 10%,
    #8ec5e5 15%,
    #6eb1db 21%,
    #509bce 27%,
    #3583bf 33%,
    #1f6caf 40%,
    #10589e 47%,
    #07468d 54%,
    #05377b 62%,
    #042a67 72%,
    #031d52 83%,
    #042050 100%
  );
  color: #fff; text-align: center; position: relative; overflow: hidden;
}
.home-final::after {
  content: ''; position: absolute; inset: 0; pointer-events: none;
  opacity: 0.06; z-index: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 180px 180px; mix-blend-mode: overlay;
}
.home-final::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 22%;
  pointer-events: none; z-index: 1;
