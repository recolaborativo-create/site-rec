<script>
  import { initReveal } from '../utils/reveal'
  initReveal()

  // Fundadora mobile: "ver mais" revela o bloco de texto ABAIXO da imagem
  const fundBtn = document.querySelector<HTMLButtonElement>('[data-fund-expand]')
  const fundText = document.querySelector<HTMLElement>('[data-fund-text]')
  if (fundBtn && fundText) {
    fundBtn.addEventListener('click', () => {
      const open = fundText.classList.toggle('is-open')
      fundBtn.innerHTML = open ? 'ver menos ↑' : 'ver mais →'
    })
  }
</script>
