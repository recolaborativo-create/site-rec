---
import BaseLayout from '../layouts/BaseLayout.astro'
import { externalLinks } from '../data/nav'
import { whatsappLink } from '../utils/whatsapp'
import { loadAllPartners } from '../data/partners-merged'

const partners = await loadAllPartners()
const totalEmpresas = partners.length
const proximoNumero = totalEmpresas + 1
---
<BaseLayout
  title="Contato"
  description="Antes de virar parceria, vira conversa. Fale com o REC pelo WhatsApp, Instagram ou formulário. Atendimento humano, com resposta em até 24h."
  path="/contato"
  currentSection="Contato"
>
  <!-- ============================================
       Constelação canvas — fundo animado
       ============================================ -->
  <section class="contato-hero">
    <canvas class="constelacao-bg" data-constelacao aria-hidden="true"></canvas>

    <div class="contato-inner">
      <!-- ============================================
           Hero
           ============================================ -->
      <header class="contato-hero-text" data-reveal>
        <span class="contato-eyebrow">contato</span>
        <h1 class="contato-titulo">
          Antes de virar parceria,<br/>
          <em>vira conversa.</em>
        </h1>
        <p class="contato-lead">
          Aqui nada é automático. Nossa equipe lê cada mensagem com atenção e responde pessoalmente em até 24h. Conta o que você procura. A partir daí, conversamos sobre o melhor caminho para a sua empresa.
        </p>
      </header>

      <!-- ============================================
           Formulário conversacional
           ============================================ -->
      <form class="contato-form" data-form novalidate>
        <!-- Step 1: nome -->
        <div class="step is-active" data-step="0">
          <label class="step-label" for="campo-nome">
            <span class="step-pergunta">Como prefere ser chamado?</span>
          </label>
          <input
            type="text"
            id="campo-nome"
            name="nome"
            class="step-input"
            autocomplete="given-name"
            placeholder="seu nome ou apelido"
            required
            maxlength="60"
          />
          <button type="button" class="step-next" data-next="0">
            continuar <span aria-hidden="true">→</span>
          </button>
        </div>

        <!-- Step 2: contato -->
        <div class="step" data-step="1">
          <label class="step-label" for="campo-contato">
            <span class="step-pergunta">
              Prazer, <em data-nome-eco>...</em>. Por onde prefere ser chamado: email, whatsapp ou Instagram?
            </span>
          </label>
          <input
            type="text"
            id="campo-contato"
            name="contato"
            class="step-input"
            autocomplete="email"
            placeholder="email, whatsapp ou @instagram"
            required
            maxlength="80"
          />
          <button type="button" class="step-next" data-next="1">
            continuar <span aria-hidden="true">→</span>
          </button>
        </div>

        <!-- Step 3: mensagem -->
        <div class="step" data-step="2">
          <label class="step-label" for="campo-mensagem">
            <span class="step-pergunta">E o que te trouxe ao REC?</span>
          </label>
          <textarea
            id="campo-mensagem"
            name="mensagem"
            class="step-input step-textarea"
            placeholder="pode ser uma frase só. ex: quero conhecer a rede, tenho uma empresa que faz X, quero saber dos planos..."
            required
            rows="3"
            maxlength="400"
          ></textarea>
          <button type="submit" class="step-submit">
            entrar na constelação <span aria-hidden="true">→</span>
          </button>
        </div>

        {/* Honeypot: invisível ao usuário, bots preenchem e são silenciados. */}
        <input
          type="text"
          name="website"
          class="hp-field"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />

        <!-- Step 4: confirmação (após submit) -->
        <div class="step step-confirm" data-step="3">
          <div class="confirm-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <h2 class="confirm-titulo">
            <em data-nome-eco-final>...</em>, você é a <em>constelação Nº {proximoNumero}</em>.
          </h2>
          <p class="confirm-lead">
            Em até 24h, alguém da equipe REC te chama no <span data-contato-eco-final>contato que você deixou</span>.
          </p>
          <a
            href={whatsappLink('Acabei de mandar minha mensagem pelo site. Só queria me apresentar :)')}
            target="_blank"
            rel="noopener"
            class="confirm-cta"
          >
            quero falar agora no whatsapp →
          </a>
        </div>
      </form>

      <!-- ============================================
           Alternativa: contato direto
           ============================================ -->
      <div class="contato-direto" data-reveal>
        <div class="contato-direto-divisor"><span>ou prefere ir direto?</span></div>

        <div class="contato-direto-grid">
          <a
            href={whatsappLink('Oi! Vim pelo site do REC.')}
            target="_blank"
            rel="noopener"
            class="contato-direto-card whatsapp"
          >
            <span class="contato-direto-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
              </svg>
            </span>
            <span class="contato-direto-label">whatsapp</span>
            <span class="contato-direto-valor">{externalLinks.whatsapp.number}</span>
          </a>

          <a
            href={externalLinks.instagram.url}
            target="_blank"
            rel="noopener"
            class="contato-direto-card instagram"
          >
            <span class="contato-direto-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
            </span>
            <span class="contato-direto-label">instagram</span>
            <span class="contato-direto-valor">{externalLinks.instagram.handle}</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       CTA FINAL — padrão das outras páginas
       ============================================ -->
  <section class="contato-final" data-reveal>
    <div class="contato-final-bars" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>
    <div class="contato-final-inner">
      <span class="contato-final-eyebrow">faz parte da rede</span>
      <h2>
        Pronto pra entrar<br/>
        <em>na conversa?</em>
      </h2>
      <p>Atendimento humano. Resposta em até 24h.</p>
      <a
        href={whatsappLink('Oi! Vim pelo site do REC e quero saber mais.')}
        target="_blank"
        rel="noopener"
        class="contato-final-cta"
      >
        falar no whatsapp →
      </a>
    </div>
  </section>
</BaseLayout>

<!-- ============================================
     SCRIPTS
     ============================================ -->
<script>
  // ───────────────────────────────────────────
  // Reveal on scroll
  // ───────────────────────────────────────────
  const reveal = document.querySelectorAll('[data-reveal]')
  if (reveal.length && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('in-view'); io.unobserve(e.target) }
      })
    }, { threshold: 0.12 })
    reveal.forEach(el => io.observe(el))
  } else {
    reveal.forEach(el => el.classList.add('in-view'))
  }

  // ───────────────────────────────────────────
  // Formulário conversacional
  // ───────────────────────────────────────────
  const form = document.querySelector('[data-form]') as HTMLFormElement | null
  if (form) {
    const steps = Array.from(form.querySelectorAll<HTMLElement>('.step'))
    const nomeInput = form.querySelector<HTMLInputElement>('#campo-nome')
    const contatoInput = form.querySelector<HTMLInputElement>('#campo-contato')
    const mensagemInput = form.querySelector<HTMLTextAreaElement>('#campo-mensagem')
    const nomeEcos = form.querySelectorAll<HTMLElement>('[data-nome-eco]')
    const nomeEcoFinal = form.querySelector<HTMLElement>('[data-nome-eco-final]')
    const contatoEcoFinal = form.querySelector<HTMLElement>('[data-contato-eco-final]')
    const nextButtons = form.querySelectorAll<HTMLButtonElement>('[data-next]')

    function ativarStep(idx: number) {
      steps.forEach((s, i) => {
        s.classList.toggle('is-active', i === idx)
        s.classList.toggle('is-done', i < idx)
      })
      // Foca no input ativo
      const active = steps[idx]
      if (active) {
        const input = active.querySelector<HTMLInputElement | HTMLTextAreaElement>('input, textarea')
        if (input) setTimeout(() => input.focus(), 350)
      }
      // Trigger no canvas de constelação
      window.dispatchEvent(new CustomEvent('constelacao-pulse', { detail: { step: idx } }))
    }

    nextButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const stepIdx = Number(btn.dataset.next ?? -1)
        const stepEl = steps[stepIdx]
        const input = stepEl?.querySelector<HTMLInputElement>('input, textarea')
        if (!input) return
        if (!input.value.trim()) {
          input.classList.add('is-empty-shake')
          setTimeout(() => input.classList.remove('is-empty-shake'), 600)
          input.focus()
          return
        }
        // Atualiza o eco do nome
        if (stepIdx === 0 && nomeInput) {
          const primeiroNome = nomeInput.value.trim().split(/\s+/)[0]
          nomeEcos.forEach(el => el.textContent = primeiroNome)
        }
        ativarStep(stepIdx + 1)
      })
    })

    // Enter avança nos inputs
    ;[nomeInput, contatoInput].forEach((inp) => {
      if (!inp) return
      inp.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault()
          const stepEl = inp.closest('.step') as HTMLElement | null
          const btn = stepEl?.querySelector<HTMLButtonElement>('[data-next]')
          btn?.click()
        }
      })
    })

    // Submit
    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const nome = nomeInput?.value.trim() || ''
      const contato = contatoInput?.value.trim() || ''
      const mensagem = mensagemInput?.value.trim() || ''
      if (!nome || !contato || !mensagem) return

      // Animação: novo ponto entra na constelação
      window.dispatchEvent(new CustomEvent('constelacao-novo-ponto'))

      // Atualiza confirmação
      if (nomeEcoFinal) nomeEcoFinal.textContent = nome.split(/\s+/)[0]
      if (contatoEcoFinal) contatoEcoFinal.textContent = contato

      // Move pro step de confirmação
      ativarStep(3)

      // Tenta enviar via API; se falhar, abre WhatsApp como fallback
      const hp = form?.querySelector<HTMLInputElement>('input[name="website"]')
      try {
        await fetch('/api/contato', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ nome, contato, mensagem, website: hp?.value ?? '' }),
        })
      } catch {
        // sem backend ainda — tudo bem, animação e WhatsApp resolvem
      }
    })
  }

  // ───────────────────────────────────────────
  // Canvas constelação — minimalista, suave
  // ───────────────────────────────────────────
  const canvas = document.querySelector<HTMLCanvasElement>('[data-constelacao]')
  if (canvas) {
    const ctx = canvas.getContext('2d')!
    let w = 0, h = 0, dpr = 1
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    interface Ponto {
      x: number; y: number
      baseX: number; baseY: number
      vx: number; vy: number
      raio: number
      pulse: number
      pulseSpeed: number
      isNovo?: boolean
      ageNovo?: number
    }

    const pontos: Ponto[] = []
    let conexoesNovas: { from: Ponto; to: Ponto; progress: number }[] = []

    function rng(seed: number) {
      let s = seed
      return () => { s = (s * 9301 + 49297) % 233280; return s / 233280 }
    }
    const rand = rng(42)

    function setup() {
      dpr = Math.min(window.devicePixelRatio || 1, 2)
      w = canvas!.clientWidth
      h = canvas!.clientHeight
      canvas!.width = w * dpr
      canvas!.height = h * dpr
      ctx.scale(dpr, dpr)

      pontos.length = 0
      // Distribuição: 18 pontos em grid + jitter (sensação de constelação real)
      const cols = 6
      const rows = 3
      const cellW = w / cols
      const cellH = h / rows
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          const baseX = c * cellW + cellW / 2 + (rand() - 0.5) * cellW * 0.6
          const baseY = r * cellH + cellH / 2 + (rand() - 0.5) * cellH * 0.6
          pontos.push({
            x: baseX, y: baseY,
            baseX, baseY,
            vx: 0, vy: 0,
            raio: 1.4 + rand() * 2.2,
            pulse: rand() * Math.PI * 2,
            pulseSpeed: 0.005 + rand() * 0.015,
          })
        }
      }
    }

    function desenha() {
      ctx.clearRect(0, 0, w, h)

      // Atualiza posições com pulso suave
      for (const p of pontos) {
        if (!reducedMotion) {
          p.pulse += p.pulseSpeed
          p.x = p.baseX + Math.cos(p.pulse) * 1.5
          p.y = p.baseY + Math.sin(p.pulse * 0.8) * 1.5
        }
        if (p.isNovo && p.ageNovo !== undefined) {
          p.ageNovo += 1
        }
      }

      // Linhas — só entre pontos próximos
      ctx.lineWidth = 1
      for (let i = 0; i < pontos.length; i++) {
        for (let j = i + 1; j < pontos.length; j++) {
          const a = pontos[i], b = pontos[j]
          const dx = a.x - b.x, dy = a.y - b.y
          const dist = Math.hypot(dx, dy)
          const limite = Math.min(w, h) * 0.18
          if (dist < limite) {
            const alpha = (1 - dist / limite) * 0.08
            ctx.strokeStyle = `rgba(0, 161, 152, ${alpha})`
            ctx.beginPath()
            ctx.moveTo(a.x, a.y)
            ctx.lineTo(b.x, b.y)
            ctx.stroke()
          }
        }
      }

      // Conexões "explodindo" para o novo ponto
      conexoesNovas = conexoesNovas.filter(c => {
        c.progress = Math.min(1, c.progress + 0.02)
        const x = c.from.x + (c.to.x - c.from.x) * c.progress
        const y = c.from.y + (c.to.y - c.from.y) * c.progress
        ctx.strokeStyle = `rgba(0, 161, 152, ${0.6 * (1 - Math.abs(c.progress - 0.5) * 2)})`
        ctx.lineWidth = 1.6
        ctx.beginPath()
        ctx.moveTo(c.from.x, c.from.y)
        ctx.lineTo(x, y)
        ctx.stroke()
        return c.progress < 1
      })

      // Pontos
      for (const p of pontos) {
        const alphaPulse = 0.55 + 0.25 * Math.sin(p.pulse * 2)
        if (p.isNovo) {
          // Glow forte pro ponto novo
          const age = p.ageNovo ?? 0
          const grow = Math.min(1, age / 40)
          const raioFinal = (4 + Math.sin(age * 0.1) * 1.2) * grow
          const grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, raioFinal * 6)
          grad.addColorStop(0, 'rgba(255, 200, 60, 0.95)')
          grad.addColorStop(0.4, 'rgba(255, 200, 60, 0.35)')
          grad.addColorStop(1, 'rgba(255, 200, 60, 0)')
          ctx.fillStyle = grad
          ctx.beginPath()
          ctx.arc(p.x, p.y, raioFinal * 6, 0, Math.PI * 2)
          ctx.fill()

          ctx.fillStyle = '#FFC83C'
          ctx.beginPath()
          ctx.arc(p.x, p.y, raioFinal, 0, Math.PI * 2)
          ctx.fill()
        } else {
          ctx.fillStyle = `rgba(0, 161, 152, ${alphaPulse * 0.65})`
          ctx.beginPath()
          ctx.arc(p.x, p.y, p.raio, 0, Math.PI * 2)
          ctx.fill()

          // Halo
          ctx.fillStyle = `rgba(0, 161, 152, ${alphaPulse * 0.12})`
          ctx.beginPath()
          ctx.arc(p.x, p.y, p.raio * 3, 0, Math.PI * 2)
          ctx.fill()
        }
      }

      requestAnimationFrame(desenha)
    }

    // Brilho extra a cada step preenchido
    window.addEventListener('constelacao-pulse', (e: any) => {
      const step = e.detail?.step ?? 0
      // acende 3 pontos aleatórios brevemente — sensação que algo "responde"
      const candidatos = pontos.filter(p => !p.isNovo)
      for (let i = 0; i < Math.min(3 + step, candidatos.length); i++) {
        const p = candidatos[Math.floor(Math.random() * candidatos.length)]
        p.pulse = 0
        p.pulseSpeed = 0.04
        setTimeout(() => { p.pulseSpeed = 0.005 + Math.random() * 0.015 }, 1200)
      }
    })

    // Submit → novo ponto + conexões
    window.addEventListener('constelacao-novo-ponto', () => {
      const novo: Ponto = {
        x: w / 2, y: h / 2,
        baseX: w / 2, baseY: h / 2,
        vx: 0, vy: 0,
        raio: 3,
        pulse: 0,
        pulseSpeed: 0.04,
        isNovo: true,
        ageNovo: 0,
      }
      pontos.push(novo)

      // Conecta com os 5 mais próximos
      const ordenados = [...pontos]
        .filter(p => p !== novo)
        .sort((a, b) => Math.hypot(a.x - novo.x, a.y - novo.y) - Math.hypot(b.x - novo.x, b.y - novo.y))
        .slice(0, 5)
      ordenados.forEach((p, i) => {
        setTimeout(() => {
          conexoesNovas.push({ from: novo, to: p, progress: 0 })
        }, i * 180)
      })
    })

    setup()
    desenha()
    let resizeTimer: number | undefined
    window.addEventListener('resize', () => {
      window.clearTimeout(resizeTimer)
      resizeTimer = window.setTimeout(setup, 200)
    })
  }
</script>

<!-- ============================================
     ESTILOS
     ============================================ -->
<style>
[data-reveal] {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity var(--motion-slow) var(--easing), transform var(--motion-slow) var(--easing);
}
[data-reveal].in-view {
  opacity: 1;
  transform: translateY(0);
}

/* ============================================
   HERO + CANVAS DE FUNDO
   ============================================ */
.contato-hero {
  position: relative;
  min-height: calc(100vh - 80px);
  min-height: calc(100dvh - 80px);
  overflow: hidden;
  background:
    radial-gradient(ellipse at top right, rgba(0,161,152,0.06) 0%, transparent 55%),
    radial-gradient(ellipse at bottom left, rgba(1,38,89,0.04) 0%, transparent 55%),
    linear-gradient(180deg, #ffffff 0%, #fbfcfe 100%);
  padding: var(--space-16) var(--space-6) var(--space-20);
  display: flex;
  align-items: center;
}
.constelacao-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}
.contato-inner {
  position: relative;
  z-index: 1;
  max-width: 720px;
  margin: 0 auto;
  width: 100%;
}

/* ============================================
   HERO TEXT
   ============================================ */
.contato-hero-text {
  text-align: center;
  margin-bottom: var(--space-10);
}
.contato-eyebrow {
  display: inline-block;
  font-family: var(--font-ui);
  font-size: var(--type-micro);
  font-weight: 700;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--rec-teal);
  padding: 6px 16px;
  border: 1px solid rgba(0,161,152,0.3);
  border-radius: 999px;
  margin-bottom: var(--space-5);
}
.contato-titulo {
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 5.6vw, 4rem);
  font-weight: 200;
  line-height: 1.04;
  letter-spacing: -0.035em;
  color: var(--rec-blue);
  margin: 0 0 var(--space-5);
}
.contato-titulo em {
  color: var(--rec-teal);
  font-style: italic;
  font-weight: 300;
}
.contato-lead {
  font-size: clamp(1rem, 1.3vw, 1.12rem);
  line-height: 1.65;
  color: rgba(1,38,89,0.72);
  max-width: 540px;
  margin: 0 auto;
}

/* ============================================
   FORMULÁRIO CONVERSACIONAL
   ============================================ */
.contato-form {
  position: relative;
  background: rgba(255,255,255,0.78);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border: 1px solid rgba(0,161,152,0.18);
  border-radius: 24px;
  padding: var(--space-8) var(--space-7);
  box-shadow: 0 12px 48px rgba(1,38,89,0.08);
  min-height: 280px;
}
.step {
  display: none;
  animation: stepIn 540ms cubic-bezier(0.22, 1, 0.36, 1);
}
.step.is-active {
  display: block;
}
@keyframes stepIn {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}
.step-label {
  display: block;
  margin-bottom: var(--space-4);
}
.step-pergunta {
  font-family: var(--font-display);
  font-size: clamp(1.4rem, 2.4vw, 1.85rem);
  font-weight: 300;
  line-height: 1.25;
  color: var(--rec-blue);
  letter-spacing: -0.02em;
}
