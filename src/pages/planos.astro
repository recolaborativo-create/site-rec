---
import BaseLayout from '../layouts/BaseLayout.astro'
import PlanTabs from '../components/plans/PlanTabs.astro'
---
<BaseLayout
  title="Planos"
  description="Adesão à comunidade ou serviços HUB Digital - dois caminhos REC."
  path="/planos"
  currentSection="Planos"
>
  <section class="planos-intro">
    <div class="intro-inner">
      <span class="uppercase-label" style="color: var(--rec-teal)">planos</span>
      <h1>Dois caminhos - <em>tu escolhe.</em></h1>
      <p class="lead">Comunidade pra entrar na rede. HUB Digital pra crescer no marketing. Cada caminho tem seus planos próprios - sem misturar.</p>
    </div>
  </section>
  <PlanTabs />
</BaseLayout>

<style>
.planos-intro { padding: var(--space-16) var(--space-6) var(--space-8); }
.intro-inner { max-width: 760px; margin: 0 auto; }
.planos-intro h1 { font-size: clamp(2rem, 5vw, 3rem); line-height: 1.05; margin: var(--space-3) 0 var(--space-4); font-weight: 800; }
.planos-intro h1 em { color: var(--rec-teal); font-style: normal; }
.lead { font-size: var(--type-body); color: #556; line-height: 1.7; max-width: 580px; }
</style>
