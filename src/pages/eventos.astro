---
// =============================================================
// /eventos — Página de eventos REC
// Timeline scroll-driven: UMA PÁGINA POR ANO, animação direcional.
// =============================================================
import BaseLayout from '../layouts/BaseLayout.astro'
import { whatsappLink, whatsappEventLink, messages } from '../utils/whatsapp'
import { getEvents, type RecEvent } from '../data/events'

// SSR: lê o Notion ao vivo a cada visita (com cache de 60s no módulo).
// Edita no Notion → aparece no site sem rebuild.
export const prerender = false
const events = await getEvents()

const monthsShort = ['jan', 'fev', 'mar', 'abr', 'mai', 'jun', 'jul', 'ago', 'set', 'out', 'nov', 'dez']

function fmtDay(iso: string) { const [, , d] = iso.split('-'); return d }
function fmtMonth(iso: string) { const [, m] = iso.split('-'); return monthsShort[parseInt(m, 10) - 1] ?? '' }
function fmtYear(iso: string) { const [y] = iso.split('-'); return y }

const statusLabels: Record<RecEvent['status'], string> = {
  proximo: 'em breve',
  inscricoes: 'inscrições abertas',
  encerrado: 'encerrado',
}

const featuredEvent = events.find(e => e.featured) ?? events[0]
const otherEvents = events.filter(e => e.id !== featuredEvent?.id)

type Marco = { titulo: string; desc: string }
type YearEntry = {
  year: number
  layout: 'hero' | 'grid' | 'list' | 'duo' | 'final'
  intro?: string
  marcos: Marco[]
  isFuture?: boolean
}

const timeline: YearEntry[] = [
  {
    year: 2018, layout: 'hero', intro: 'Onde tudo começou.',
    marcos: [
      { titulo: 'Idealização do REC', desc: 'Nasce a ideia de criar uma rede colaborativa, gratuita para empreendedores. Primeiro grupo, primeiras conexões.' },
    ],
  },
  {
    year: 2019, layout: 'duo', intro: 'Os primeiros passos.',
    marcos: [
      { titulo: 'Primeiros encontros', desc: 'Eventos presenciais reúnem um grupo seleto de empreendedores dispostos a crescer juntos.' },
      { titulo: 'Criação da comunidade', desc: 'Estruturação dos primeiros grupos e canais de comunicação da rede.' },
    ],
  },
  {
    year: 2020, layout: 'list', intro: 'Reinvenção em tempos de crise.',
    marcos: [
      { titulo: 'Adaptação ao digital', desc: 'A rede migra encontros para o online e descobre novos formatos de conexão.' },
      { titulo: 'Crescimento acelerado', desc: 'Número de membros cresce expressivamente mesmo em período de crise.' },
    ],
  },
  {
    year: 2021, layout: 'grid', intro: 'Volta dos encontros presenciais.',
    marcos: [
      { titulo: 'Primeiro grande evento', desc: 'Realização do primeiro encontro com mais de 100 participantes.' },
      { titulo: 'Expansão de setores', desc: 'A rede acolhe empreendedores de diferentes nichos e cidades.' },
    ],
  },
  {
    year: 2022, layout: 'list', intro: 'Estruturação e novos formatos.',
    marcos: [
      { titulo: 'Lançamento do Hub Online', desc: 'Nasce o núcleo estratégico de soluções empresariais.' },
      { titulo: 'Aumento significativo de parcerias', desc: 'Uma crescente nas parcerias e nos eventos da comunidade.' },
      { titulo: 'Rodadas de negócio', desc: 'Começam a surgir maiores resultados de negociações entre os empreendedores que fazem parte da comunidade.' },
    ],
  },
  {
    year: 2023, layout: 'list', intro: 'Consolidação como referência.',
    marcos: [
      { titulo: 'Nasce o Network Entre Elas', desc: 'Um evento exclusivo para empreendedoras e empresárias.' },
      { titulo: 'Evento segmentado', desc: 'Entendemos o quanto a segmentação em eventos é importante, nascendo assim um diferencial enorme.' },
      { titulo: 'Expansão regional', desc: 'Devido à presença e procura na nossa comunidade por empreendedoras e empreendedores de outras cidades.' },
    ],
  },
  {
    year: 2024, layout: 'grid', intro: 'Mais formatos, mais conexões.',
    marcos: [
      { titulo: 'Crescimento de membros', desc: 'Marca histórica de membros ativos na comunidade.' },
      { titulo: 'Novos formatos', desc: 'Workshops, imersões e mentorias no calendário oficial.' },
      { titulo: 'Parcerias estratégicas', desc: 'Acordos que ampliam os benefícios e o alcance da rede.' },
      { titulo: 'Network Entre Eles', desc: 'Nasce o movimento de networking masculino, ampliando a rede para empreendedores de diferentes segmentos.' },
    ],
  },
  {
    year: 2025, layout: 'duo', intro: 'O REC se torna referência no Rio Grande do Sul.',
    marcos: [
      { titulo: 'Network Entre Elas', desc: 'O maior e único evento segmentado do Rio Grande do Sul, com mais de 350 participantes.' },
      { titulo: 'Novo site', desc: 'Plataforma digital renovada com HUB, comunidade e eventos.' },
      { titulo: 'Uma das maiores redes RS', desc: 'Uma das maiores redes de negócios que fomenta eventos em prol do empreendedorismo no Rio Grande do Sul.' },
    ],
  },
  {
    year: 2026, layout: 'list', intro: 'Quase uma década de movimento.',
    marcos: [
      { titulo: 'Nova estruturação', desc: 'Início da nova estruturação dos nossos sistemas, ampliando autoridade e posicionamento.' },
      { titulo: 'Espaço físico REC', desc: 'Início do nosso espaço físico de conexões e soluções empresariais.' },
      { titulo: 'Maior índice de resultados', desc: 'Maior índice de indicações, parcerias e negócios entre os membros que fazem parte da comunidade.' },
      { titulo: 'Método REC', desc: 'Idealização do Método REC, um programa de aceleração empreendedora para quem está iniciando ou em transição de carreira, voltado a nano e microempreendedores em fase inicial.' },
    ],
  },
  {
    year: 2027, layout: 'final', intro: 'O próximo capítulo é com você.', isFuture: true,
    marcos: [
      { titulo: 'O que nos espera', desc: 'O futuro do REC está sendo construído agora. Faça parte desse próximo capítulo.' },
    ],
  },
]

const totalYears = timeline.length

// JSON-LD: Schema.org Event para cada evento futuro/aberto (Google rich results)
const SITE_URL = 'https://somosrecoficial.com.br'
const eventSchemas: Array<Record<string, unknown>> = events
  .filter(e => e.status !== 'encerrado')
  .map(e => {
    // Combina date + time (ex: "2026-05-25" + "19h") → ISO local America/Sao_Paulo
    const hourMatch = e.time.match(/(\d{1,2})/)
    const hour = hourMatch ? hourMatch[1].padStart(2, '0') : '19'
    return {
      '@context': 'https://schema.org',
      '@type': 'Event',
      name: e.name,
      startDate: `${e.date}T${hour}:00:00-03:00`,
      eventStatus: 'https://schema.org/EventScheduled',
      eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
      location: {
        '@type': 'Place',
        name: e.city,
        address: { '@type': 'PostalAddress', addressLocality: e.city.split(',')[0]?.trim() ?? e.city, addressCountry: 'BR' },
      },
      description: e.description,
      organizer: { '@type': 'Organization', name: 'REC Colaborativo', url: SITE_URL },
      image: `${SITE_URL}/NORMAL - FT.png`,
    }
  })

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Eventos', item: `${SITE_URL}/eventos` },
  ],
}

const eventosSchemas = [...eventSchemas, breadcrumbSchema]
---
<BaseLayout
  title="Eventos"
  description="Próximos eventos REC e nossa trajetória. Encontros, rodadas, summit e quase uma década de movimento."
  path="/eventos"
  currentSection="Eventos"
  schemas={eventosSchemas}
>

  <!-- ============================================
       1. HERO
       ============================================ -->
  <section class="ev-hero" data-reveal>
    <div class="ev-hero-inner">
      <span class="ev-eyebrow">eventos &amp; trajetória</span>
      <h1>O REC <em>acontece</em><br />presencialmente.</h1>
      <p class="ev-hero-lead">
        Encontros, rodadas, workshops e imersões para empresárias que querem crescer
        com rede. E uma trajetória de quase uma década que conta essa história.
      </p>
    </div>
  </section>

  <!-- ============================================
       2. PRÓXIMOS EVENTOS
       ============================================ -->
  <section class="ev-upcoming" id="proximos" data-reveal>
    <header class="ev-section-head">
      <span class="ev-eyebrow">próximos eventos</span>
      <h2>Onde o REC <em>acontece.</em></h2>
      <p>Encontros, rodadas e experiências para quem quer crescer com a rede.</p>
    </header>

    {featuredEvent && (
      <article class="ev-featured" data-reveal>
        <div class="ev-featured-date">
          <span class="day">{fmtDay(featuredEvent.date)}</span>
          <span class="month">{fmtMonth(featuredEvent.date)}</span>
          <span class="year">{fmtYear(featuredEvent.date)}</span>
        </div>
        <div class="ev-featured-body">
          <div class="ev-featured-meta">
            <span class="ev-tag ev-tag--type">{featuredEvent.type}</span>
            <span class={`ev-tag ev-tag--status ev-tag--${featuredEvent.status}`}>
              {statusLabels[featuredEvent.status]}
            </span>
          </div>
          <h3>{featuredEvent.name}</h3>
          <p>{featuredEvent.description}</p>
          <div class="ev-featured-info">
            <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>{featuredEvent.city}</span>
            <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>{featuredEvent.time}</span>
          </div>
          <a href={whatsappEventLink(featuredEvent.name, featuredEvent.city)} target="_blank" rel="noopener" class="ev-featured-cta">
            saber mais
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </article>
    )}

    <div class="ev-grid" data-events-grid>
      {otherEvents.map((e, i) => (
        <article class={`ev-card${i > 0 ? ' ev-card-extra' : ''}`} data-reveal style={`--reveal-delay: ${i * 80}ms`}>
          <div class="ev-card-date">
            <span class="day">{fmtDay(e.date)}</span>
            <span class="month">{fmtMonth(e.date)}</span>
          </div>
          <div class="ev-card-body">
            <div class="ev-card-meta">
              <span class="ev-tag ev-tag--type">{e.type}</span>
              <span class={`ev-tag ev-tag--status ev-tag--${e.status}`}>{statusLabels[e.status]}</span>
            </div>
            <h3>{e.name}</h3>
            <p>{e.description}</p>
            <div class="ev-card-info">
              <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>{e.city}</span>
              <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>{e.time}</span>
            </div>
            <a href={whatsappEventLink(e.name, e.city)} target="_blank" rel="noopener" class="ev-card-cta">saber mais →</a>
          </div>
        </article>
      ))}
    </div>
    <button type="button" class="ev-show-more-btn" data-events-show-more aria-expanded="false">
      ver mais eventos <span aria-hidden="true">↓</span>
    </button>
  </section>

  <!-- ============================================
       3. INTRO DA TIMELINE
       ============================================ -->
  <section class="ev-history-intro" data-reveal>
    <span class="ev-eyebrow">nossa história</span>
    <h2>Quase uma década de <em>movimento.</em></h2>
    <p>Desde a idealização até hoje, cada ano deixou uma marca.</p>
    <div class="ev-scroll-hint" aria-hidden="true">
      <span>role para descobrir</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
    </div>
  </section>

  <!-- ============================================
       4. TIMELINE — sticky + scroll-driven
       ============================================ -->
  <section
    class="ev-timeline"
    id="ev-timeline-section"
    data-total={totalYears}
    style={`--total-years: ${totalYears};`}
    aria-label="Linha do tempo do REC"
  >
    <div class="ev-timeline-sticky">

      <!-- Botões de navegação entre seções -->
      <div class="ev-section-nav" aria-label="Navegar entre seções">
        <button class="ev-section-btn" id="ev-prev-section" type="button" aria-label="Ir para seção anterior">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="18 15 12 9 6 15"/></svg>
          seção anterior
        </button>
        <button class="ev-section-btn" id="ev-next-section" type="button" aria-label="Ir para próxima seção">
          próxima seção
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
      </div>

      <!-- ── COLUNA ESQUERDA: arco + ano grande ── -->
      <div class="ev-timeline-left">
        <svg class="ev-arc" viewBox="0 0 300 700" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
          <defs>
            <linearGradient id="arcGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%"  stop-color="rgba(0,161,152,0.04)"/>
              <stop offset="45%" stop-color="rgba(0,161,152,0.32)"/>
              <stop offset="55%" stop-color="rgba(0,161,152,0.32)"/>
              <stop offset="100%" stop-color="rgba(0,161,152,0.04)"/>
            </linearGradient>
          </defs>
          <path d="M 30,60 Q 260,350 30,640" fill="none" stroke="url(#arcGrad)" stroke-width="1.5" />
        </svg>

        <!-- Pontos dos anos no arco — todos visíveis, clicáveis -->
        <div class="ev-arc-points">
          {timeline.map((y, idx) => {
            const total = timeline.length
            const t = total > 1 ? idx / (total - 1) : 0.5
            const top = 8 + t * 84
            const bx = (1-t)*(1-t)*30 + 2*t*(1-t)*260 + t*t*30
            const xPct = (bx / 300) * 100
            return (
              <button
                class:list={['ev-arc-point', { 'ev-arc-point--current': idx === 0 }]}
                data-year-idx={idx}
                style={`top: ${top}%; left: ${xPct}%;`}
                aria-label={`Ir para ${y.year}`}
                type="button"
              >
                <span class="ev-arc-point-dot"></span>
                <span class="ev-arc-point-ring" aria-hidden="true"></span>
                <span class="ev-arc-point-label">{y.year}</span>
              </button>
            )
          })}
        </div>

        <!-- Stack de anos grande (animação direcional) -->
        <div class="ev-year-stack" aria-live="polite">
          {timeline.map((y, idx) => (
            <span
              class:list={['ev-year-big', { 'is-active': idx === 0 }]}
              data-year-page={idx}
            >{y.year}</span>
          ))}
        </div>
      </div>

      <!-- ── COLUNA DIREITA: páginas de conteúdo ── -->
      <div class="ev-timeline-right">
        <div class="ev-page-stack">
          {timeline.map((y, idx) => (
            <article
              class:list={['ev-year-page', `ev-year-page--${y.layout}`, { 'is-active': idx === 0, 'ev-year-page--future': y.isFuture }]}
              data-page-index={idx}
              data-year={y.year}
              aria-hidden={idx === 0 ? 'false' : 'true'}
            >
              <!-- Elemento decorativo único por ano (posição variada) -->
              <div class="ev-deco" data-year={y.year} aria-hidden="true"></div>

              <div class="ev-page-head">
                <span class="ev-page-tag">{y.year}</span>
                {y.intro && <h3 class="ev-page-intro">{y.intro}</h3>}
              </div>

              {y.layout === 'hero' && (
                <div class="ev-marcos ev-marcos--hero">
                  {y.marcos.map(m => (
                    <div class="ev-marco-hero">
                      <h4 class="ev-marco-titulo">{m.titulo}</h4>
                      <p class="ev-marco-desc">{m.desc}</p>
                    </div>
                  ))}
                </div>
              )}

              {y.layout === 'duo' && (
                <div class="ev-marcos ev-marcos--duo">
                  {y.marcos.map((m, i) => (
                    <div class="ev-marco-item" style={`--delay: ${i * 90}ms`}>
                      <span class="ev-marco-bullet" aria-hidden="true"></span>
                      <h4 class="ev-marco-titulo">{m.titulo}</h4>
                      <p class="ev-marco-desc">{m.desc}</p>
                    </div>
                  ))}
                </div>
              )}

              {y.layout === 'list' && (
                <div class="ev-marcos ev-marcos--list">
                  {y.marcos.map((m, i) => (
                    <div class="ev-marco-row" style={`--delay: ${i * 90}ms`}>
                      <span class="ev-marco-rownum">{String(i + 1).padStart(2, '0')}</span>
                      <div>
                        <h4 class="ev-marco-titulo">{m.titulo}</h4>
                        <p class="ev-marco-desc">{m.desc}</p>
                      </div>
                    </div>
                  ))}
                </div>
              )}

              {y.layout === 'grid' && (
                <div class="ev-marcos ev-marcos--grid">
                  {y.marcos.map((m, i) => (
                    <div class="ev-marco-card" style={`--delay: ${i * 90}ms`}>
                      <span class="ev-marco-cardnum">0{i + 1}</span>
                      <h4 class="ev-marco-titulo">{m.titulo}</h4>
                      <p class="ev-marco-desc">{m.desc}</p>
                    </div>
                  ))}
                </div>
              )}

              {y.layout === 'final' && (
                <div class="ev-marcos ev-marcos--final">
                  {y.marcos.map(m => (
                    <div class="ev-marco-final">
                      <h4 class="ev-marco-titulo">{m.titulo}</h4>
                      <p class="ev-marco-desc">{m.desc}</p>
                      <a href={whatsappLink(messages.agendaTimeline)} target="_blank" rel="noopener" class="ev-marco-cta">
                        quero fazer parte
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                      </a>
                    </div>
                  ))}
                </div>
              )}

            </article>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ============================================
       5. TEXTO INFORMATIVO — sobre os eventos REC
       ============================================ -->
  <section class="ev-about" data-reveal>
    <div class="ev-about-inner">
      <span class="ev-eyebrow">eventos REC</span>
      <p class="ev-about-lead">Realizamos eventos empresariais, experiências e encontros estratégicos voltados à conexão, visibilidade, networking e geração de oportunidades para empreendedores.</p>
      <div class="ev-about-body">
        <p>Os eventos do REC acontecem em diferentes formatos, reunindo encontros estratégicos, experiências da comunidade, conexões corporativas e ativações presenciais pensadas para gerar <strong>relacionamento e negócios</strong>.</p>
        <p class="ev-about-extra">O <strong>Network Entre Elas</strong>, que só em sua última edição contou com a presença de 370 mulheres, tem como propósito fortalecer conexões estratégicas, gerar parcerias e ampliar oportunidades de negócios entre empreendedoras e empresárias femininas de diferentes segmentos e cidades.</p>
        <p class="ev-about-extra">Um dos diferenciais dos nossos eventos está na <strong>curadoria das conexões</strong>, priorizando ambientes dinâmicos e estratégicos, com constante renovação de participantes e incentivo à interação entre empreendedores de diferentes áreas.</p>
        <p class="ev-about-extra">Além disso, muitos dos espaços de fala e oportunidades dentro dos eventos são direcionados aos próprios <strong>membros da comunidade</strong>, fortalecendo autoridade, posicionamento e visibilidade empresarial.</p>
        <p>O diferencial está na <strong>curadoria das conexões</strong>. Ambientes dinâmicos e estratégicos, com renovação constante de participantes e troca entre empreendedores de diferentes áreas.</p>
      </div>
    </div>
  </section>

  <!-- ============================================
       6. CTA FINAL — igual ao hub.astro
       ============================================ -->
  <section class="ev-final" data-reveal>
    <div class="ev-final-bars" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>
    <div class="ev-final-inner">
      <h2>Faça parte do <em>próximo</em> evento.</h2>
      <p>Garanta seu lugar nos próximos encontros REC.</p>
      <a href={whatsappLink(messages.agendaFinalCta)} target="_blank" rel="noopener" class="ev-final-cta">quero participar →</a>
    </div>
  </section>

</BaseLayout>

<script>
  import { initReveal } from '../utils/reveal'
  initReveal()

  // Fix main overflow (globals.css define overflow:hidden que quebra o sticky)
  const mainEl = document.querySelector('main')
  if (mainEl) mainEl.style.overflow = 'visible'

  // "Ver mais eventos" — só ativo no mobile
  const showMoreBtn = document.querySelector<HTMLButtonElement>('[data-events-show-more]')
  const eventsGrid = document.querySelector<HTMLElement>('[data-events-grid]')
  if (showMoreBtn && eventsGrid) {
    const isMobile = window.matchMedia('(max-width: 1023px)').matches
    if (isMobile) {
      showMoreBtn.addEventListener('click', () => {
        const expanded = eventsGrid.classList.toggle('is-expanded')
        showMoreBtn.setAttribute('aria-expanded', String(expanded))
        showMoreBtn.innerHTML = expanded
          ? 'ver menos <span aria-hidden="true">↑</span>'
          : 'ver mais eventos <span aria-hidden="true">↓</span>'
      })
    } else {
      // Desktop: oculta o botão, mostra todos os eventos
      showMoreBtn.style.display = 'none'
      eventsGrid.classList.add('is-expanded')
    }
  }

  const section = document.getElementById('ev-timeline-section') as HTMLElement | null
  const nav = document.querySelector<HTMLElement>('[data-adaptive-nav]')

  if (section) {
    const total = parseInt(section.dataset.total || '1', 10)
    const pages = Array.from(section.querySelectorAll<HTMLElement>('.ev-year-page'))
    const yearBigs = Array.from(section.querySelectorAll<HTMLElement>('.ev-year-big'))
    const arcPoints = Array.from(section.querySelectorAll<HTMLButtonElement>('.ev-arc-point'))

    // ─── MOBILE: timeline vira carrossel horizontal scroll-snap ───
    // Em <=1023px, NÃO usa wheel/sticky/scroll-driven. Usa swipe nativo + dots.
    const isMobile = window.matchMedia('(max-width: 1023px)').matches

    if (isMobile) {
      // Marca todas as pages como ativas pra desbloquear opacity/pointer-events
      pages.forEach(p => p.classList.add('is-active'))
      yearBigs.forEach(y => y.classList.add('is-active'))

      // Gera os dots indicadores
      const stack = section.querySelector<HTMLElement>('.ev-page-stack')
      if (stack) {
        const dotsEl = document.createElement('div')
        dotsEl.className = 'ev-mobile-dots'
        dotsEl.setAttribute('role', 'tablist')
        dotsEl.setAttribute('aria-label', 'navegação anos')
        pages.forEach((page, i) => {
          const year = page.dataset.year || ''
          const dot = document.createElement('button')
          dot.className = 'ev-mobile-dot'
          dot.type = 'button'
          dot.dataset.idx = String(i)
          dot.setAttribute('aria-label', `ir para ${year}`)
          dot.innerHTML = `<span class="ev-mobile-dot-y">${year}</span>`
          if (i === 0) dot.classList.add('is-active')
          dot.addEventListener('click', () => {
            page.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' })
          })
          dotsEl.appendChild(dot)
        })
        // Insere os dots depois do stack
        stack.parentElement?.appendChild(dotsEl)

        // Atualiza dot ativo conforme scroll horizontal + scroll do dot pra centro
        const dots = Array.from(dotsEl.querySelectorAll<HTMLElement>('.ev-mobile-dot'))
        function activateDot(idx: number) {
          dots.forEach((d, i) => d.classList.toggle('is-active', i === idx))
          // Centraliza o dot ativo no carrossel dos dots
          const activeDot = dots[idx]
          if (activeDot) {
            const dotsRect = dotsEl.getBoundingClientRect()
            const dotRect = activeDot.getBoundingClientRect()
            const center = dotRect.left + dotRect.width / 2
            const containerCenter = dotsRect.left + dotsRect.width / 2
            const delta = center - containerCenter
            dotsEl.scrollBy({ left: delta, behavior: 'smooth' })
          }
        }
        const io = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting && e.intersectionRatio > 0.5) {
              const idx = pages.indexOf(e.target as HTMLElement)
              if (idx >= 0) activateDot(idx)
            }
          })
        }, { root: stack, threshold: [0.5] })
        pages.forEach(p => io.observe(p))
      }

      // BOTÃO seção anterior/próxima continuam funcionando
      const prevBtnM = document.getElementById('ev-prev-section')
      const nextBtnM = document.getElementById('ev-next-section')
      if (prevBtnM) prevBtnM.addEventListener('click', () => {
        const intro = document.querySelector('.ev-history-intro') as HTMLElement | null
        intro?.scrollIntoView({ behavior: 'smooth', block: 'start' })
      })
      if (nextBtnM) nextBtnM.addEventListener('click', () => {
        const about = document.querySelector('.ev-about') as HTMLElement | null
        about?.scrollIntoView({ behavior: 'smooth', block: 'start' })
      })
    } else {
    // ─── DESKTOP: lógica original com sticky + scroll-driven ───

    let currentActive = 0
    let wheelLocked = false

    function getSectionBounds() {
      const sTop = section!.offsetTop
      const usable = section!.offsetHeight - window.innerHeight
      return { sTop, usable }
    }

    function isInsideTimeline() {
      const { sTop, usable } = getSectionBounds()
      return window.scrollY >= sTop && window.scrollY <= sTop + usable
    }

    function syncScrollToIndex(index: number) {
      const { sTop, usable } = getSectionBounds()
      const target = sTop + (index / Math.max(1, total - 1)) * usable
      window.scrollTo({ top: target, behavior: 'instant' })
    }

    function apply(index: number) {
      pages.forEach((p, i) => {
        p.classList.remove('is-active', 'is-past', 'is-future')
        p.setAttribute('aria-hidden', i === index ? 'false' : 'true')
        if (i === index) p.classList.add('is-active')
        else if (i < index) p.classList.add('is-past')
        else p.classList.add('is-future')
      })
      yearBigs.forEach((y, i) => {
        y.classList.remove('is-active', 'is-past', 'is-future')
        if (i === index) y.classList.add('is-active')
        else if (i < index) y.classList.add('is-past')
        else y.classList.add('is-future')
      })
      arcPoints.forEach((p, i) => {
        p.classList.toggle('ev-arc-point--current', i === index)
      })
    }

    // Avança 1 passo via wheel — nunca pula
    // inércia de trackpad: deltaY vai caindo; ignoramos valores pequenos após o pico
    let peakDelta = 0
    let inertiaTimer: ReturnType<typeof setTimeout> | null = null

    function stepByWheel(dir: 1 | -1, absDelta: number = 100): boolean {
      // Detecta pico: se o deltaY atual for muito menor que o pico recente → inércia, ignora
      if (absDelta > peakDelta) peakDelta = absDelta
      const isInertia = peakDelta > 40 && absDelta < peakDelta * 0.35
      // Reseta pico depois de 180ms de silêncio (fim do gesto)
      if (inertiaTimer) clearTimeout(inertiaTimer)
      inertiaTimer = setTimeout(() => { peakDelta = 0 }, 180)

      if (isInertia) return true   // bloqueia scroll mas não avança ano
      if (wheelLocked) return true
      if (absDelta < 12) return true // eventos microscópicos: bloqueia, ignora

      const next = currentActive + dir
      if (next < 0 || next >= total) return false // sai → scroll normal
      apply(next)
      currentActive = next
      syncScrollToIndex(next)
      wheelLocked = true
      setTimeout(() => { wheelLocked = false }, 1000)
      return true
    }

    // Pulo direto ao clicar no arco
    function jumpToYear(index: number) {
      const clamped = Math.max(0, Math.min(total - 1, index))
      apply(clamped)
      currentActive = clamped
      wheelLocked = false
      syncScrollToIndex(clamped)
    }

    // Cliques nos pontos do arco
    arcPoints.forEach((btn, i) => {
      btn.addEventListener('click', () => jumpToYear(i))
      btn.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); jumpToYear(i) }
      })
    })

    let wheelExited = false

    // BOTÃO SEÇÃO ANTERIOR: vai para o intro da timeline
    const prevBtn = document.getElementById('ev-prev-section')
    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        wheelExited = true
        document.body.classList.remove('in-timeline')
        const historyIntro = document.querySelector('.ev-history-intro') as HTMLElement | null
        if (historyIntro) {
          historyIntro.scrollIntoView({ behavior: 'smooth', block: 'start' })
        }
      })
    }

    // BOTÃO PRÓXIMA SEÇÃO: vai para a seção "sobre os eventos"
    const nextBtn = document.getElementById('ev-next-section')
    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        wheelExited = true
        document.body.classList.remove('in-timeline')
        const sectionEnd = section.offsetTop + section.offsetHeight
        window.scrollTo({ top: sectionEnd, behavior: 'smooth' })
      })
    }

    // Quando entrar de novo na timeline, reativa a captura
    window.addEventListener('scroll', () => {
      if (!isInsideTimeline()) return
      if (wheelExited) wheelExited = false
    }, { passive: true })

    // WHEEL: 1 ano por evento, imune à inércia do trackpad
    window.addEventListener('wheel', (e) => {
      if (wheelExited) return
      if (!isInsideTimeline()) return
      const dir = e.deltaY > 0 ? 1 : -1
      const handled = stepByWheel(dir, Math.abs(e.deltaY))
      if (handled) { e.preventDefault(); e.stopPropagation() }
    }, { passive: false })

    // SCROLL: só para navbar (usa body class para ganhar do timer do nav-scroll.ts)
    function updateNav() {
      document.body.classList.toggle('in-timeline', isInsideTimeline())
    }
    window.addEventListener('scroll', updateNav, { passive: true })

    // Setas do teclado
    window.addEventListener('keydown', (e) => {
      if (!isInsideTimeline()) return
      if (e.key === 'ArrowDown' || e.key === 'ArrowRight') { e.preventDefault(); stepByWheel(1) }
      if (e.key === 'ArrowUp'   || e.key === 'ArrowLeft')  { e.preventDefault(); stepByWheel(-1) }
    })

    apply(0)
    } // fim do else (desktop)
  }
</script>

