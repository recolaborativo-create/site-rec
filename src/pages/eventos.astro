.ev-page-stack {
  position: relative;
  flex: 1; display: flex; align-items: center; min-height: 0;
  max-width: 720px; width: 100%;
}

/* Páginas — animação direcional */
.ev-year-page {
  position: absolute; inset: 0;
  display: flex; flex-direction: column; justify-content: center;
  gap: var(--space-5);
  opacity: 0;
  transition: opacity 650ms cubic-bezier(0.22,1,0.36,1), transform 750ms cubic-bezier(0.22,1,0.36,1);
  pointer-events: none;
  padding-right: var(--space-4);
}
.ev-year-page.is-active  { opacity: 1;  transform: translateY(0);    pointer-events: auto; }
.ev-year-page.is-past    { opacity: 0;  transform: translateY(-55px);}
.ev-year-page.is-future  { opacity: 0;  transform: translateY(55px); }

/* ── CABEÇALHO DA PÁGINA ── */
.ev-page-head { display: flex; flex-direction: column; gap: var(--space-2); }
.ev-page-tag { font-family: var(--font-ui); font-size: 0.72rem; letter-spacing: 0.3em; text-transform: uppercase; font-weight: 700; color: var(--rec-teal); }
.ev-page-intro { font-family: var(--font-display); font-size: clamp(1.4rem, 2.5vw, 1.9rem); font-weight: 300; line-height: 1.25; color: #fff; margin: 0; max-width: 560px; letter-spacing: -0.01em; }

/* ── TIPOGRAFIA BASE DOS MARCOS ── */
.ev-marco-titulo { font-family: var(--font-display); font-weight: 500; color: #fff; margin: 0; line-height: 1.2; }
.ev-marco-desc { font-size: 1rem; line-height: 1.65; color: rgba(255,255,255,0.7); margin: 0; }

/* == Layout HERO (1 marco grande) == */
.ev-marcos--hero { display: flex; flex-direction: column; gap: var(--space-3); max-width: 560px; }
.ev-marco-hero .ev-marco-titulo { font-size: clamp(2.2rem, 4.5vw, 3.2rem); font-weight: 400; line-height: 1.05; letter-spacing: -0.02em; }
.ev-marco-hero .ev-marco-desc { font-size: 1.1rem; line-height: 1.7; }

/* == Layout DUO (2 marcos com bullet) == */
.ev-marcos--duo { display: flex; flex-direction: column; gap: var(--space-6); max-width: 560px; }
.ev-marco-item {
  position: relative; padding-left: var(--space-6);
  opacity: 0; transform: translateY(18px);
  transition: opacity 500ms var(--easing) var(--delay, 0ms), transform 500ms var(--easing) var(--delay, 0ms);
}
.is-active .ev-marco-item { opacity: 1; transform: translateY(0); }
.ev-marco-bullet { position: absolute; left: 0; top: 8px; width: 12px; height: 12px; border-radius: 50%; background: var(--rec-teal); box-shadow: 0 0 0 4px rgba(0,161,152,0.15); }
.ev-marco-item .ev-marco-titulo { font-size: 1.4rem; margin-bottom: 6px; }
.ev-marco-item .ev-marco-desc { font-size: 0.98rem; }

/* == Layout LIST (3 marcos com número) == */
.ev-marcos--list { display: flex; flex-direction: column; gap: var(--space-5); max-width: 600px; }
.ev-marco-row {
  display: grid; grid-template-columns: 50px 1fr; gap: var(--space-4); align-items: start;
  opacity: 0; transform: translateX(-18px);
  transition: opacity 500ms var(--easing) var(--delay, 0ms), transform 500ms var(--easing) var(--delay, 0ms);
}
.is-active .ev-marco-row { opacity: 1; transform: translateX(0); }
.ev-marco-rownum { font-family: var(--font-display); font-size: 1.6rem; font-weight: 300; color: var(--rec-teal); line-height: 1; padding-top: 4px; border-right: 1px solid rgba(0,161,152,0.25); padding-right: var(--space-3); text-align: right; }
.ev-marco-row .ev-marco-titulo { font-size: 1.25rem; margin-bottom: 4px; }
.ev-marco-row .ev-marco-desc { font-size: 0.95rem; }

/* == Layout GRID (4 cards 2×2) == */
.ev-marcos--grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-4); max-width: 620px; }
.ev-marco-card {
  padding: var(--space-5); border: 1px solid rgba(0,161,152,0.16); border-radius: 12px; background: rgba(0,161,152,0.04);
  opacity: 0; transform: scale(0.94);
  transition: opacity 500ms var(--easing) var(--delay, 0ms), transform 500ms var(--easing) var(--delay, 0ms), background 250ms var(--easing), border-color 250ms var(--easing);
}
.is-active .ev-marco-card { opacity: 1; transform: scale(1); }
.ev-marco-card:hover { background: rgba(0,161,152,0.09); border-color: rgba(0,161,152,0.3); }
.ev-marco-cardnum { display: inline-block; font-family: var(--font-ui); font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 700; color: var(--rec-teal); margin-bottom: var(--space-2); }
.ev-marco-card .ev-marco-titulo { font-size: 1.05rem; margin-bottom: 6px; line-height: 1.3; }
.ev-marco-card .ev-marco-desc { font-size: 0.88rem; line-height: 1.55; }

/* == Layout FINAL (futuro + CTA) == */
.ev-marcos--final { display: flex; flex-direction: column; gap: var(--space-5); max-width: 560px; }
.ev-marco-final .ev-marco-titulo { font-size: clamp(2rem, 3.8vw, 2.8rem); font-weight: 400; color: var(--rec-teal); line-height: 1.1; margin-bottom: var(--space-3); }
.ev-marco-final .ev-marco-desc { font-size: 1.05rem; margin-bottom: var(--space-5); max-width: 480px; }
.ev-marco-cta { display: inline-flex; align-items: center; gap: 10px; align-self: flex-start; background: var(--rec-teal); color: #fff; padding: 16px 32px; border-radius: 999px; font-weight: 700; font-size: 0.95rem; text-transform: lowercase; letter-spacing: 0.04em; transition: transform var(--motion-fast) var(--easing), box-shadow var(--motion-fast) var(--easing), background var(--motion-fast) var(--easing); }
.ev-marco-cta svg { width: 14px; height: 14px; transition: transform var(--motion-fast) var(--easing); }
.ev-marco-cta:hover { background: #00b3a9; transform: translateY(-2px); box-shadow: 0 12px 28px rgba(0,161,152,0.4); }
.ev-marco-cta:hover svg { transform: translateX(3px); }

/* =========================================================
   ELEMENTOS DECORATIVOS — sutis, sem sobrepor texto
   Posicionados em cantos seguros, refinados
   ========================================================= */
.ev-deco {
  position: absolute;
  opacity: 0;
  pointer-events: none;
  z-index: 0;
  transition: opacity 600ms var(--easing) 200ms, transform 650ms cubic-bezier(0.22,1,0.36,1) 200ms;
}
.is-active .ev-deco { opacity: 1; }

/* 2018 — anel fino no canto inferior direito */
.ev-deco[data-year="2018"] {
  bottom: var(--space-6); right: var(--space-6);
  width: 120px; height: 120px; border-radius: 50%;
  border: 1px solid rgba(0,161,152,0.2);
  transform: scale(0.8);
}
.ev-deco[data-year="2018"]::before {
  content: ''; position: absolute;
  inset: 22px; border-radius: 50%;
  border: 1px solid rgba(0,161,152,0.1);
}
.is-active .ev-deco[data-year="2018"] { transform: scale(1); }

/* 2019 — dois círculos sobrepostos · canto inferior direito */
.ev-deco[data-year="2019"] {
  bottom: var(--space-8); right: var(--space-6);
  width: 120px; height: 70px;
  transform: scale(0.8);
}
.ev-deco[data-year="2019"]::before,
.ev-deco[data-year="2019"]::after {
  content: ''; position: absolute;
  width: 54px; height: 54px; border-radius: 50%;
  border: 1px solid rgba(0,161,152,0.22);
}
.ev-deco[data-year="2019"]::before { top: 8px; left: 0; }
.ev-deco[data-year="2019"]::after  { top: 8px; right: 0; background: rgba(0,161,152,0.04); }
.is-active .ev-deco[data-year="2019"] { transform: scale(1); }

/* 2020 — grid 3×3 de pontos · canto inferior direito */
.ev-deco[data-year="2020"] {
  bottom: var(--space-8); right: var(--space-6);
  width: 72px; height: 72px;
  background-image:
    radial-gradient(circle 2px at 16% 16%, rgba(0,161,152,0.5) 100%, transparent 100%),
    radial-gradient(circle 2px at 50% 16%, rgba(0,161,152,0.35) 100%, transparent 100%),
    radial-gradient(circle 2px at 84% 16%, rgba(0,161,152,0.25) 100%, transparent 100%),
    radial-gradient(circle 2px at 16% 50%, rgba(0,161,152,0.35) 100%, transparent 100%),
    radial-gradient(circle 2px at 50% 50%, rgba(0,161,152,0.5) 100%, transparent 100%),
    radial-gradient(circle 2px at 84% 50%, rgba(0,161,152,0.35) 100%, transparent 100%),
    radial-gradient(circle 2px at 16% 84%, rgba(0,161,152,0.25) 100%, transparent 100%),
    radial-gradient(circle 2px at 50% 84%, rgba(0,161,152,0.35) 100%, transparent 100%),
    radial-gradient(circle 2px at 84% 84%, rgba(0,161,152,0.5) 100%, transparent 100%);
  transform: rotate(8deg) scale(0.8);
}
.is-active .ev-deco[data-year="2020"] { transform: rotate(0deg) scale(1); }

/* 2021 — três barras ascendentes · canto inferior direito */
.ev-deco[data-year="2021"] {
  bottom: var(--space-8); right: var(--space-8);
  width: 42px; height: 52px;
  display: flex;
  align-items: flex-end;
  gap: 6px;
  transform: translateY(8px);
}
.ev-deco[data-year="2021"]::before {
  content: '';
  position: absolute; inset: 0;
  background:
    linear-gradient(to top, rgba(0,161,152,0.4) 100%, transparent 100%) 0 100% / 9px 60% no-repeat,
    linear-gradient(to top, rgba(0,161,152,0.35) 100%, transparent 100%) 15px 100% / 9px 78% no-repeat,
    linear-gradient(to top, rgba(0,161,152,0.45) 100%, transparent 100%) 30px 100% / 9px 100% no-repeat;
  border-radius: 2px;
}
.is-active .ev-deco[data-year="2021"] { transform: translateY(0); }

/* 2022 — losango simples · canto inferior direito */
.ev-deco[data-year="2022"] {
  bottom: var(--space-8); right: var(--space-7);
  width: 52px; height: 52px;
  border: 1px solid rgba(0,161,152,0.28);
  transform: rotate(45deg) scale(0.8);
}
.ev-deco[data-year="2022"]::before {
  content: ''; position: absolute;
  inset: 10px;
  border: 1px solid rgba(0,161,152,0.14);
}
.is-active .ev-deco[data-year="2022"] { transform: rotate(45deg) scale(1); }

/* 2023 — arco em quarto de círculo · canto inferior direito */
.ev-deco[data-year="2023"] {
  bottom: var(--space-6); right: var(--space-6);
  width: 90px; height: 90px;
  border-top: 1px solid rgba(0,161,152,0.22);
  border-left: 1px solid rgba(0,161,152,0.22);
  border-radius: 100% 0 0 0;
  transform: scale(0.75);
}
.ev-deco[data-year="2023"]::before {
  content: ''; position: absolute;
  inset: 18px 0 0 18px;
  border-top: 1px solid rgba(0,161,152,0.12);
  border-left: 1px solid rgba(0,161,152,0.12);
  border-radius: 100% 0 0 0;
}
.is-active .ev-deco[data-year="2023"] { transform: scale(1); }

/* 2024 — quatro pontos em diagonal · canto inferior direito */
.ev-deco[data-year="2024"] {
  bottom: var(--space-8); right: var(--space-6);
  width: 64px; height: 64px;
  background-image:
    radial-gradient(circle 3px at 16% 16%, rgba(0,161,152,0.5) 100%, transparent 100%),
    radial-gradient(circle 3px at 84% 16%, rgba(0,161,152,0.35) 100%, transparent 100%),
    radial-gradient(circle 3px at 16% 84%, rgba(0,161,152,0.35) 100%, transparent 100%),
    radial-gradient(circle 3px at 84% 84%, rgba(0,161,152,0.5) 100%, transparent 100%);
  transform: scale(0.8);
}
.is-active .ev-deco[data-year="2024"] { transform: scale(1); }

/* 2025 — linha horizontal com ponto central · canto inferior direito */
.ev-deco[data-year="2025"] {
  bottom: var(--space-8); right: var(--space-6);
  width: 80px; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(0,161,152,0.3), transparent);
  transform: scaleX(0.6);
}
.ev-deco[data-year="2025"]::before {
  content: ''; position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--rec-teal);
  box-shadow: 0 0 12px rgba(0,161,152,0.4);
}
.ev-deco[data-year="2025"]::after {
  content: ''; position: absolute;
  top: -24px; left: 50%;
  transform: translateX(-50%);
  width: 1px; height: 20px;
  background: linear-gradient(180deg, transparent, rgba(0,161,152,0.3));
}
.is-active .ev-deco[data-year="2025"] { transform: scaleX(1); }

/* 2026 — arco aberto · canto inferior direito (conforme pedido) */
.ev-deco[data-year="2026"] {
  bottom: var(--space-6); right: var(--space-6);
  width: 110px; height: 65px;
  border-top: 1.5px solid rgba(0,161,152,0.28);
  border-radius: 50% / 100% 100% 0 0;
  transform: scale(0.8);
}
.is-active .ev-deco[data-year="2026"] { transform: scale(1); }

/* 2027 — círculo tracejado · canto inferior direito */
.ev-deco[data-year="2027"] {
  bottom: var(--space-6); right: var(--space-6);
  width: 80px; height: 80px; border-radius: 50%;
  border: 1.5px dashed rgba(0,161,152,0.24);
  transform: scale(0.8) rotate(-15deg);
}
.ev-deco[data-year="2027"]::before {
  content: ''; position: absolute;
  inset: 14px; border-radius: 50%;
  border: 1px dashed rgba(0,161,152,0.14);
}
.is-active .ev-deco[data-year="2027"] { transform: scale(1) rotate(0deg); }

/* Navegação entre seções */
.ev-section-nav {
  position: absolute;
  top: var(--space-4);
  right: var(--space-5);
  z-index: 20;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: var(--space-2);
}
.ev-section-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  background: transparent;
  color: rgba(0,161,152,0.5);
  border: 1.5px solid rgba(0,161,152,0.22);
  border-radius: 999px;
  padding: 6px 16px;
  font-family: var(--font-ui);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 220ms var(--easing), border-color 220ms var(--easing), color 220ms var(--easing);
}
.ev-section-btn svg { width: 13px; height: 13px; stroke: currentColor; }
.ev-section-btn:hover {
  background: rgba(0,161,152,0.1);
  border-color: rgba(0,161,152,0.6);
  color: var(--rec-teal);
}

/* ── RESPONSIVO MOBILE ───────────── */
@media (max-width: 980px) {
  .ev-timeline { height: auto; background: #010e2a; }
  .ev-timeline-sticky { position: static; height: auto; grid-template-columns: 1fr; }
  .ev-timeline-left { display: none; }
  .ev-timeline-right { padding: var(--space-8) var(--space-6); background: #010e2a; }
  .ev-page-stack { position: static; display: block; max-width: 720px; margin: 0 auto; }
  .ev-year-page { position: relative; inset: auto; opacity: 1; transform: none; padding: var(--space-6) 0 var(--space-8) var(--space-6); border-left: 2px solid rgba(0,161,152,0.22); margin-bottom: var(--space-4); }
  /* Decos visíveis em cada card mobile — escala reduzida (60%) pra não competir com texto */
  .ev-deco {
    display: block;
    transform: scale(0.6) !important;
    transform-origin: bottom right;
    opacity: 0.7 !important;
  }
  .ev-marcos--grid { grid-template-columns: 1fr; }
  .ev-marco-item, .ev-marco-row, .ev-marco-card { opacity: 1; transform: none; }
}

/* =========================================================
   5. CTA FINAL — idêntico ao hub.astro
   ========================================================= */
/* ── SEÇÃO INFORMATIVA ──────────────────────────── */
.ev-about {
  background: #fff;
  padding: var(--space-20) var(--space-6);
}
.ev-about-inner {
  max-width: 860px;
  margin: 0 auto;
}
.ev-about .ev-eyebrow {
  margin-bottom: var(--space-5);
}
.ev-about-lead {
  font-family: var(--font-display);
  font-size: clamp(1.5rem, 2.6vw, 2rem);
  font-weight: 300;
  line-height: 1.3;
  color: var(--rec-blue);
  margin: 0 0 var(--space-8);
  letter-spacing: -0.01em;
  border-left: 3px solid var(--rec-teal);
  padding-left: var(--space-5);
}
.ev-about-body {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-5) var(--space-8);
}
.ev-about-body p {
  font-size: var(--type-body);
  line-height: 1.75;
  color: rgba(1,38,89,0.72);
  margin: 0;
}
.ev-about-body p strong {
  color: var(--rec-blue);
  font-weight: 600;
}
@media (max-width: 680px) {
  .ev-about-body { grid-template-columns: 1fr; }
  .ev-about-lead { font-size: 1.35rem; }
}

/* ── CTA FINAL — idêntico ao hub.astro ─────────── */
.ev-final {
  position: relative;
  overflow: hidden;
  padding: var(--space-24) var(--space-6);
  background: linear-gradient(
    180deg,
    #fbfcfe  0%,  #f5fafd  3%,  #eef6fc  6%,
    #eef6fc  9%,  #e4f0fa 12%,  #d6e9f7 16%,
    #c5dff3 20%,  #b0d2ee 24%,  #97c3e7 29%,
    #7ab0de 34%,  #5d9cd3 39%,  #4287c5 45%,
    #2c73b6 51%,  #1a60a6 57%,  #0f4e95 63%,
    #083e81 70%,  #052e6a 79%,  #031f52 89%,
    #042050 100%
  );
  text-align: center;
}
/* Noise anti-banding */
.ev-final::after {
  content: ''; position: absolute; inset: 0; pointer-events: none; opacity: 0.06; z-index: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 180px 180px; mix-blend-mode: overlay;
}
/* Branco linear no topo — elimina seam com a seção branca acima */
.ev-final::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0;
  height: 22%; pointer-events: none; z-index: 1;
  background: linear-gradient(to bottom, #fbfcfe 0%, #fbfcfe 30%, rgba(251,252,254,0) 100%);
}
.ev-final-bars { position: absolute; top: 32px; right: 5vw; display: flex; flex-direction: column; gap: 6px; pointer-events: none; z-index: 1; mix-blend-mode: multiply; }
.ev-final-bars span { display: block; border-radius: 999px; height: 10px; }
.ev-final-bars span:nth-child(1) { width: 95px; background: var(--rec-blue); }
.ev-final-bars span:nth-child(2) { width: 78px; background: var(--rec-teal); }
.ev-final-bars span:nth-child(3) { width: 48px; background: var(--rec-blue); }
@media (max-width: 768px) { .ev-final-bars { display: none; } }
.ev-final-inner { position: relative; max-width: 680px; margin: 0 auto; z-index: 2; }
.ev-final h2 { font-size: clamp(2.6rem, 6vw, 4.2rem); font-weight: 800; letter-spacing: var(--letter-tight); line-height: 1.1; margin-bottom: var(--space-4); color: var(--rec-blue); }
.ev-final h2 em { color: var(--rec-teal); font-style: normal; font-weight: 400; }
.ev-final p { color: rgba(255,255,255,0.85); line-height: 1.7; margin-bottom: var(--space-8); font-size: var(--type-body); }
.ev-final-cta {
  display: inline-block; background: transparent; color: var(--rec-teal);
  padding: 20px 60px; border-radius: 999px; border: 2px solid var(--rec-teal);
  font-weight: 700; letter-spacing: 0.08em; font-size: 1.05rem;
  transition: background var(--motion-fast) var(--easing), color var(--motion-fast) var(--easing), box-shadow var(--motion-fast) var(--easing), transform var(--motion-fast) var(--easing);
  animation: ev-cta-pulse 2.8s ease-in-out infinite;
}
.ev-final-cta:hover { background: var(--rec-teal); color: #fff; transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,161,152,0.45); animation: none; }
@keyframes ev-cta-pulse { 0%,100% { box-shadow: 0 0 0 0 rgba(0,161,152,0); } 50% { box-shadow: 0 0 0 10px rgba(0,161,152,0.18); } }

/* =========================================================
   ACESSIBILIDADE
   ========================================================= */
@media (prefers-reduced-motion: reduce) {
  .ev-year-page, .ev-year-big { transition: opacity 200ms ease; transform: none !important; }
  .ev-scroll-hint svg, .ev-final-cta { animation: none; }
  .ev-marco-item, .ev-marco-row, .ev-marco-card { opacity: 1; transform: none; transition: none; }
}

/* =========================================================
   MOBILE — Timeline vira carrossel horizontal scroll-snap
   ========================================================= */
@media (max-width: 1023px) {
  /* No mobile, botões "seção anterior/próxima" da timeline somem — usa scroll natural */
  #ev-prev-section, #ev-next-section { display: none !important; }

  /* Eventos extras escondidos até clicar "ver mais" */
  .ev-grid:not(.is-expanded) .ev-card-extra { display: none; }
}
/* Desktop: nunca mostrar o botão "ver mais eventos" */
@media (min-width: 1024px) { .ev-show-more-btn { display: none !important; } }

/* Botão "ver mais eventos" — só mobile, centralizado */
.ev-show-more-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin: var(--space-5) auto 0;
  background: transparent;
  border: 1.5px solid rgba(0,161,152,0.4);
  color: var(--rec-teal);
  padding: 12px 22px;
  border-radius: 999px;
  font-family: var(--font-ui);
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  cursor: pointer;
  transition: all var(--motion-fast) var(--easing);
  width: fit-content;
  max-width: 100%;
}
.ev-show-more-btn:hover {
