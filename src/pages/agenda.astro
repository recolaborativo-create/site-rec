---
import BaseLayout from '../layouts/BaseLayout.astro'
import Timeline from '../components/timeline/Timeline.astro'
import StatCounter from '../components/ui/StatCounter.astro'
---
<BaseLayout
  title="Agenda"
  description="Trajetória do REC e próximos encontros - 8 anos de ecossistema, 370 mulheres, 84 empresas."
  path="/agenda"
  currentSection="Agenda"
>
  <section class="agenda-hero">
    <div class="hero-inner">
      <span class="uppercase-label" style="color: var(--rec-teal)">trajetória</span>
      <h1>Onde o REC já esteve - <em>onde está indo.</em></h1>
      <div class="stats-row">
        <StatCounter target={370} label="mulheres inscritas" />
        <StatCounter target={84} label="empresas parceiras" />
        <StatCounter target={8} label="anos de ecossistema" />
      </div>
    </div>
  </section>

  <Timeline />

  <section class="agenda-cta">
    <div class="cta-inner">
      <h2>Quer estar no próximo?</h2>
      <p>Os próximos encontros são divulgados primeiro pra membras da comunidade.</p>
      <a href="/planos" class="cta-primary">entrar na comunidade →</a>
    </div>
  </section>
</BaseLayout>

<style>
.agenda-hero { padding: var(--space-16) var(--space-6) var(--space-8); }
.hero-inner { max-width: var(--container-max); margin: 0 auto; }
.agenda-hero h1 { font-size: clamp(2rem, 5vw, 3rem); line-height: 1.05; margin: var(--space-3) 0 var(--space-8); font-weight: 800; max-width: 760px; }
.agenda-hero h1 em { color: var(--rec-teal); font-style: normal; }
.stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-8); }
.agenda-cta { padding: var(--space-16) var(--space-6); background: var(--grad-soft-teal); text-align: center; }
.cta-inner h2 { font-size: 1.6rem; margin-bottom: var(--space-3); }
.cta-inner p { color: #556; margin-bottom: var(--space-6); }
.cta-primary { display: inline-block; background: var(--rec-purple); color: #fff; padding: 14px 32px; border-radius: 8px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; font-size: var(--type-small); }
@media (max-width: 600px) { .stats-row { grid-template-columns: 1fr; gap: var(--space-6); } }
</style>
