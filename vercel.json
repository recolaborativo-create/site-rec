{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/cron/generate-blog-drafts",
      "schedule": "0 9 * * 0"
    }
  ],
  "redirects": [
    { "source": "/sobre-nos", "destination": "/comunidade", "permanent": true },
    { "source": "/sobre", "destination": "/comunidade", "permanent": true },
    { "source": "/nossa-rede", "destination": "/comunidade", "permanent": true },
    { "source": "/beneficios", "destination": "/comunidade", "permanent": true },
    { "source": "/agenda", "destination": "/eventos", "permanent": true },
    { "source": "/agenda/:path*", "destination": "/eventos/:path*", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
